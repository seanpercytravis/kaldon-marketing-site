# Kaldon marketing site env vars
#
# PUBLIC_* prefix = exposed to client (Astro convention).
# Without prefix = server-only / build-only.

# PostHog (funnel + cohort + session replay + cross-domain attribution).
# Optional. If unset, PostHog snippet is not rendered and trackEvent
# falls through to Plausible only. Get the key from
# https://us.posthog.com/settings/project — it's the "Project API Key".
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Auto-blog (used by scripts/generate-blog-post.mjs and
# .github/workflows/auto-blog.yml). Server / CI only.
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Cloudflare Workers deploy (used by wrangler in CI). Server / CI only.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
