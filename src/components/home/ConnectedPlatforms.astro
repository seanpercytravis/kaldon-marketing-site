---
// ConnectedPlatforms.astro. monochrome platform wordmarks strip.
// Real SVG logos would be ideal; pending those, typographic wordmarks at
// -0.02em tracking read as intentional on a dark background.
const platforms = [
  { name: 'Amazon' },
  { name: 'Walmart' },
  { name: 'Shopify' },
  { name: 'Stripe' },
  { name: 'Meta' },
  { name: 'TikTok' },
  { name: 'Google' },
  { name: 'GoHighLevel' },
  { name: 'Etsy' },
  { name: 'Pinterest' },
];
---

<section class="hairline-t hairline-b">
  <div class="container-custom py-12 md:py-16">
    <p class="text-center text-small" style="color: var(--ghost);">
      Connected to the marketplaces, ad platforms, and tools your business runs on.
    </p>
    <div class="mt-8 flex flex-wrap justify-center items-center gap-x-8 gap-y-6 md:gap-x-12">
      {platforms.map((p) => (
        <span
          class="font-display"
          style="font-weight: 500; font-size: 18px; letter-spacing: -0.02em; color: var(--ghost);"
        >
          {p.name}
        </span>
      ))}
      <span
        class="font-mono"
        style="font-weight: 500; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); padding: 5px 10px; border: 1px solid rgba(255, 184, 0, 0.35); border-radius: 999px;"
      >
        +40 more
      </span>
    </div>
  </div>
</section>
