---
// PipelineScroll.astro — the signature moment.
// Pinned vertical-scroll → horizontal-pan across 5 phase panels via GSAP
// ScrollTrigger (containerAnimation pattern). No scroll-jacking — reversible,
// stays in natural scroll flow, collapses to vertical stack at <1024px and
// when prefers-reduced-motion is set.

const phases = [
  {
    num: '01',
    name: 'Discover',
    headline: 'Find the products the market is demanding that nobody\'s making.',
    body:
      'Kaldon reads billions of market signals — sales velocity, pricing gaps, search demand, social momentum, advertising saturation, and competitor coverage — across Amazon, Walmart, and the broader market. The output isn\'t a list of products to resell. It\'s a map of unmet demand: what people are actively asking for, what they\'re already paying for, and what nobody is shipping yet.',
    outcomes: [
      'Unmet-demand score with a clear go / no-go',
      'Validated unique value proposition your product can own',
      'Verified suppliers capable of actually manufacturing it',
    ],
  },
  {
    num: '02',
    name: 'Build',
    headline: 'A professional brand identity, in minutes, not months.',
    body:
      'Tell Kaldon about your product and it generates everything a brand designer would charge $3,000–5,000 for: product mockups, brand colors, typography, voice, and a polished brand board.',
    outcomes: [
      'Complete brand kit with product images',
      'Color palette, typography, voice guidelines',
      'Shareable brand board for partners and manufacturers',
    ],
  },
  {
    num: '03',
    name: 'Create',
    headline: 'Months of marketing content, ready in minutes.',
    body:
      'Kaldon generates social posts, product videos, landing pages, and blog articles — all on-brand, scheduled across Instagram, Facebook, LinkedIn, X, and Pinterest.',
    outcomes: [
      'Full content calendar across 5 platforms',
      'Product videos, landing pages, SEO articles',
      'Blog auto-publishes on schedule — hands-free',
    ],
  },
  {
    num: '04',
    name: 'Launch',
    headline: 'Your store, marketing, and customer pipeline — in one click.',
    body:
      'Kaldon builds your entire business infrastructure automatically: online store, email sequences, automated workflows, customer database, ad campaigns, and an AI customer support assistant.',
    outcomes: [
      'Fully operational store with checkout',
      'Email marketing, CRM, automated workflows',
      'AI customer support, ready ad campaigns',
    ],
  },
  {
    num: '05',
    name: 'Grow',
    headline: 'AI that optimizes your business while you sleep.',
    body:
      'Once you\'re live, Kaldon keeps working. It monitors ad performance and adjusts targeting, identifies at-risk customers, and generates fresh content so your social never goes quiet.',
    outcomes: [
      'AI-managed ad optimization',
      'Automated customer retention',
      'Unified performance dashboard across all channels',
    ],
  },
];
---

<section id="pipeline" class="pipeline-section">
  <!-- Intro header — static, above the pinned section -->
  <div class="pipeline-intro container-custom">
    <div class="max-w-prose mx-auto text-center">
      <span class="kicker">The Pipeline</span>
      <h2 class="font-display font-semibold text-chalk" style="font-weight: 600; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.1; letter-spacing: -0.02em;">
        Five steps from market gap to shipped business.
      </h2>
      <p class="mt-4 text-body-lg text-ghost">
        Every step feeds the next. Demand data becomes a validated product concept. The concept becomes a brand. The brand becomes content. The content populates a live store. The store data scales your ads. One continuous creation pipeline.
      </p>
    </div>
  </div>

  <!-- Pinned stage (desktop) / vertical stack (mobile + reduced motion) -->
  <div class="pipeline-stage" id="pipeline-stage">
    <div class="pipeline-track" id="pipeline-track">
      {phases.map((phase, i) => (
        <article class="phase-panel" data-phase={i}>
          <div class="phase-inner container-custom">
            <div class="phase-grid">
              <div class="phase-text">
                <span class="phase-num" aria-hidden="true">{phase.num}</span>
                <h3 class="phase-name font-display" style="font-weight: 600;">{phase.name}</h3>
                <p class="phase-headline">{phase.headline}</p>
                <p class="phase-body">{phase.body}</p>
                <ul class="phase-outcomes">
                  {phase.outcomes.map((outcome) => (
                    <li>
                      <svg class="outcome-check" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M4 10.5 L8 14.5 L16 6" stroke="#00D4FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      <span>{outcome}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="phase-visual">
                <!-- Placeholder phase illustration — typographic badge in lieu of real UI -->
                <div class="phase-badge">
                  <div class="phase-badge-bar">
                    <span class="kicker" style="margin: 0; font-size: 10px; color: var(--ghost);">Phase {phase.num} · {phase.name}</span>
                    <span class="pulse-dot" style="width: 6px; height: 6px;"></span>
                  </div>
                  <div class="phase-badge-body">
                    <p class="phase-badge-title">{phase.headline}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Progress indicator (desktop only) -->
    <div class="phase-progress" aria-hidden="true">
      {phases.map((_, i) => (
        <span class={`phase-dot ${i === 0 ? 'active' : ''}`} data-dot={i}></span>
      ))}
    </div>
  </div>
</section>

<style>
  .pipeline-section {
    background: var(--void);
    padding-block: clamp(80px, 10vw, 128px) 0;
  }
  .pipeline-intro {
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  /* ----- Desktop: pinned horizontal-pan ----- */
  .pipeline-stage {
    position: relative;
    padding-bottom: 128px;
  }
  .pipeline-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100vw;
    gap: 0;
    width: max-content;
    will-change: transform;
  }
  .phase-panel {
    width: 100vw;
    min-height: min(720px, 80vh);
    display: flex;
    align-items: center;
  }
  .phase-inner { width: 100%; }

  .phase-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
    max-width: var(--container);
    margin: 0 auto;
  }

  .phase-text { max-width: 560px; }

  .phase-num {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(72px, 10vw, 120px);
    font-weight: 400;
    line-height: 1;
    color: var(--text-quaternary);
    letter-spacing: -0.04em;
  }
  .phase-name {
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--chalk);
    margin-top: 8px;
  }
  .phase-headline {
    margin-top: 24px;
    font-size: clamp(18px, 2.2vw, 22px);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--text-secondary);
  }
  .phase-body {
    margin-top: 16px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ghost);
    max-width: 480px;
  }

  .phase-outcomes {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .phase-outcomes li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.5;
    letter-spacing: -0.005em;
  }
  .outcome-check { flex-shrink: 0; margin-top: 3px; }

  /* Phase visual card */
  .phase-visual {
    display: flex;
    justify-content: center;
  }
  .phase-badge {
    width: 100%;
    max-width: 520px;
    aspect-ratio: 5 / 4;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 16px;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .phase-badge-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--hairline);
    background: rgba(255, 255, 255, 0.015);
  }
  .phase-badge-body {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 32px;
  }
  .phase-badge-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--chalk);
  }

  /* Progress dots */
  .phase-progress {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 2;
  }
  .phase-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--graphite);
    transition: background 200ms var(--ease-out-quad), transform 200ms var(--ease-out-quad);
  }
  .phase-dot.active {
    background: var(--signal);
    transform: scale(1.3);
  }

  /* ----- Mobile / reduced motion: stack vertically ----- */
  @media (max-width: 1023px), (prefers-reduced-motion: reduce) {
    .pipeline-track {
      display: flex;
      flex-direction: column;
      width: 100%;
      grid-auto-flow: unset;
      grid-auto-columns: unset;
    }
    .phase-panel {
      width: 100%;
      min-height: unset;
      padding-block: 56px;
      border-bottom: 1px solid var(--hairline);
    }
    .phase-panel:last-child { border-bottom: none; }
    .phase-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .phase-progress { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (isDesktop && !reducedMotion) {
    const stage = document.getElementById('pipeline-stage') as HTMLElement | null;
    const track = document.getElementById('pipeline-track') as HTMLElement | null;
    const dots = document.querySelectorAll<HTMLElement>('.phase-dot');

    if (stage && track) {
      const panels = track.querySelectorAll<HTMLElement>('.phase-panel');
      const totalPanels = panels.length;

      // Horizontal pan: translate track by (trackWidth − viewportWidth).
      // ease: "none" is REQUIRED for 1:1 scroll↔position mapping.
      gsap.to(track, {
        x: () => -(track.scrollWidth - window.innerWidth),
        ease: 'none',
        scrollTrigger: {
          trigger: stage,
          pin: true,
          start: 'top top',
          end: () => '+=' + (track.scrollWidth - window.innerWidth),
          scrub: 1,
          invalidateOnRefresh: true,
          anticipatePin: 1,
          onUpdate: (self) => {
            const idx = Math.min(
              totalPanels - 1,
              Math.round(self.progress * (totalPanels - 1))
            );
            dots.forEach((d, i) => d.classList.toggle('active', i === idx));
          },
        },
      });

      // Recompute once fonts load (FOUT can shift trigger positions)
      if ('fonts' in document) {
        (document as any).fonts.ready.then(() => ScrollTrigger.refresh());
      }
    }
  }
</script>
