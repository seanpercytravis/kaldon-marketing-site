---
// ProblemSection.astro — the $10,000 problem, monochrome grid treatment.
// Replaces the rainbow 6-color grid with single-hue typographic cards.

const tools = [
  { name: 'Jungle Scout / Helium 10', role: 'Product research', cost: '$79–99/mo' },
  { name: 'Canva Pro / Looka', role: 'Brand design + logo', cost: '$15–35/mo' },
  { name: 'Jasper / Copy.ai', role: 'Content writing', cost: '$49–59/mo' },
  { name: 'Later / Hootsuite', role: 'Social scheduling', cost: '$25–49/mo' },
  { name: 'Shopify', role: 'Store platform', cost: '$39–79/mo' },
  { name: 'Meta Ads Manager', role: 'Ad management', cost: 'Your time' },
];
---

<section class="section-spacing" style="background: var(--void);">
  <div class="container-custom">
    <header class="max-w-prose mx-auto text-center mb-12 md:mb-16">
      <span class="kicker">The $10,000 Problem</span>
      <h2 class="font-display font-semibold text-chalk" style="font-weight: 600; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.1; letter-spacing: -0.02em;">
        Launching a product shouldn't require six subscriptions and two hundred hours.
      </h2>
      <p class="mt-4 text-body-lg" style="color: var(--ghost); line-height: 1.5;">
        You've got a product idea. Turning it into a real, selling business means learning six tools, paying six subscriptions, and stitching together six workflows that don't talk to each other.
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
      {tools.map((t) => (
        <div
          class="rounded-card p-6 flex items-start justify-between gap-6 transition-colors duration-150"
          style="background: var(--deep-space); border: 1px solid var(--hairline);"
        >
          <div>
            <h3 class="font-display" style="font-weight: 600; font-size: 16px; color: var(--chalk); letter-spacing: -0.01em;">
              {t.name}
            </h3>
            <p class="mt-1 text-small" style="color: var(--ghost);">
              {t.role}
            </p>
          </div>
          <span class="font-mono text-small" style="color: var(--ghost); white-space: nowrap;">
            {t.cost}
          </span>
        </div>
      ))}
    </div>

    <div class="mt-12 md:mt-16 text-center">
      <p class="text-body-lg" style="color: var(--ghost);">
        <span class="font-display" style="font-weight: 500; color: var(--text-secondary); text-decoration: line-through; text-decoration-color: rgba(139,139,163,0.4); text-decoration-thickness: 1.5px;">
          $207–400/month
        </span>
        <span class="ml-3">And none of them talk to each other.</span>
      </p>
      <p class="mt-4 font-display" style="font-weight: 500; font-size: 18px; color: var(--gold);">
        There's a better way.
      </p>
    </div>
  </div>
</section>
