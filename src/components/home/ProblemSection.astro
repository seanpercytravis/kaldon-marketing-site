---
// ProblemSection.astro. the $10,000 problem, monochrome grid treatment.
// Replaces the rainbow 6-color grid with single-hue typographic cards.

// Premium-tier pricing. These are the plans a serious seller actually needs.
// Jungle Scout Brand Owner ($129/mo) + Helium 10 Diamond ($279-299/mo) = $399+
// Jasper Business + Copy.ai Team for real volume.
// Canva Teams + Adobe CC + Midjourney Mega for professional visual output.
// Shopify Advanced ($399/mo) + premium theme + apps ($100-400/mo).
const tools = [
  { name: 'Jungle Scout Brand Owner + Helium 10 Diamond', role: 'Premium product research', cost: '$149–399/mo' },
  { name: 'ChatGPT Pro + Claude Max + Gemini Ultra', role: 'AI content generation', cost: '$60–200/mo' },
  { name: 'Jasper Business + Copy.ai Team', role: 'AI copywriting at scale', cost: '$149–349/mo' },
  { name: 'Canva Teams + Adobe CC + Midjourney Mega', role: 'Visual + brand design', cost: '$100–300/mo' },
  { name: 'Later Agency + Hootsuite Business', role: 'Social scheduling + analytics', cost: '$99–249/mo' },
  { name: 'Shopify Advanced + premium theme + apps', role: 'Store + website dev', cost: '$499–799/mo' },
];
const services = [
  { name: 'Pro product + lifestyle photography', role: 'Studio + on-location shoots', cost: '$800–2,500 / shoot' },
  { name: 'Amazon + Walmart listing agency', role: 'Premium SEO + A+ content', cost: '$800–2,000 / listing' },
  { name: 'Brand identity + copy studio', role: 'Naming, story, positioning', cost: '$2,500–8,000 / project' },
];
---

<section class="section-spacing" style="background: var(--void);">
  <div class="container-custom">
    <header class="max-w-prose mx-auto text-center mb-12 md:mb-16">
      <span class="kicker">The $50,000 Problem</span>
      <h2 class="font-display font-semibold text-chalk" style="font-weight: 600; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.1; letter-spacing: -0.02em;">
        A real DIY stack costs $18,000 to $50,000 a year. Before you ship one unit.
      </h2>
      <p class="mt-4 text-body-lg" style="color: var(--ghost); line-height: 1.5;">
        Serious sellers don't run free tiers. Research takes Jungle Scout Brand Owner plus Helium 10 Diamond. Content takes ChatGPT Pro, Jasper Business, and Copy.ai Team. Visuals take Canva Teams, Adobe CC, and Midjourney. Social takes Later Agency. Store takes Shopify Advanced plus apps. And none of it talks to each other.
      </p>
    </header>

    <div class="stack-group-label">
      <span class="font-mono" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500;">Monthly subscriptions</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
      {tools.map((t) => (
        <div
          class="rounded-card p-6 flex items-start justify-between gap-6 transition-colors duration-150"
          style="background: var(--deep-space); border: 1px solid var(--hairline);"
        >
          <div>
            <h3 class="font-display" style="font-weight: 600; font-size: 16px; color: var(--chalk); letter-spacing: -0.01em;">
              {t.name}
            </h3>
            <p class="mt-1 text-small" style="color: var(--ghost);">
              {t.role}
            </p>
          </div>
          <span class="font-mono text-small" style="color: var(--ghost); white-space: nowrap;">
            {t.cost}
          </span>
        </div>
      ))}
    </div>

    <div class="stack-group-label">
      <span class="font-mono" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500;">Per-launch services</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
      {services.map((s) => (
        <div
          class="rounded-card p-6 flex items-start justify-between gap-6 transition-colors duration-150"
          style="background: var(--deep-space); border: 1px solid var(--hairline);"
        >
          <div>
            <h3 class="font-display" style="font-weight: 600; font-size: 16px; color: var(--chalk); letter-spacing: -0.01em;">
              {s.name}
            </h3>
            <p class="mt-1 text-small" style="color: var(--ghost);">
              {s.role}
            </p>
          </div>
          <span class="font-mono text-small" style="color: var(--ghost); white-space: nowrap;">
            {s.cost}
          </span>
        </div>
      ))}
    </div>

    <div class="mt-16 md:mt-20 grid md:grid-cols-[1fr_auto_1fr] gap-8 md:gap-12 items-center max-w-4xl mx-auto">
      <div class="text-center md:text-right">
        <span class="font-mono" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500; display: block; margin-bottom: 12px;">DIY premium stack</span>
        <p class="font-mono" style="font-weight: 400; font-size: clamp(40px, 6vw, 64px); color: var(--text-secondary); letter-spacing: -0.04em; line-height: 0.95; text-decoration: line-through; text-decoration-color: rgba(139,139,163,0.35); text-decoration-thickness: 1.5px;">
          $1,056–2,296<span style="font-size: 0.5em; letter-spacing: 0; text-decoration: none; color: var(--ghost);">/mo</span>
        </p>
        <p class="font-mono" style="margin-top: 10px; font-size: 12px; color: var(--ghost); letter-spacing: 0.02em;">
          + $4,100–12,500 per launch in services
        </p>
      </div>
      <div class="font-mono text-center" style="font-size: 14px; color: var(--ghost); letter-spacing: 0.04em;">
        <span aria-hidden="true">→</span>
      </div>
      <div class="text-center md:text-left">
        <span class="font-mono" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gold); font-weight: 500; display: block; margin-bottom: 12px;">Kaldon Growth</span>
        <p class="font-mono" style="font-weight: 400; font-size: clamp(40px, 6vw, 64px); color: var(--gold); letter-spacing: -0.04em; line-height: 0.95;">
          $149<span style="font-size: 0.5em; letter-spacing: 0; color: var(--ghost);">/mo</span>
        </p>
        <p class="font-mono" style="margin-top: 10px; font-size: 12px; color: var(--gold); letter-spacing: 0.02em;">
          Everything included. No per-launch fees.
        </p>
      </div>
    </div>

    <!-- Savings anchor: headline number that drives the story home -->
    <div class="savings-callout">
      <span class="font-mono" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); font-weight: 500; display: block; margin-bottom: 8px;">Year-one savings</span>
      <p class="font-display" style="font-weight: 600; font-size: clamp(36px, 5vw, 56px); color: var(--chalk); letter-spacing: -0.03em; line-height: 1;">
        $18,000 to $50,000+ saved.
      </p>
      <p class="mt-3 text-body" style="color: var(--ghost);">
        Six premium subscriptions and every freelance service, replaced by one platform at <span style="color: var(--chalk); font-weight: 500;">$149 / mo</span>.
      </p>
    </div>

    <style>
      .stack-group-label {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 32px;
        margin-bottom: 16px;
      }
      .stack-group-label::before,
      .stack-group-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--hairline);
      }
      .stack-group-label:first-of-type {
        margin-top: 0;
      }
      .savings-callout {
        margin-top: 40px;
        padding: 32px 24px;
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
        background: var(--deep-space);
        border: 1px solid rgba(255, 184, 0, 0.25);
        border-radius: 12px;
        box-shadow: 0 0 0 1px rgba(255, 184, 0, 0.05) inset, 0 20px 40px rgba(0, 0, 0, 0.3);
      }
    </style>
  </div>
</section>
