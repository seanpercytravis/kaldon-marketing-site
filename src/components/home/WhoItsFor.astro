---
// WhoItsFor.astro — 3 cards linking to use-case pages
const segments = [
  {
    kicker: 'New Sellers',
    title: 'Find your first product with confidence.',
    body: 'Kaldon scans markets across Amazon, Walmart, and DTC to find real demand with room for a new brand. Your first analysis is free.',
    href: '/use-cases/new-sellers',
  },
  {
    kicker: 'Existing Brands',
    title: 'Automate your marketing. Expand to new channels.',
    body: 'Import your brand. Generate months of on-brand content in minutes. Expand beyond the one marketplace you\'re on.',
    href: '/use-cases/existing-brands',
  },
  {
    kicker: 'Agencies',
    title: 'Deliver $10,000 in value per client. In a day.',
    body: 'Run research, build brand identities, generate all assets, and deploy stores for clients in hours instead of weeks.',
    href: '/use-cases/agencies',
  },
];
---

<section class="section-spacing" style="background: var(--void);">
  <div class="container-custom">
    <header class="max-w-prose mx-auto text-center mb-12 md:mb-16">
      <span class="kicker">Who It's For</span>
      <h2 class="font-display font-semibold text-chalk" style="font-weight: 600; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.1; letter-spacing: -0.02em;">
        Built for the people building real businesses.
      </h2>
    </header>

    <div class="grid md:grid-cols-3 gap-4 md:gap-5">
      {segments.map((s) => (
        <a
          href={s.href}
          class="group block rounded-card p-8 transition-colors duration-150"
          style="background: var(--deep-space); border: 1px solid var(--hairline);"
        >
          <span class="kicker" style="color: var(--signal); margin-bottom: 20px;">{s.kicker}</span>
          <h3 class="font-display" style="font-weight: 600; font-size: 22px; color: var(--chalk); letter-spacing: -0.015em; line-height: 1.25;">
            {s.title}
          </h3>
          <p class="mt-3 text-body-sm" style="color: var(--ghost); line-height: 1.6;">
            {s.body}
          </p>
          <span class="link-arrow mt-6 inline-flex">
            Learn more
            <span class="arrow" aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  a.group:hover { border-color: var(--hairline-active); }
</style>
