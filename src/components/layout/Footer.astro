---
// Footer.astro — 4-column link grid + email capture + bottom bar
// Single Void background with hairline top divider (Linear pattern)
const year = new Date().getFullYear();
---

<footer class="mt-auto hairline-t" style="background: var(--void);">
  <div class="container-custom py-16 md:py-20">
    <!-- Email Capture Row -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 pb-12 mb-12 border-b border-hairline">
      <div class="max-w-md">
        <h3 class="text-h4 font-display font-semibold text-chalk" style="font-weight: 600;">
          Get eCommerce intelligence in your inbox
        </h3>
        <p class="text-body-sm text-ghost mt-2">
          Product research trends, platform updates, and launch playbooks. No spam, unsubscribe anytime.
        </p>
      </div>
      <form id="footer-email-form" class="flex flex-col sm:flex-row gap-3 w-full md:w-auto md:shrink-0">
        <label for="footer-email" class="sr-only">Your email address</label>
        <input
          id="footer-email"
          type="email"
          name="email"
          autocomplete="email"
          placeholder="you@example.com"
          required
          class="h-11 px-4 rounded-btn text-body-sm font-sans w-full sm:w-72 transition-colors"
          style="background: var(--deep-space); border: 1px solid var(--hairline); color: var(--chalk);"
        />
        <button type="submit" class="btn-primary" data-event="email_capture" style="height: 44px;">
          Subscribe
        </button>
      </form>
    </div>

    <!-- Link Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-12">
      <div>
        <p class="kicker" style="margin-bottom: 20px;">Product</p>
        <ul class="space-y-3">
          <li><a href="/features" class="text-body-sm text-ghost hover:text-chalk transition-colors">Features</a></li>
          <li><a href="/how-it-works" class="text-body-sm text-ghost hover:text-chalk transition-colors">How It Works</a></li>
          <li><a href="/pricing" class="text-body-sm text-ghost hover:text-chalk transition-colors">Pricing</a></li>
          <li><a href="/compare/research-tools" class="text-body-sm text-ghost hover:text-chalk transition-colors">Compare</a></li>
          <li><a href="/demo" class="text-body-sm text-ghost hover:text-chalk transition-colors">Demo</a></li>
        </ul>
      </div>

      <div>
        <p class="kicker" style="margin-bottom: 20px;">Company</p>
        <ul class="space-y-3">
          <li><a href="/about" class="text-body-sm text-ghost hover:text-chalk transition-colors">About</a></li>
          <li><a href="/blog" class="text-body-sm text-ghost hover:text-chalk transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-body-sm text-ghost hover:text-chalk transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <p class="kicker" style="margin-bottom: 20px;">Resources</p>
        <ul class="space-y-3">
          <li><a href="/use-cases/new-sellers" class="text-body-sm text-ghost hover:text-chalk transition-colors">New Sellers</a></li>
          <li><a href="/use-cases/existing-brands" class="text-body-sm text-ghost hover:text-chalk transition-colors">Existing Brands</a></li>
          <li><a href="/use-cases/agencies" class="text-body-sm text-ghost hover:text-chalk transition-colors">Agencies</a></li>
        </ul>
      </div>

      <div>
        <p class="kicker" style="margin-bottom: 20px;">Legal</p>
        <ul class="space-y-3">
          <li><a href="/terms" class="text-body-sm text-ghost hover:text-chalk transition-colors">Terms</a></li>
          <li><a href="/privacy" class="text-body-sm text-ghost hover:text-chalk transition-colors">Privacy</a></li>
          <li><a href="mailto:beta@kaldon.io" class="text-body-sm text-ghost hover:text-chalk transition-colors">beta@kaldon.io</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-hairline flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="flex items-center gap-3">
        <a href="/" class="shrink-0" aria-label="Kaldon home">
          <img src="/images/logos/kaldon-logo-dark.svg" alt="Kaldon" class="h-5" width="90" height="20" />
        </a>
        <p class="text-small text-ghost">
          &copy; {year} Kaldon. Intelligence that commands action.
        </p>
      </div>
      <div class="flex items-center gap-4">
        <a href="https://twitter.com/kaldonhq" aria-label="Kaldon on X (Twitter)" class="w-8 h-8 inline-flex items-center justify-center rounded-btn text-ghost hover:text-chalk hover:bg-white/5 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://linkedin.com/company/kaldon" aria-label="Kaldon on LinkedIn" class="w-8 h-8 inline-flex items-center justify-center rounded-btn text-ghost hover:text-chalk hover:bg-white/5 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  (function() {
    const form = document.getElementById('footer-email-form');
    form?.addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = this.querySelector('button');
      btn.textContent = 'Subscribed';
      btn.disabled = true;
      btn.style.opacity = '0.6';
      if (typeof window.trackEvent === 'function') {
        window.trackEvent('email_capture', { source: 'footer' });
      }
    });
  })();
</script>
