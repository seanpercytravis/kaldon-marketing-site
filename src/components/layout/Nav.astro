---
// Nav.astro. transparent at top, glass-blur on scroll (Linear pattern)
// 64px height, Gold primary CTA, mono-label mobile menu
import { appUrl } from '../../lib/urls';

const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? currentPath === '/' : currentPath.startsWith(path);

const navSignupUrl = appUrl('/signup', 'nav');
const navLoginUrl = appUrl('/login', 'nav');
---

<nav id="main-nav" class="fixed top-0 inset-x-0 z-50 transition-colors duration-100 ease-out" aria-label="Main navigation">
  <div class="container-custom">
    <div class="flex items-center justify-between h-20">
      <!-- Logo. roughly 2x the prior size so the "AI-Powered eCommerce
           Intelligence" descriptor is legible at normal reading distance. -->
      <a href="/" class="flex items-center shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-signal focus-visible:ring-offset-2 focus-visible:ring-offset-void rounded-sm">
        <img src="/images/logos/kaldon-logo-dark.svg" alt="Kaldon. AI-Powered eCommerce Intelligence" class="h-14 md:h-16 w-auto" width="320" height="64" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1" role="menubar">
        <a href="/how-it-works" class="nav-link" aria-current={isActive('/how-it-works') ? 'page' : undefined}>How It Works</a>
        <a href="/features" class="nav-link" aria-current={isActive('/features') ? 'page' : undefined}>Features</a>
        <a href="/pricing" class="nav-link" aria-current={isActive('/pricing') ? 'page' : undefined}>Pricing</a>
        <div class="nav-dropdown" data-dropdown>
          <button
            type="button"
            class="nav-link flex items-center gap-1 nav-dropdown-trigger"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="nav-menu-compare"
            data-dropdown-trigger
          >
            Compare
            <svg class="w-3 h-3 nav-dropdown-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div
            id="nav-menu-compare"
            class="nav-dropdown-panel absolute top-full left-0 mt-2 w-[340px] p-2 rounded-card border border-hairline"
            style="background: #12121A; box-shadow: 0 20px 48px -20px rgba(0,0,0,0.6);"
            role="menu"
            data-dropdown-panel
          >
            <a href="/compare/research-tools" class="nav-drop-item" role="menuitem">
              <span class="nav-drop-title">vs Research Tools</span>
              <span class="nav-drop-sub">Why "find what's selling" tools stop short</span>
            </a>
            <a href="/compare/ecommerce-platforms" class="nav-drop-item" role="menuitem">
              <span class="nav-drop-title">vs eCommerce Platforms</span>
              <span class="nav-drop-sub">Shopify sells products. Kaldon builds them first</span>
            </a>
            <a href="/compare/doing-it-yourself" class="nav-drop-item" role="menuitem">
              <span class="nav-drop-title">DIY vs Kaldon</span>
              <span class="nav-drop-sub">8–20 weeks of work, collapsed into days</span>
            </a>
          </div>
        </div>
        <div class="nav-dropdown" data-dropdown>
          <button
            type="button"
            class="nav-link flex items-center gap-1 nav-dropdown-trigger"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="nav-menu-use-cases"
            data-dropdown-trigger
          >
            Use Cases
            <svg class="w-3 h-3 nav-dropdown-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div
            id="nav-menu-use-cases"
            class="nav-dropdown-panel absolute top-full left-0 mt-2 w-[320px] p-2 rounded-card border border-hairline"
            style="background: #12121A; box-shadow: 0 20px 48px -20px rgba(0,0,0,0.6);"
            role="menu"
            data-dropdown-panel
          >
            <a href="/use-cases/new-sellers" class="nav-drop-item" role="menuitem">
              <span class="nav-drop-title">New Sellers</span>
              <span class="nav-drop-sub">From market gap to your first product</span>
            </a>
            <a href="/use-cases/existing-brands" class="nav-drop-item" role="menuitem">
              <span class="nav-drop-title">Existing Brands</span>
              <span class="nav-drop-sub">VET · DISCOVER · EXPAND · three modes</span>
            </a>
            <a href="/use-cases/agencies" class="nav-drop-item" role="menuitem">
              <span class="nav-drop-title">Agencies</span>
              <span class="nav-drop-sub">Ship client products in hours, not weeks</span>
            </a>
          </div>
        </div>
        <a href="/blog" class="nav-link">Blog</a>
      </div>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-2 md:gap-3">
        <a href={navLoginUrl} class="btn-ghost hidden sm:inline-flex text-sm">Log In</a>
        <a href={navSignupUrl} class="btn-primary" data-event="signup_cta_click" style="height: 36px; padding: 0 16px; font-size: 14px;">Start Free</a>
        <button
          id="mobile-menu-toggle"
          class="md:hidden w-10 h-10 inline-flex items-center justify-center rounded-btn text-ghost hover:text-chalk hover:bg-white/5 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="mobile-menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden fixed inset-0 top-20 z-50 overflow-y-auto" style="background: #0A0A0F;">
    <div class="container-custom py-10 space-y-1">
      <a href="/how-it-works" class="block py-3 text-lg font-medium text-chalk hover:text-signal transition-colors">How It Works</a>
      <a href="/features" class="block py-3 text-lg font-medium text-chalk hover:text-signal transition-colors">Features</a>
      <a href="/pricing" class="block py-3 text-lg font-medium text-chalk hover:text-signal transition-colors">Pricing</a>

      <div class="pt-6 mt-4 border-t border-hairline">
        <p class="kicker" style="margin-bottom: 12px;">Compare</p>
        <a href="/compare/research-tools" class="block py-2 text-base text-ghost hover:text-chalk transition-colors">vs Research Tools</a>
        <a href="/compare/ecommerce-platforms" class="block py-2 text-base text-ghost hover:text-chalk transition-colors">vs eCommerce Platforms</a>
        <a href="/compare/doing-it-yourself" class="block py-2 text-base text-ghost hover:text-chalk transition-colors">DIY vs Kaldon</a>
      </div>

      <div class="pt-6 mt-4 border-t border-hairline">
        <p class="kicker" style="margin-bottom: 12px;">Use Cases</p>
        <a href="/use-cases/new-sellers" class="block py-2 text-base text-ghost hover:text-chalk transition-colors">New Sellers</a>
        <a href="/use-cases/existing-brands" class="block py-2 text-base text-ghost hover:text-chalk transition-colors">Existing Brands</a>
        <a href="/use-cases/agencies" class="block py-2 text-base text-ghost hover:text-chalk transition-colors">Agencies</a>
      </div>

      <div class="pt-6 mt-4 border-t border-hairline">
        <a href="/blog" class="block py-3 text-lg font-medium text-chalk hover:text-signal transition-colors">Blog</a>
        <a href="/about" class="block py-3 text-lg font-medium text-chalk hover:text-signal transition-colors">About</a>
        <a href="/contact" class="block py-3 text-lg font-medium text-chalk hover:text-signal transition-colors">Contact</a>
      </div>

      <div class="pt-8 mt-6 border-t border-hairline space-y-3">
        <a href={navLoginUrl} class="block text-center py-3 text-base text-ghost hover:text-chalk transition-colors">Log In</a>
        <a href={navSignupUrl} class="btn-primary btn-large w-full" data-event="mobile_signup_cta_click">Start Free</a>
      </div>
    </div>
  </div>
</nav>

<!-- Nav spacer (fixed nav means content needs top offset) -->
<div class="h-20" aria-hidden="true"></div>

<script is:inline>
  (function() {
    const nav = document.getElementById('main-nav');
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('mobile-menu-icon');
    if (!nav) return;

    // Scroll-state: transparent → blurred Void
    let scrolled = false;
    function updateNav() {
      const shouldScroll = window.scrollY > 24;
      if (shouldScroll !== scrolled) {
        scrolled = shouldScroll;
        if (scrolled) {
          nav.style.background = 'rgba(10, 10, 15, 0.72)';
          nav.style.backdropFilter = 'blur(20px) saturate(150%)';
          nav.style.webkitBackdropFilter = 'blur(20px) saturate(150%)';
          nav.style.borderBottom = '1px solid rgba(255,255,255,0.06)';
        } else {
          nav.style.background = 'transparent';
          nav.style.backdropFilter = 'none';
          nav.style.webkitBackdropFilter = 'none';
          nav.style.borderBottom = '1px solid transparent';
        }
      }
    }
    updateNav();
    window.addEventListener('scroll', updateNav, { passive: true });

    // Mobile menu
    menuToggle?.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      menuToggle.setAttribute('aria-expanded', String(!isOpen));
      menuToggle.setAttribute('aria-label', !isOpen ? 'Close menu' : 'Open menu');
      if (!isOpen) {
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />';
        document.body.style.overflow = 'hidden';
      } else {
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
        document.body.style.overflow = '';
      }
    });

    // Close mobile menu on link tap
    menu?.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        menu.classList.add('hidden');
        menuToggle.setAttribute('aria-expanded', 'false');
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
        document.body.style.overflow = '';
      });
    });

    // Desktop dropdown keyboard + click accessibility.
    // Supports: Enter/Space to toggle, Escape to close, ArrowDown to enter
    // menu, ArrowUp/ArrowDown to cycle items, outside click to close.
    const dropdowns = document.querySelectorAll('[data-dropdown]');
    const openDropdown = (dd, focusFirst) => {
      dropdowns.forEach((other) => {
        if (other !== dd) {
          other.setAttribute('data-open', 'false');
          other.querySelector('[data-dropdown-trigger]')?.setAttribute('aria-expanded', 'false');
        }
      });
      dd.setAttribute('data-open', 'true');
      dd.querySelector('[data-dropdown-trigger]')?.setAttribute('aria-expanded', 'true');
      if (focusFirst) {
        dd.querySelector('[data-dropdown-panel] a')?.focus();
      }
    };
    const closeDropdown = (dd, returnFocus) => {
      dd.setAttribute('data-open', 'false');
      const trigger = dd.querySelector('[data-dropdown-trigger]');
      trigger?.setAttribute('aria-expanded', 'false');
      if (returnFocus) trigger?.focus();
    };

    dropdowns.forEach((dd) => {
      const trigger = dd.querySelector('[data-dropdown-trigger]');
      const panel = dd.querySelector('[data-dropdown-panel]');
      if (!trigger || !panel) return;

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const isOpen = dd.getAttribute('data-open') === 'true';
        if (isOpen) closeDropdown(dd, false);
        else openDropdown(dd, false);
      });

      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          openDropdown(dd, true);
        } else if (e.key === 'Escape') {
          closeDropdown(dd, true);
        }
      });

      panel.addEventListener('keydown', (e) => {
        const items = Array.from(panel.querySelectorAll('a'));
        const idx = items.indexOf(document.activeElement);
        if (e.key === 'Escape') {
          e.preventDefault();
          closeDropdown(dd, true);
        } else if (e.key === 'ArrowDown') {
          e.preventDefault();
          const next = items[(idx + 1) % items.length];
          next?.focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          const prev = items[(idx - 1 + items.length) % items.length];
          prev?.focus();
        } else if (e.key === 'Home') {
          e.preventDefault();
          items[0]?.focus();
        } else if (e.key === 'End') {
          e.preventDefault();
          items[items.length - 1]?.focus();
        } else if (e.key === 'Tab') {
          // Let tab flow naturally, but close if tabbing out of panel.
          setTimeout(() => {
            if (!dd.contains(document.activeElement)) {
              closeDropdown(dd, false);
            }
          }, 0);
        }
      });
    });

    // Click outside closes any open dropdown
    document.addEventListener('click', (e) => {
      dropdowns.forEach((dd) => {
        if (dd.getAttribute('data-open') === 'true' && !dd.contains(e.target)) {
          closeDropdown(dd, false);
        }
      });
    });
  })();
</script>
