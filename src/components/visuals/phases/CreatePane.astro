---
// CreatePane.astro. Phase 3 graphic: content calendar + live post mockups.
// A compact week strip hints at the 28-post month, while three realistic
// social post mockups (IG Reel, TikTok, LinkedIn) make the "content creation"
// promise visible at a glance. Same 3D isometric chrome as the other panes.
interface Props {
  variant?: 'hero' | 'inline';
}
const { variant = 'hero' } = Astro.props;

// 7-cell week strip. Deterministic pattern so visual reads as "full week planned".
const weekCells: Array<{ day: string; posts: Array<'ig' | 'x' | 'li' | 'fb' | 'pin' | 'tt'> }> = [
  { day: 'M', posts: ['ig', 'fb'] },
  { day: 'T', posts: ['tt'] },
  { day: 'W', posts: ['ig', 'li', 'x'] },
  { day: 'T', posts: ['pin'] },
  { day: 'F', posts: ['ig', 'tt'] },
  { day: 'S', posts: ['x'] },
  { day: 'S', posts: ['fb', 'li'] },
];

const platformColors: Record<string, string> = {
  ig: '#00D4FF',
  x: '#FFB800',
  li: '#00D4FF',
  fb: '#FFB800',
  pin: '#00D4FF',
  tt: '#FFB800',
};
---

<div class={`phase-pane-wrap ${variant === 'inline' ? 'inline-variant' : ''}`} aria-hidden="true">
  <div class="phase-pane">
    <div class="pane-bar">
      <div class="pane-breadcrumb">
        <span class="pane-brand">Kaldon</span>
        <span class="pane-sep">›</span>
        <span class="pane-path">Create</span>
        <span class="pane-sep">›</span>
        <span class="pane-current">Content · Apr</span>
      </div>
      <div class="pane-status">
        <span class="pulse-dot"></span>
        <span class="pane-status-text">28 posts queued</span>
      </div>
    </div>

    <div class="pane-body">
      <!-- Hero stat: post count + platforms -->
      <div class="content-hero">
        <div>
          <span class="create-kicker">Scheduled this month</span>
          <div class="create-hero-line">
            <span class="create-hero-num">28</span>
            <span class="create-hero-sub">posts · 6 platforms</span>
          </div>
        </div>
        <div class="platform-legend">
          <span class="legend-item"><span class="legend-dot" style="background: #00D4FF;"></span>IG</span>
          <span class="legend-item"><span class="legend-dot" style="background: #FFB800;"></span>TikTok</span>
          <span class="legend-item"><span class="legend-dot" style="background: #00D4FF;"></span>LinkedIn</span>
          <span class="legend-item"><span class="legend-dot" style="background: #FFB800;"></span>X · Pin · FB</span>
        </div>
      </div>

      <!-- Week strip -->
      <div class="week-strip">
        <span class="week-strip-kicker">This week</span>
        <div class="week-grid">
          {weekCells.map((cell) => (
            <div class={`week-cell ${cell.posts.length > 0 ? 'has-posts' : ''}`}>
              <span class="week-day">{cell.day}</span>
              <div class="week-dots">
                {cell.posts.map((p) => (
                  <span class="week-dot" style={`background: ${platformColors[p]};`}></span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Post mockups row: IG Reel, TikTok, LinkedIn -->
      <div class="posts-row">
        <!-- IG Reel (vertical) -->
        <div class="post-card post-ig">
          <div class="post-thumb">
            <div class="post-thumb-img post-thumb-ig"></div>
            <span class="post-play" aria-hidden="true">▶</span>
            <span class="post-badge post-badge-ig">Reel</span>
          </div>
          <p class="post-caption">Why 78% of buyers filter by $25–35…</p>
          <div class="post-meta">
            <span class="post-meta-dot" style="background: #00D4FF;"></span>
            <span class="post-meta-text">Instagram · 9:00 AM</span>
          </div>
        </div>

        <!-- TikTok (vertical) -->
        <div class="post-card post-tt">
          <div class="post-thumb">
            <div class="post-thumb-img post-thumb-tt"></div>
            <span class="post-play" aria-hidden="true">▶</span>
            <span class="post-badge post-badge-tt">0:23</span>
          </div>
          <p class="post-caption">POV: you found the gap before…</p>
          <div class="post-meta">
            <span class="post-meta-dot" style="background: #FFB800;"></span>
            <span class="post-meta-text">TikTok · 6:00 PM</span>
          </div>
        </div>

        <!-- LinkedIn (article) -->
        <div class="post-card post-li">
          <div class="post-thumb post-thumb-article">
            <div class="post-article-header">
              <span class="post-avatar"></span>
              <div class="post-article-meta">
                <span class="post-article-name">Ironfield</span>
                <span class="post-article-sub">2h · Article</span>
              </div>
            </div>
            <div class="post-article-body">
              <span class="post-article-line w-90"></span>
              <span class="post-article-line w-70"></span>
              <span class="post-article-line w-80"></span>
            </div>
          </div>
          <p class="post-caption">The 14% pricing gap nobody is pricing to…</p>
          <div class="post-meta">
            <span class="post-meta-dot" style="background: #00D4FF;"></span>
            <span class="post-meta-text">LinkedIn · Tue 8 AM</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .phase-pane-wrap {
    position: relative;
    width: 100%;
    max-width: 620px;
    aspect-ratio: 1 / 1;
    margin-left: auto;
    -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 92%);
            mask-image: linear-gradient(to bottom, black 55%, transparent 92%);
    perspective: 4000px;
    pointer-events: none;
  }
  .phase-pane-wrap.inline-variant {
    max-width: 520px;
    aspect-ratio: 5 / 4;
    margin-left: 0;
    -webkit-mask-image: linear-gradient(to bottom, black 65%, transparent 98%);
            mask-image: linear-gradient(to bottom, black 65%, transparent 98%);
  }

  .phase-pane {
    position: absolute;
    inset: 0;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px 12px 0 0;
    transform: rotateX(38deg) rotateY(30deg) rotate(325deg) translateZ(0);
    transform-origin: 50% 50%;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.03) inset, 0 40px 80px rgba(0,0,0,0.4);
    overflow: hidden;
  }
  .phase-pane::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(255,255,255,0.12), rgba(255,255,255,0.02) 40%, rgba(255,255,255,0.06));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  .pane-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--hairline);
    background: rgba(255,255,255,0.015);
  }
  .pane-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--ghost);
    letter-spacing: 0.02em;
  }
  .pane-brand { color: var(--chalk); }
  .pane-sep { color: rgba(139,139,163,0.35); }
  .pane-current { color: var(--chalk); }
  .pane-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ghost);
  }
  .pane-status .pulse-dot { width: 7px; height: 7px; }

  .pane-body {
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .create-kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ghost);
    font-weight: 500;
    margin-bottom: 4px;
  }

  .content-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }
  .create-hero-line { display: flex; align-items: baseline; gap: 8px; }
  .create-hero-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.035em;
    color: var(--chalk);
  }
  .create-hero-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ghost);
  }
  .platform-legend {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-align: right;
  }
  .legend-item {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ghost);
    display: inline-flex;
    align-items: center;
    gap: 5px;
    justify-content: flex-end;
  }
  .legend-dot { width: 6px; height: 6px; border-radius: 999px; }

  /* Week strip */
  .week-strip {
    padding-top: 10px;
    border-top: 1px solid var(--hairline);
  }
  .week-strip-kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ghost);
    font-weight: 500;
    margin-bottom: 6px;
  }
  .week-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .week-cell {
    padding: 5px 4px;
    border-radius: 4px;
    background: var(--void);
    border: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    min-height: 32px;
  }
  .week-cell.has-posts {
    border-color: rgba(255,184,0,0.2);
    background: rgba(255,184,0,0.04);
  }
  .week-day {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ghost);
    font-weight: 500;
  }
  .week-cell.has-posts .week-day { color: var(--chalk); }
  .week-dots { display: flex; gap: 2px; }
  .week-dot { width: 4px; height: 4px; border-radius: 999px; }

  /* Post mockup row */
  .posts-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .post-card {
    padding: 8px;
    background: var(--void);
    border: 1px solid var(--hairline);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
  }
  .post-ig { border-left: 2px solid #00D4FF; }
  .post-tt { border-left: 2px solid #FFB800; }
  .post-li { border-left: 2px solid #00D4FF; }

  .post-thumb {
    position: relative;
    aspect-ratio: 9 / 12;
    border-radius: 4px;
    overflow: hidden;
    background: var(--deep-space);
  }
  .post-thumb-article { aspect-ratio: 9 / 12; padding: 8px; background: var(--deep-space); border: 1px solid var(--hairline); }

  .post-thumb-img {
    position: absolute;
    inset: 0;
  }
  .post-thumb-ig {
    background:
      radial-gradient(ellipse at 30% 40%, rgba(0, 212, 255, 0.28), transparent 50%),
      radial-gradient(ellipse at 70% 75%, rgba(255, 184, 0, 0.18), transparent 50%),
      linear-gradient(135deg, #1a1a2e 0%, #12121a 100%);
  }
  .post-thumb-tt {
    background:
      radial-gradient(circle at 50% 35%, rgba(255, 184, 0, 0.32), transparent 45%),
      radial-gradient(circle at 25% 75%, rgba(0, 212, 255, 0.2), transparent 45%),
      linear-gradient(170deg, #1f1a14 0%, #12121a 100%);
  }

  .post-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: #0a0a0f;
    font-size: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 2px;
  }
  .post-badge {
    position: absolute;
    top: 5px;
    right: 5px;
    font-family: var(--font-mono);
    font-size: 7px;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 3px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .post-badge-ig { background: rgba(0, 212, 255, 0.2); color: #00D4FF; }
  .post-badge-tt { background: rgba(255, 184, 0, 0.2); color: #FFB800; }

  /* LinkedIn article mockup */
  .post-article-header {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 6px;
  }
  .post-avatar {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, #00D4FF, #FFB800);
    flex-shrink: 0;
  }
  .post-article-meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .post-article-name {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 600;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }
  .post-article-sub {
    font-family: var(--font-mono);
    font-size: 7px;
    color: var(--ghost);
  }
  .post-article-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-top: 6px;
  }
  .post-article-line {
    height: 4px;
    background: rgba(245, 245, 247, 0.12);
    border-radius: 2px;
  }
  .post-article-line.w-90 { width: 90%; }
  .post-article-line.w-80 { width: 80%; }
  .post-article-line.w-70 { width: 70%; }

  .post-caption {
    font-family: var(--font-display);
    font-size: 9px;
    color: var(--chalk);
    line-height: 1.3;
    letter-spacing: -0.005em;
    font-weight: 500;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--ghost);
  }
  .post-meta-dot { width: 4px; height: 4px; border-radius: 999px; flex-shrink: 0; }

  @media (prefers-reduced-motion: reduce) {
    .pane-status .pulse-dot { animation: none; }
  }

  @media (max-width: 1023px) {
    .phase-pane-wrap {
      max-width: 100%;
      aspect-ratio: auto;
      height: auto;
      perspective: 2000px;
      -webkit-mask-image: linear-gradient(to bottom, black 90%, transparent 100%);
              mask-image: linear-gradient(to bottom, black 90%, transparent 100%);
    }
    .phase-pane {
      position: relative;
      inset: auto;
      transform: rotateX(3deg) rotateY(-2deg) rotate(-0.5deg);
      border-radius: 12px;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.03) inset, 0 16px 32px rgba(0,0,0,0.35);
    }
  }
</style>
