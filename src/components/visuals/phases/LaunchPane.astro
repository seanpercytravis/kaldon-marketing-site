---
// LaunchPane.astro. Phase 4 graphic: live storefront mockup + deployment.
// Shows a realistic browser frame with Ironfield's shipped DTC storefront
// (hero, product grid, nav), alongside a compact deployment checklist that
// signals every downstream system is live. Same 3D isometric chrome.
interface Props {
  variant?: 'hero' | 'inline';
}
const { variant = 'hero' } = Astro.props;

const deployments = [
  { label: 'Storefront', status: 'live' },
  { label: 'Checkout', status: 'live' },
  { label: 'Email + SMS', status: 'live' },
  { label: 'Chatbot', status: 'live' },
  { label: 'Blog', status: 'scheduled' },
  { label: 'Ads', status: 'ready' },
];

const statusLabels: Record<string, { text: string; color: string }> = {
  live: { text: 'LIVE', color: 'var(--signal)' },
  scheduled: { text: 'QUEUED', color: 'var(--gold)' },
  ready: { text: 'READY', color: 'var(--ghost)' },
};
---

<div class={`phase-pane-wrap ${variant === 'inline' ? 'inline-variant' : ''}`} aria-hidden="true">
  <div class="phase-pane">
    <div class="pane-bar">
      <div class="pane-breadcrumb">
        <span class="pane-brand">Kaldon</span>
        <span class="pane-sep">›</span>
        <span class="pane-path">Launch</span>
        <span class="pane-sep">›</span>
        <span class="pane-current">ironfield.co</span>
      </div>
      <div class="pane-status live">
        <span class="pulse-dot"></span>
        <span class="pane-status-text">Live · 128 ms TTFB</span>
      </div>
    </div>

    <div class="pane-body">
      <!-- Storefront browser mockup -->
      <div class="browser-frame">
        <div class="browser-chrome">
          <div class="browser-dots">
            <span class="browser-dot"></span>
            <span class="browser-dot"></span>
            <span class="browser-dot"></span>
          </div>
          <div class="browser-url">
            <span class="browser-lock" aria-hidden="true">⊙</span>
            <span class="browser-url-text">ironfield.co</span>
          </div>
          <div class="browser-spacer"></div>
        </div>
        <div class="storefront">
          <!-- Nav -->
          <div class="store-nav">
            <span class="store-logo">IRONFIELD</span>
            <div class="store-nav-links">
              <span>Shop</span>
              <span>Story</span>
              <span>Journal</span>
            </div>
            <span class="store-cart">Cart · 0</span>
          </div>

          <!-- Hero -->
          <div class="store-hero">
            <div class="store-hero-copy">
              <span class="store-hero-kicker">Ceramic-lined hydration</span>
              <p class="store-hero-title">Built for the next 20%.</p>
              <span class="store-hero-cta">Shop the launch →</span>
            </div>
            <div class="store-hero-product">
              <div class="store-product-img" aria-hidden="true"></div>
            </div>
          </div>

          <!-- Product grid -->
          <div class="store-grid">
            <div class="store-tile">
              <div class="store-tile-img store-tile-img-a"></div>
              <span class="store-tile-name">Ironfield 32</span>
              <span class="store-tile-price">$42</span>
            </div>
            <div class="store-tile">
              <div class="store-tile-img store-tile-img-b"></div>
              <span class="store-tile-name">Ironfield 24</span>
              <span class="store-tile-price">$36</span>
            </div>
            <div class="store-tile">
              <div class="store-tile-img store-tile-img-c"></div>
              <span class="store-tile-name">Field Kit</span>
              <span class="store-tile-price">$58</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Compact deployment checklist -->
      <div class="deploy-compact">
        {deployments.map((d) => (
          <div class={`deploy-pill ${d.status}`}>
            <span class="deploy-pill-check" aria-hidden="true">
              {d.status === 'live' ? (
                <svg width="10" height="10" viewBox="0 0 20 20" fill="none"><path d="M4 10.5 L8 14.5 L16 6" stroke="#00D4FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
              ) : d.status === 'scheduled' ? (
                <svg width="10" height="10" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="#FFB800" stroke-width="2" /><path d="M10 6 L10 10 L13 12" stroke="#FFB800" stroke-width="2" stroke-linecap="round" /></svg>
              ) : (
                <svg width="10" height="10" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="#8B8BA3" stroke-width="2" /></svg>
              )}
            </span>
            <span class="deploy-pill-label">{d.label}</span>
            <span class="deploy-pill-status" style={`color: ${statusLabels[d.status].color};`}>{statusLabels[d.status].text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .phase-pane-wrap {
    position: relative;
    width: 100%;
    max-width: 620px;
    aspect-ratio: 1 / 1;
    margin-left: auto;
    -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 92%);
            mask-image: linear-gradient(to bottom, black 55%, transparent 92%);
    perspective: 4000px;
    pointer-events: none;
  }
  .phase-pane-wrap.inline-variant {
    max-width: 520px;
    aspect-ratio: 5 / 4;
    margin-left: 0;
    -webkit-mask-image: linear-gradient(to bottom, black 65%, transparent 98%);
            mask-image: linear-gradient(to bottom, black 65%, transparent 98%);
  }

  .phase-pane {
    position: absolute;
    inset: 0;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px 12px 0 0;
    transform: rotateX(38deg) rotateY(30deg) rotate(325deg) translateZ(0);
    transform-origin: 50% 50%;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.03) inset, 0 40px 80px rgba(0,0,0,0.4);
    overflow: hidden;
  }
  .phase-pane::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(255,255,255,0.12), rgba(255,255,255,0.02) 40%, rgba(255,255,255,0.06));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  .pane-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--hairline);
    background: rgba(255,255,255,0.015);
  }
  .pane-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--ghost);
    letter-spacing: 0.02em;
  }
  .pane-brand { color: var(--chalk); }
  .pane-sep { color: rgba(139,139,163,0.35); }
  .pane-current { color: var(--signal); }
  .pane-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ghost);
  }
  .pane-status.live { color: var(--signal); }
  .pane-status .pulse-dot { width: 7px; height: 7px; }

  .pane-body {
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Browser frame + storefront */
  .browser-frame {
    border: 1px solid var(--hairline);
    border-radius: 8px;
    overflow: hidden;
    background: var(--void);
  }
  .browser-chrome {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid var(--hairline);
  }
  .browser-dots { display: flex; gap: 5px; }
  .browser-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: rgba(139, 139, 163, 0.3);
  }
  .browser-url {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 3px 10px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ghost);
    max-width: 60%;
    margin: 0 auto;
  }
  .browser-lock { color: var(--signal); font-size: 10px; }
  .browser-url-text { color: var(--chalk); letter-spacing: -0.01em; }
  .browser-spacer { width: 21px; }

  .storefront {
    background: #F5F5F0;
    color: #14141a;
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .store-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 6px;
    border-bottom: 1px solid rgba(20, 20, 26, 0.08);
  }
  .store-logo {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #14141a;
  }
  .store-nav-links {
    display: inline-flex;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: 8px;
    color: rgba(20, 20, 26, 0.7);
    letter-spacing: 0.01em;
  }
  .store-cart {
    font-family: var(--font-mono);
    font-size: 8px;
    color: rgba(20, 20, 26, 0.6);
    letter-spacing: 0.02em;
  }

  .store-hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 8px;
    padding: 10px;
    background: linear-gradient(135deg, #1a1f2e 0%, #0a0f1a 100%);
    border-radius: 5px;
    color: #F5F5F0;
    min-height: 80px;
    align-items: center;
  }
  .store-hero-copy {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .store-hero-kicker {
    font-family: var(--font-mono);
    font-size: 7px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #FFB800;
    font-weight: 500;
  }
  .store-hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #F5F5F0;
    margin: 0;
  }
  .store-hero-cta {
    font-family: var(--font-mono);
    font-size: 8px;
    color: #00D4FF;
    letter-spacing: 0.04em;
    margin-top: 4px;
  }
  .store-hero-product {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }
  .store-product-img {
    width: 70%;
    aspect-ratio: 1 / 1.4;
    border-radius: 4px;
    background:
      radial-gradient(ellipse at 40% 30%, rgba(0, 212, 255, 0.32), transparent 55%),
      radial-gradient(ellipse at 70% 70%, rgba(255, 184, 0, 0.22), transparent 55%),
      linear-gradient(160deg, #2a3142 0%, #14141a 100%);
    border: 1px solid rgba(245, 245, 240, 0.12);
  }

  .store-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
  .store-tile {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .store-tile-img {
    aspect-ratio: 1;
    border-radius: 3px;
    border: 1px solid rgba(20, 20, 26, 0.08);
  }
  .store-tile-img-a {
    background:
      radial-gradient(circle at 50% 45%, rgba(0, 150, 200, 0.25), transparent 60%),
      linear-gradient(135deg, #E8E5DD, #C9C3B6);
  }
  .store-tile-img-b {
    background:
      radial-gradient(circle at 50% 45%, rgba(200, 150, 80, 0.28), transparent 60%),
      linear-gradient(135deg, #EBE5D7, #D4C8B0);
  }
  .store-tile-img-c {
    background:
      radial-gradient(circle at 50% 45%, rgba(60, 70, 90, 0.35), transparent 60%),
      linear-gradient(135deg, #DDDBD4, #BAB4A8);
  }
  .store-tile-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 8px;
    color: #14141a;
    letter-spacing: -0.005em;
  }
  .store-tile-price {
    font-family: var(--font-mono);
    font-size: 8px;
    color: rgba(20, 20, 26, 0.65);
  }

  /* Compact checklist pills */
  .deploy-compact {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 5px;
    padding-top: 10px;
    border-top: 1px solid var(--hairline);
  }
  .deploy-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px;
    background: var(--void);
    border: 1px solid var(--hairline);
    border-radius: 4px;
  }
  .deploy-pill.live { border-color: rgba(0, 212, 255, 0.2); }
  .deploy-pill.scheduled { border-color: rgba(255, 184, 0, 0.18); }
  .deploy-pill-check { display: flex; }
  .deploy-pill-label {
    flex: 1;
    font-family: var(--font-sans);
    font-size: 10px;
    color: var(--chalk);
    font-weight: 500;
  }
  .deploy-pill-status {
    font-family: var(--font-mono);
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  @media (prefers-reduced-motion: reduce) {
    .pane-status .pulse-dot { animation: none; }
  }

  @media (max-width: 1023px) {
    .phase-pane-wrap {
      max-width: 100%;
      aspect-ratio: auto;
      height: auto;
      perspective: 2000px;
      -webkit-mask-image: linear-gradient(to bottom, black 90%, transparent 100%);
              mask-image: linear-gradient(to bottom, black 90%, transparent 100%);
    }
    .phase-pane {
      position: relative;
      inset: auto;
      transform: rotateX(3deg) rotateY(-2deg) rotate(-0.5deg);
      border-radius: 12px;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.03) inset, 0 16px 32px rgba(0,0,0,0.35);
    }
  }
</style>
