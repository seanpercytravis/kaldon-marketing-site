---
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
  structuredData?: object[];
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage,
  ogType = 'website',
  noIndex = false,
  structuredData = [],
} = Astro.props;

const siteUrl = 'https://kaldon.io';

// Auto-select per-page OG image from pathname if no explicit ogImage passed.
// See scripts/generate-og.mjs for the generator; PNGs live in
// public/images/og/. Fallback: og-default.webp.
function ogSlugFromPath(path: string): string {
  const clean = path.replace(/\/$/, '').replace(/^\//, '');
  if (clean === '') return 'home';
  // Translate URL path to OG slug (matches generate-og.mjs page slugs)
  const map: Record<string, string> = {
    'use-cases/new-sellers': 'use-cases-new-sellers',
    'use-cases/existing-brands': 'use-cases-existing-brands',
    'use-cases/agencies': 'use-cases-agencies',
    'compare/research-tools': 'compare-research-tools',
    'compare/ecommerce-platforms': 'compare-ecommerce-platforms',
    'compare/doing-it-yourself': 'compare-doing-it-yourself',
    'vs/helium-10': 'vs-helium-10',
    'vs/jungle-scout': 'vs-jungle-scout',
    'vs/shopify': 'vs-shopify',
  };
  if (map[clean]) return map[clean];
  // Pages without a generated OG image fall back to og-default.webp.
  // Keeps social previews working on /contact, /privacy, /terms, /404,
  // and individual blog posts (which don't have per-post OGs yet).
  const noOgImage = new Set(['contact', 'privacy', 'terms', '404']);
  if (noOgImage.has(clean)) return '';
  // Multi-segment paths not in map (e.g., /blog/{slug}) → default
  if (clean.includes('/')) return '';
  // Single-segment routes: pricing, features, how-it-works, demo, blog,
  // about, who-its-for → use the segment directly
  return clean;
}
const derivedSlug = ogSlugFromPath(Astro.url.pathname);
const resolvedOgImage = ogImage
  ? ogImage
  : derivedSlug
    ? `/images/og/${derivedSlug}.png`
    : '/images/og-default.webp';
const fullOgImage = resolvedOgImage.startsWith('http')
  ? resolvedOgImage
  : `${siteUrl}${resolvedOgImage}`;

// Auto-generate BreadcrumbList from the current URL path.
// "/" renders no breadcrumbs. Otherwise: Home > segment 1 > segment 2…
function titleize(segment: string): string {
  const overrides: Record<string, string> = {
    // Section overrides
    'vs': 'Compare',
    'use-cases': 'Use Cases',
    'how-it-works': 'How It Works',
    'who-its-for': "Who It's For",
    'ecommerce-platforms': 'eCommerce Platforms',
    'research-tools': 'Research Tools',
    'doing-it-yourself': 'DIY',
    'new-sellers': 'New Sellers',
    'existing-brands': 'Existing Brands',
    // Blog post slug → real title (prevents awkward auto-titleize like
    // "True Cost Ecommerce Product Launch 2026")
    'true-cost-ecommerce-product-launch-2026':
      'The True Cost of Launching an eCommerce Product in 2026',
    'how-to-find-winning-product-sell-online-2026':
      'How to Find a Winning Product to Sell Online (2026)',
    'amazon-to-dtc-build-brand-beyond-marketplace':
      'Amazon to DTC: Building a Brand Beyond the Marketplace',
    'helium-10-vs-jungle-scout-vs-kaldon':
      'Helium 10 vs Jungle Scout vs Kaldon',
    'what-ai-product-research-actually-looks-like':
      'What AI Product Research Actually Looks Like',
    // Competitor slugs for /vs/*
    'helium-10': 'Helium 10',
    'jungle-scout': 'Jungle Scout',
    'shopify': 'Shopify',
  };
  if (overrides[segment]) return overrides[segment];
  return segment
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const path = Astro.url.pathname.replace(/\/$/, '').replace(/^\//, '');
const segments = path === '' ? [] : path.split('/');

// PostHog (funnel/cohort/replay) sits alongside Plausible (privacy-first
// pageviews). Set PUBLIC_POSTHOG_KEY in Cloudflare Worker env vars to
// enable. cross_subdomain_cookie:true carries identity across kaldon.io
// and app.kaldon.io so the cross-domain signup attribution works.
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://us.i.posthog.com';
const breadcrumbList = segments.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        ...segments.map((seg, i) => ({
          '@type': 'ListItem',
          position: i + 2,
          name: titleize(seg),
          item: `${siteUrl}/${segments.slice(0, i + 1).join('/')}/`,
        })),
      ],
    }
  : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0A0A0F" />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Kaldon" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Fonts: self-hosted Satoshi + Inter Variable + JetBrains Mono via global.css -->
  <link rel="preload" href="/fonts/inter/inter-variable-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/satoshi/Satoshi-Medium.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono/jetbrains-mono-variable-latin.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Plausible Analytics. Privacy-first pageviews + custom events. -->
  <script defer data-domain="kaldon.io" src="https://plausible.io/js/script.js"></script>

  <!-- PostHog. Funnel + cohort + session replay + cross-domain attribution
       to app.kaldon.io. Loads only when PUBLIC_POSTHOG_KEY is set. -->
  {posthogKey && (
    <script is:inline define:vars={{ posthogKey, posthogHost }}>
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageViewId captureTraceFeedback captureTraceMetric".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
      posthog.init(posthogKey, {
        api_host: posthogHost,
        person_profiles: 'identified_only',
        cross_subdomain_cookie: true,
        persistence: 'localStorage+cookie',
        capture_pageview: 'history_change',
        capture_pageleave: true,
        autocapture: true,
        disable_session_recording: false,
        respect_dnt: true
      });
    </script>
  )}

  <!-- Rewardful affiliate tracking. Fires on every page load so referral
       attribution is captured before any CTA click that crosses to app.kaldon.io. -->
  <script is:inline>(function(w,r){w._rwq=r;w[r]=w[r]||function(){(w[r].q=w[r].q||[]).push(arguments)}})(window,'rewardful');</script>
  <script is:inline async src="https://r.wdfl.co/rw.js" data-rewardful="e619ee"></script>

  <!-- Structured Data -->
  {structuredData.map((data) => (
    <script type="application/ld+json" set:html={JSON.stringify(data)} />
  ))}
  {breadcrumbList && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbList)} />
  )}

  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body class="bg-void text-chalk min-h-screen flex flex-col antialiased">
  <!-- Skip to content -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-gold focus:text-void focus:px-4 focus:py-2 focus:rounded-btn focus:outline-none font-medium">
    Skip to content
  </a>

  <Nav />

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- Cookie Consent (legal requirement. minimal, no blocking modal) -->
  <div id="cookie-consent" class="hidden fixed bottom-6 left-6 right-6 sm:left-auto sm:right-6 sm:max-w-sm rounded-card p-5 z-40 border border-hairline" style="background: #12121A;">
    <p class="text-small text-ghost mb-4">
      We use cookies to improve your experience. <a href="/privacy" class="text-signal hover:underline">Privacy Policy</a>.
    </p>
    <div class="flex gap-3">
      <button id="accept-cookies" class="btn-primary flex-1" style="height: 36px; padding: 0 14px; font-size: 13px;">Accept</button>
      <button id="decline-cookies" class="btn-secondary flex-1" style="height: 36px; padding: 0 14px; font-size: 13px;">Decline</button>
    </div>
  </div>

  <!-- Client-side scripts: trackEvent + cookie consent. Nav + Footer have their own scripts. -->
  <script is:inline>
    // Conversion tracking helper. Fans out to Plausible (privacy-first
    // pageviews + custom events), PostHog (funnel + cohort + replay),
    // gtag (Google Ads), and fbq (Meta Pixel). Each guard is independent
    // so missing libraries don't block the others.
    window.trackEvent = function(eventName, params) {
      if (typeof window.plausible === 'function') window.plausible(eventName, { props: params });
      if (window.posthog && typeof window.posthog.capture === 'function') window.posthog.capture(eventName, params);
      if (typeof gtag === 'function') gtag('event', eventName, params);
      if (typeof fbq === 'function') fbq('trackCustom', eventName, params);
    };
    document.querySelectorAll('[data-event]').forEach(function(el) {
      el.addEventListener('click', function() {
        window.trackEvent(el.dataset.event, { source: window.location.pathname });
      });
    });

    // Cookie consent
    (function() {
      const banner = document.getElementById('cookie-consent');
      if (!banner) return;
      if (!localStorage.getItem('cookie-consent')) {
        setTimeout(function() { banner.classList.remove('hidden'); }, 1500);
      }
      document.getElementById('accept-cookies')?.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'accepted');
        banner.classList.add('hidden');
      });
      document.getElementById('decline-cookies')?.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'declined');
        banner.classList.add('hidden');
      });
    })();
  </script>
</body>
</html>
