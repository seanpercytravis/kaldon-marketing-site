---
import BaseLayout from './BaseLayout.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  readTime: string;
  heroImage: string;
  heroAlt: string;
}

const { title, description, category, date, readTime, heroImage, heroAlt } = Astro.props;
---

<BaseLayout title={`${title} | Kaldon Blog`} description={description}>
  <article class="pt-16 md:pt-24 pb-20" style="background: var(--void);">
    <div class="container-custom max-w-prose">
      <!-- Breadcrumb / meta -->
      <div class="flex items-center gap-4 mb-8 pt-8" style="border-top: 1px solid var(--hairline); padding-top: 24px;">
        <a href="/blog" class="link-arrow" style="font-size: 13px;">
          <span class="arrow" aria-hidden="true" style="transform: rotate(180deg) translateY(1px);">→</span>
          <span style="margin-left: 4px;">All articles</span>
        </a>
      </div>

      <!-- Category + meta -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="kicker" style="margin: 0;">{category}</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost); opacity: 0.6;">·</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost);">{date}</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost); opacity: 0.6;">·</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost);">{readTime}</span>
      </div>

      <!-- Title -->
      <h1 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.1; letter-spacing: -0.022em; color: var(--chalk);">{title}</h1>

      <!-- Author -->
      <div class="flex items-center gap-3 mt-10 pb-10" style="border-bottom: 1px solid var(--hairline);">
        <div class="blog-avatar" aria-hidden="true">ST</div>
        <div>
          <p class="font-display font-semibold" style="font-weight: 600; font-size: 14px; color: var(--chalk); letter-spacing: -0.005em;">Sean Travis</p>
          <p class="font-mono" style="font-size: 11px; color: var(--ghost);">Founder · Kaldon</p>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="blog-hero mt-10">
        <img src={heroImage} alt={heroAlt} class="w-full h-auto" loading="eager" />
      </div>

      <!-- Content -->
      <div class="blog-prose mt-10">
        <slot />
      </div>

      <!-- CTA -->
      <div class="mt-16 rounded-card p-8 text-center" style="background: var(--deep-space); border: 1px solid var(--hairline);">
        <span class="kicker">Try Kaldon</span>
        <h3 class="font-display font-semibold mt-2" style="font-weight: 600; font-size: 22px; color: var(--chalk); letter-spacing: -0.015em;">See the pipeline for yourself.</h3>
        <p class="mt-3 text-body-sm" style="color: var(--ghost);">Start with 2 free analyses. No credit card required.</p>
        <div class="mt-6">
          <Button variant="primary" href="https://kaldon.io/signup" data-event="blog_post_cta">
            Start Free
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
            </svg>
          </Button>
        </div>
      </div>
    </div>
  </article>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    author: { '@type': 'Person', name: 'Sean Travis' },
    publisher: {
      '@type': 'Organization',
      name: 'Kaldon',
      logo: { '@type': 'ImageObject', url: 'https://kaldon.io/images/logos/kaldon-logo-dark.svg' },
    },
    datePublished: '2026-03-18',
    image: heroImage.startsWith('http') ? heroImage : `https://kaldon.io${heroImage}`,
    mainEntityOfPage: Astro.url.href,
  })} />
</BaseLayout>

<style>
  .blog-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--void);
    border: 1px solid var(--hairline-active);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    color: var(--chalk);
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .blog-hero {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--hairline);
    background: var(--deep-space);
  }

  /* Typographic prose — editorial treatment */
  .blog-prose {
    color: var(--text-secondary);
    font-size: 16.5px;
    line-height: 1.75;
    letter-spacing: -0.005em;
  }
  .blog-prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--chalk);
    margin-top: 56px;
    margin-bottom: 20px;
  }
  .blog-prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--chalk);
    margin-top: 40px;
    margin-bottom: 16px;
  }
  .blog-prose :global(p) {
    margin-bottom: 20px;
  }
  .blog-prose :global(a) {
    color: var(--signal);
    text-decoration: none;
    transition: color 160ms var(--ease-out-quad);
  }
  .blog-prose :global(a:hover) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-prose :global(strong) {
    color: var(--chalk);
    font-weight: 600;
  }
  .blog-prose :global(ul), .blog-prose :global(ol) {
    margin: 20px 0 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .blog-prose :global(li) {
    line-height: 1.7;
  }
  .blog-prose :global(ul li) { list-style: disc; }
  .blog-prose :global(ol li) { list-style: decimal; }
  .blog-prose :global(blockquote) {
    margin: 28px 0;
    padding: 20px 24px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-left: 2px solid var(--gold);
    border-radius: 0 12px 12px 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }
  .blog-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--deep-space);
    color: var(--signal);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--hairline);
  }
  .blog-prose :global(pre) {
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
    margin: 24px 0;
  }
  .blog-prose :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--text-secondary);
  }
  .blog-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--hairline);
    margin: 48px 0;
  }
</style>
