---
import BaseLayout from './BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { appUrl } from '../lib/urls';

interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  readTime: string;
  heroImage?: string;
  heroAlt?: string;
  /** Auto-generated posts pass these additional fields. Hand-written posts omit. */
  excerpt?: string;
  lastUpdated?: string;
  tldr?: string;
  tags?: string[];
  image?: string; // alt alias used by content-collection frontmatter
}

const {
  title,
  description,
  category,
  date,
  readTime,
  heroImage,
  heroAlt,
  lastUpdated,
  tldr,
  tags = [],
  image,
} = Astro.props;

const resolvedHero = heroImage ?? image ?? null;
const resolvedHeroAlt = heroAlt ?? title;

// All blog posts. source of truth for "Related posts" at the bottom.
// Kept inline here since the blog is small; move to a content collection
// if it grows past ~20 posts.
const allPosts = [
  { slug: 'true-cost-ecommerce-product-launch-2026', title: 'The true cost of launching an eCommerce product in 2026', excerpt: 'Six subscriptions. $205+/mo. 200+ hours of manual work.', category: 'Product Research', date: 'Mar 18, 2026', readTime: '8 min', image: '/images/screenshots/01-analysis-hero.webp' },
  { slug: 'how-to-find-winning-product-sell-online-2026', title: 'How to find a winning product to sell online (2026)', excerpt: 'Step-by-step: niche selection to validation, with frameworks.', category: 'Product Research', date: 'Mar 18, 2026', readTime: '12 min', image: '/images/screenshots/16-opportunity-feed.webp' },
  { slug: 'amazon-to-dtc-build-brand-beyond-marketplace', title: 'Amazon to DTC: build a brand beyond the marketplace', excerpt: 'Reduce marketplace dependency. Build a brand customers seek.', category: 'Brand Building', date: 'Mar 18, 2026', readTime: '10 min', image: '/images/screenshots/07-brand-detail.webp' },
  { slug: 'helium-10-vs-jungle-scout-vs-kaldon', title: 'Helium 10 vs Jungle Scout vs Kaldon: which to use?', excerpt: 'Fair three-way comparison. Features, pricing, what happens after research.', category: 'Marketplace Tips', date: 'Mar 18, 2026', readTime: '10 min', image: '/images/screenshots/17-pricing.webp' },
  { slug: 'what-ai-product-research-actually-looks-like', title: 'What AI product research actually looks like', excerpt: 'Real AI-powered analysis report with commentary on every section.', category: 'Product Research', date: 'Mar 18, 2026', readTime: '9 min', image: '/images/screenshots/03-analysis-action-plan.webp' },
];

// Derive current slug from URL so we can filter the current post out.
const currentSlug = Astro.url.pathname.replace(/\/$/, '').split('/').pop();
const blogCampaign = currentSlug ? `blog_${currentSlug.replace(/-/g, '_')}` : 'blog';

// Pick up to 2 related posts: prefer same category, fall back to any
// other post. Deterministic order.
const sameCategory = allPosts.filter((p) => p.category === category && p.slug !== currentSlug);
const otherPosts = allPosts.filter((p) => p.category !== category && p.slug !== currentSlug);
const relatedPosts = [...sameCategory, ...otherPosts].slice(0, 2);
---

<BaseLayout title={`${title} | Kaldon Blog`} description={description}>
  <article class="pt-16 md:pt-24 pb-20" style="background: var(--void);">
    <div class="container-custom max-w-prose">
      <!-- Breadcrumb / meta -->
      <div class="flex items-center gap-4 mb-8 pt-8" style="border-top: 1px solid var(--hairline); padding-top: 24px;">
        <a href="/blog" class="link-arrow" style="font-size: 13px;">
          <span class="arrow" aria-hidden="true" style="transform: rotate(180deg) translateY(1px);">→</span>
          <span style="margin-left: 4px;">All articles</span>
        </a>
      </div>

      <!-- Category + meta -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="kicker" style="margin: 0;">{category}</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost); opacity: 0.6;">·</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost);">{date}</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost); opacity: 0.6;">·</span>
        <span class="font-mono" style="font-size: 11px; color: var(--ghost);">{readTime}</span>
      </div>

      <!-- Title -->
      <h1 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.1; letter-spacing: -0.022em; color: var(--chalk);">{title}</h1>

      <!-- Author -->
      <div class="flex items-center gap-3 mt-10 pb-10" style="border-bottom: 1px solid var(--hairline);">
        <div class="blog-avatar" aria-hidden="true">ST</div>
        <div>
          <p class="font-display font-semibold" style="font-weight: 600; font-size: 14px; color: var(--chalk); letter-spacing: -0.005em;">Sean Travis</p>
          <p class="font-mono" style="font-size: 11px; color: var(--ghost);">Founder · Kaldon</p>
        </div>
      </div>

      <!-- Hero Image (optional; auto-generated posts may not have one) -->
      {resolvedHero && (
        <div class="blog-hero mt-10">
          <img src={resolvedHero} alt={resolvedHeroAlt} width="1124" height="712" class="w-full h-auto" loading="eager" fetchpriority="high" decoding="async" />
        </div>
      )}

      <!-- TLDR summary (auto-generated posts only) -->
      {tldr && (
        <div class="blog-tldr mt-10">
          <span class="kicker" style="color: var(--gold); margin-bottom: 8px; display: inline-block;">TLDR</span>
          <p style="font-family: var(--font-display); font-weight: 500; font-size: 17px; line-height: 1.5; color: var(--chalk); letter-spacing: -0.01em; margin: 0;">{tldr}</p>
        </div>
      )}

      <!-- Content -->
      <div class="blog-prose mt-10">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="blog-tags mt-8">
          {tags.map((t: string) => (
            <span class="blog-tag">{t}</span>
          ))}
        </div>
      )}

      {lastUpdated && (
        <p class="font-mono mt-6" style="font-size: 11px; color: var(--ghost); letter-spacing: 0.04em;">
          Last updated {lastUpdated}
        </p>
      )}

      <!-- CTA -->
      <div class="mt-16 rounded-card p-8 text-center" style="background: var(--deep-space); border: 1px solid var(--hairline);">
        <span class="kicker">Try Kaldon</span>
        <h3 class="font-display font-semibold mt-2" style="font-weight: 600; font-size: 22px; color: var(--chalk); letter-spacing: -0.015em;">See the pipeline for yourself.</h3>
        <p class="mt-3 text-body-sm" style="color: var(--ghost);">Start with 2 free analyses. No credit card required.</p>
        <div class="mt-6">
          <Button variant="primary" href={appUrl('/signup', blogCampaign)} data-event="blog_post_cta">
            Start Free
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
            </svg>
          </Button>
        </div>
      </div>

      <!-- Related posts. zero-cost CRO lift over exiting at the single CTA -->
      {relatedPosts.length > 0 && (
        <aside class="mt-16 pt-12" style="border-top: 1px solid var(--hairline);">
          <span class="kicker">Keep reading</span>
          <h3 class="font-display font-semibold mt-1 mb-8" style="font-weight: 600; font-size: 22px; color: var(--chalk); letter-spacing: -0.015em;">Related from the Kaldon blog</h3>
          <div class="related-grid">
            {relatedPosts.map((p) => (
              <a href={`/blog/${p.slug}`} class="related-card">
                <div class="related-thumb">
                  <img src={p.image} alt={p.title} width="1124" height="712" loading="lazy" decoding="async" />
                </div>
                <div class="related-meta">
                  <span class="kicker" style="margin: 0; font-size: 10px;">{p.category}</span>
                  <span class="related-dot">·</span>
                  <span class="related-read">{p.readTime}</span>
                </div>
                <h4 class="related-title">{p.title}</h4>
                <span class="link-arrow" style="margin-top: 12px; font-size: 13px;">
                  Read
                  <span class="arrow" aria-hidden="true">→</span>
                </span>
              </a>
            ))}
          </div>
        </aside>
      )}
    </div>
  </article>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    author: { '@type': 'Person', name: 'Sean Travis' },
    publisher: {
      '@type': 'Organization',
      name: 'Kaldon',
      logo: { '@type': 'ImageObject', url: 'https://kaldon.io/images/logos/kaldon-logo-dark.svg' },
    },
    datePublished: lastUpdated ?? '2026-03-18',
    dateModified: lastUpdated ?? '2026-03-18',
    image: resolvedHero
      ? (resolvedHero.startsWith('http') ? resolvedHero : `https://kaldon.io${resolvedHero}`)
      : 'https://kaldon.io/images/og/blog.png',
    mainEntityOfPage: Astro.url.href,
  })} />
</BaseLayout>

<style>
  .blog-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--void);
    border: 1px solid var(--hairline-active);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    color: var(--chalk);
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .blog-hero {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--hairline);
    background: var(--deep-space);
  }

  /* TLDR callout for auto-generated posts (GEO-first formatting) */
  .blog-tldr {
    padding: 24px 28px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-left: 2px solid var(--gold);
    border-radius: 10px;
  }

  /* Tag chips at the end of auto-generated posts */
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .blog-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ghost);
    padding: 4px 10px;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: var(--deep-space);
  }

  /* Typographic prose. editorial treatment */
  .blog-prose {
    color: var(--text-secondary);
    font-size: 16.5px;
    line-height: 1.75;
    letter-spacing: -0.005em;
  }
  .blog-prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--chalk);
    margin-top: 56px;
    margin-bottom: 20px;
  }
  .blog-prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--chalk);
    margin-top: 40px;
    margin-bottom: 16px;
  }
  .blog-prose :global(p) {
    margin-bottom: 20px;
  }
  .blog-prose :global(a) {
    color: var(--signal);
    text-decoration: none;
    transition: color 160ms var(--ease-out-quad);
  }
  .blog-prose :global(a:hover) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-prose :global(strong) {
    color: var(--chalk);
    font-weight: 600;
  }
  .blog-prose :global(ul), .blog-prose :global(ol) {
    margin: 20px 0 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .blog-prose :global(li) {
    line-height: 1.7;
  }
  .blog-prose :global(ul li) { list-style: disc; }
  .blog-prose :global(ol li) { list-style: decimal; }
  .blog-prose :global(blockquote) {
    margin: 28px 0;
    padding: 20px 24px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-left: 2px solid var(--gold);
    border-radius: 0 12px 12px 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }
  .blog-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--deep-space);
    color: var(--signal);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--hairline);
  }
  .blog-prose :global(pre) {
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
    margin: 24px 0;
  }
  .blog-prose :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--text-secondary);
  }
  .blog-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--hairline);
    margin: 48px 0;
  }

  /* Related posts */
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .related-grid { grid-template-columns: 1fr 1fr; gap: 20px; }
  }
  .related-card {
    display: block;
    padding: 20px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .related-card:hover { border-color: var(--hairline-active); }
  .related-card:hover .arrow { transform: translateX(3px); }
  .related-card:hover .related-thumb img { transform: scale(1.03); }
  .related-thumb {
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: var(--void);
    margin-bottom: 14px;
    border: 1px solid var(--hairline);
  }
  .related-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 300ms var(--ease-out-quad);
  }
  .related-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .related-dot { color: var(--ghost); opacity: 0.5; }
  .related-read {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ghost);
  }
  .related-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--chalk);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
</style>
