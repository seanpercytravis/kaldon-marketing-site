---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  competitor: string;
  verdict: string;
  tagline: string;
  kaldonTagline: string;
  features: Array<{ name: string; competitor: string; kaldon: string; }>;
  competitorPrice: string;
  kaldonPrice: string;
  priceSummary: string;
  kaldonAdvantages: Array<{ title: string; description: string; }>;
  competitorAdvantages: Array<{ title: string; description: string; }>;
  chooseCompetitor: Array<string>;
  chooseKaldon: Array<string>;
  migrationTitle: string;
  migrationBody: string;
  migrationSteps: string[];
  faqs: Array<{ q: string; a: string; }>;
}

const { title, description, competitor, verdict, tagline, kaldonTagline, features, competitorPrice, kaldonPrice, priceSummary, kaldonAdvantages, competitorAdvantages, chooseCompetitor, chooseKaldon, migrationTitle, migrationBody, migrationSteps, faqs } = Astro.props;

function renderStatus(val: string) {
  if (val === 'yes') return '<svg class="w-5 h-5 text-[#34d399] mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>';
  if (val === 'no') return '<svg class="w-5 h-5 text-[#f87171] mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>';
  if (val === 'partial') return '<svg class="w-5 h-5 text-[#fbbf24] mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" /></svg>';
  return `<span class="text-sm text-[#94a3b8]">${val}</span>`;
}
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="pt-32 pb-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#22d3ee]/5 via-[#0a0e17] to-[#0a0e17]"></div>
    <div class="container-custom relative z-10 text-center">
      <span class="eyebrow">COMPARE</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#e2e8f0] mb-4">{competitor} vs Kaldon</h1>
      <p class="text-lg text-[#94a3b8] max-w-2xl mx-auto">{tagline}</p>
    </div>
  </section>

  <!-- Quick Verdict -->
  <section class="pb-16">
    <div class="container-custom max-w-3xl">
      <div class="bg-[#1a2236] border border-[rgba(255,255,255,0.08)] rounded-2xl p-8" style="border-left: 4px solid #22d3ee">
        <h2 class="text-sm font-bold uppercase tracking-wider text-[#22d3ee] mb-3">Quick Verdict</h2>
        <p class="text-[#e2e8f0] leading-relaxed">{verdict}</p>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section-spacing">
    <div class="container-custom max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] text-center mb-8">Feature-by-Feature Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse min-w-[600px]">
          <thead>
            <tr class="border-b border-[rgba(255,255,255,0.08)]">
              <th class="text-left py-3 px-4 text-sm font-semibold text-[#94a3b8] sticky left-0 bg-[#0a0e17] z-10 min-w-[200px]">Feature</th>
              <th class="text-center py-3 px-4 text-sm font-semibold text-[#94a3b8] w-32">{competitor}</th>
              <th class="text-center py-3 px-4 text-sm font-semibold text-[#22d3ee] w-32">Kaldon</th>
            </tr>
          </thead>
          <tbody>
            {features.map((f, i) => (
              <tr class={`border-b border-[rgba(255,255,255,0.04)] ${i % 2 === 0 ? 'bg-[#111827]/30' : ''}`}>
                <td class="py-3 px-4 text-sm text-[#e2e8f0] sticky left-0 bg-inherit z-10">{f.name}</td>
                <td class="py-3 px-4 text-center" set:html={renderStatus(f.competitor)} />
                <td class="py-3 px-4 text-center" set:html={renderStatus(f.kaldon)} />
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing Comparison -->
  <section class="section-spacing bg-[#111827]/30">
    <div class="container-custom max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] text-center mb-8">Pricing Comparison</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-2xl p-8 text-center">
          <h3 class="text-lg font-bold text-[#94a3b8] mb-2">{competitor}</h3>
          <p class="text-3xl font-extrabold text-[#e2e8f0] mb-2">{competitorPrice}</p>
          <p class="text-sm text-[#64748b]">For equivalent functionality</p>
        </div>
        <div class="bg-[#111827] border-2 border-[#22d3ee]/30 rounded-2xl p-8 text-center shadow-[0_0_30px_rgba(34,211,238,0.08)]">
          <h3 class="text-lg font-bold text-[#22d3ee] mb-2">Kaldon</h3>
          <p class="text-3xl font-extrabold text-[#e2e8f0] mb-2">{kaldonPrice}</p>
          <p class="text-sm text-[#94a3b8]">{priceSummary}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Kaldon Does That They Don't -->
  <section class="section-spacing">
    <div class="container-custom max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] text-center mb-4">What Kaldon Does That {competitor} Does Not</h2>
      <p class="text-[#94a3b8] text-center mb-8 max-w-2xl mx-auto">Capabilities that are unique to Kaldon and not available in {competitor}.</p>
      <div class="grid md:grid-cols-2 gap-4">
        {kaldonAdvantages.map((adv) => (
          <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl p-5">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#22d3ee] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <div>
                <h3 class="text-[#e2e8f0] font-semibold mb-1">{adv.title}</h3>
                <p class="text-sm text-[#94a3b8] leading-relaxed">{adv.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What They Do That Kaldon Doesn't -->
  <section class="section-spacing bg-[#111827]/30">
    <div class="container-custom max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] text-center mb-4">What {competitor} Does That Kaldon Does Not</h2>
      <p class="text-[#94a3b8] text-center mb-8 max-w-2xl mx-auto">Areas where {competitor} has capabilities that Kaldon currently does not offer.</p>
      <div class="grid md:grid-cols-2 gap-4">
        {competitorAdvantages.map((adv) => (
          <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl p-5">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#fbbf24] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" /></svg>
              <div>
                <h3 class="text-[#e2e8f0] font-semibold mb-1">{adv.title}</h3>
                <p class="text-sm text-[#94a3b8] leading-relaxed">{adv.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who Should Choose Whom -->
  <section class="section-spacing">
    <div class="container-custom max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] text-center mb-8">Who Should Choose What</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-2xl p-6">
          <h3 class="text-lg font-bold text-[#94a3b8] mb-4 flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            Choose {competitor} If You...
          </h3>
          <ul class="space-y-3">
            {chooseCompetitor.map((item) => (
              <li class="flex items-start gap-2 text-sm text-[#94a3b8]">
                <svg class="w-4 h-4 text-[#64748b] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-[#111827] border-2 border-[#22d3ee]/30 rounded-2xl p-6 shadow-[0_0_30px_rgba(34,211,238,0.08)]">
          <h3 class="text-lg font-bold text-[#22d3ee] mb-4 flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            Choose Kaldon If You...
          </h3>
          <ul class="space-y-3">
            {chooseKaldon.map((item) => (
              <li class="flex items-start gap-2 text-sm text-[#e2e8f0]">
                <svg class="w-4 h-4 text-[#22d3ee] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Migration Path -->
  <section class="section-spacing bg-[#111827]/30">
    <div class="container-custom max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] text-center mb-4">{migrationTitle}</h2>
      <p class="text-[#94a3b8] text-center mb-8">{migrationBody}</p>
      <div class="space-y-3">
        {migrationSteps.map((step, i) => (
          <div class="flex items-start gap-4 bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl p-4">
            <span class="w-8 h-8 rounded-full bg-[#22d3ee]/10 text-[#22d3ee] flex items-center justify-center text-sm font-bold shrink-0">{i + 1}</span>
            <p class="text-sm text-[#e2e8f0] pt-1">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-spacing">
    <div class="container-custom max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] text-center mb-8">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between p-5 text-left cursor-pointer" data-faq={i}>
              <span class="text-[#e2e8f0] font-medium pr-4">{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 text-[#94a3b8] shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden px-5 pb-5">
              <p class="text-sm text-[#94a3b8] leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-spacing relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#22d3ee]/10 via-[#0a0e17] to-[#a78bfa]/10"></div>
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#e2e8f0] mb-4">{kaldonTagline}</h2>
      <p class="text-lg text-[#94a3b8] mb-8">Start Free, 2 Analyses Included. No credit card required.</p>
      <a href="https://kaldon.io/signup" class="btn-primary btn-large btn-glow inline-flex items-center gap-2">Start Free, 2 Analyses Included <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></a>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.faq-toggle').forEach(btn => {
      btn.addEventListener('click', function() {
        const answer = this.nextElementSibling;
        const chevron = this.querySelector('.faq-chevron');
        const isOpen = !answer.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-chevron').forEach(c => c.style.transform = '');
        if (!isOpen) { answer.classList.remove('hidden'); chevron.style.transform = 'rotate(180deg)'; }
      });
    });
  </script>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
</BaseLayout>
