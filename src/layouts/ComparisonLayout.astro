---
import BaseLayout from './BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  title: string;
  description: string;
  competitor: string;
  verdict: string;
  tagline: string;
  kaldonTagline: string;
  features: Array<{ name: string; competitor: string; kaldon: string }>;
  competitorPrice: string;
  kaldonPrice: string;
  priceSummary: string;
  kaldonAdvantages: Array<{ title: string; description: string }>;
  competitorAdvantages: Array<{ title: string; description: string }>;
  chooseCompetitor: Array<string>;
  chooseKaldon: Array<string>;
  migrationTitle: string;
  migrationBody: string;
  migrationSteps: string[];
  faqs: Array<{ q: string; a: string }>;
  structuredData?: object[];
}

const {
  title,
  description,
  competitor,
  verdict,
  tagline,
  kaldonTagline,
  features,
  competitorPrice,
  kaldonPrice,
  priceSummary,
  kaldonAdvantages,
  competitorAdvantages,
  chooseCompetitor,
  chooseKaldon,
  migrationTitle,
  migrationBody,
  migrationSteps,
  faqs,
  structuredData = [],
} = Astro.props;

// Auto-extend with a SoftwareApplication schema specific to this comparison.
// Search engines use this to surface Kaldon as an alternative in competitor
// queries (e.g. "jungle scout alternative").
const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Kaldon',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: `Kaldon is an AI-powered eCommerce intelligence platform that replaces ${competitor} and the full creation stack. ${kaldonTagline}`,
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: '0',
    highPrice: '1499',
    priceCurrency: 'USD',
    offerCount: '5',
  },
};
const allStructuredData = [softwareAppSchema, ...structuredData];

function renderStatus(val: string): string {
  if (val === 'yes') {
    return '<svg class="w-4 h-4 mx-auto" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 L8 14.5 L16 6" stroke="#F5F5F7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>';
  }
  if (val === 'no') {
    return '<span class="text-text-quaternary text-sm" aria-hidden="true">. </span><span class="sr-only">Not included</span>';
  }
  if (val === 'partial') {
    return '<span class="font-mono text-xs" style="color: var(--gold);">Partial</span>';
  }
  return `<span class="text-sm" style="color: var(--ghost);">${val}</span>`;
}
---

<BaseLayout title={title} description={description} structuredData={allStructuredData}>
  <PageHero kicker="Compare" headline={`${competitor} vs Kaldon`} subhead={tagline} />

  <!-- Quick Verdict -->
  <section class="pb-12 md:pb-16" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <div class="rounded-card p-8" style="background: var(--deep-space); border: 1px solid var(--hairline); border-left: 2px solid var(--signal);">
        <span class="kicker" style="color: var(--signal); margin-bottom: 10px;">Quick Verdict</span>
        <p class="text-body-lg" style="color: var(--chalk); line-height: 1.55; letter-spacing: -0.005em;">{verdict}</p>
      </div>
    </div>
  </section>

  <!-- Feature comparison -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Feature Comparison</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Side by side
        </h2>
      </header>
      <div class="comparison-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="sticky-col">Feature</th>
              <th>{competitor}</th>
              <th class="highlight">Kaldon</th>
            </tr>
          </thead>
          <tbody>
            {features.map((f) => (
              <tr>
                <td class="sticky-col">{f.name}</td>
                <td set:html={renderStatus(f.competitor)} />
                <td class="highlight" set:html={renderStatus(f.kaldon)} />
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing side-by-side -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Pricing</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          What you pay
        </h2>
      </header>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="rounded-card p-8 text-center" style="background: var(--deep-space); border: 1px solid var(--hairline);">
          <h3 class="font-display" style="font-weight: 500; font-size: 15px; color: var(--ghost); letter-spacing: -0.005em;">{competitor}</h3>
          <p class="font-display mt-3" style="font-weight: 500; font-size: 32px; color: var(--chalk); letter-spacing: -0.025em; line-height: 1;">{competitorPrice}</p>
          <p class="mt-2 text-body-sm" style="color: var(--ghost);">For equivalent functionality</p>
        </div>
        <div class="compare-pricing-kaldon rounded-card p-8 text-center relative">
          <h3 class="font-display" style="font-weight: 500; font-size: 15px; color: var(--gold); letter-spacing: -0.005em;">Kaldon</h3>
          <p class="font-display mt-3" style="font-weight: 500; font-size: 32px; color: var(--chalk); letter-spacing: -0.025em; line-height: 1;">{kaldonPrice}</p>
          <p class="mt-2 text-body-sm" style="color: var(--ghost);">{priceSummary}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Kaldon Does That They Don't -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Only in Kaldon</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          What Kaldon does that {competitor} doesn't
        </h2>
      </header>
      <div class="grid md:grid-cols-2 gap-4">
        {kaldonAdvantages.map((adv) => (
          <div class="advantage-card">
            <svg class="adv-check" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10.5 L8 14.5 L16 6" stroke="#FFB800" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <div>
              <h3 class="adv-title">{adv.title}</h3>
              <p class="adv-desc">{adv.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What They Do That Kaldon Doesn't -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Honest trade-offs</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          What {competitor} does that Kaldon doesn't
        </h2>
      </header>
      <div class="grid md:grid-cols-2 gap-4">
        {competitorAdvantages.map((adv) => (
          <div class="advantage-card">
            <svg class="adv-check" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true" style="color: var(--ghost);">
              <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5" />
              <path d="M7 10 L13 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
            <div>
              <h3 class="adv-title">{adv.title}</h3>
              <p class="adv-desc">{adv.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who should choose what -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Decision Guide</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Who should choose what
        </h2>
      </header>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="choose-card">
          <p class="choose-label">Choose {competitor} if you…</p>
          <ul class="choose-list">
            {chooseCompetitor.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        <div class="choose-card choose-kaldon">
          <p class="choose-label" style="color: var(--gold);">Choose Kaldon if you…</p>
          <ul class="choose-list">
            {chooseKaldon.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Migration path -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10">
        <span class="kicker">Migration Path</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          {migrationTitle}
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">{migrationBody}</p>
      </header>
      <ol class="migration-steps">
        {migrationSteps.map((step, i) => (
          <li>
            <span class="migration-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="migration-text">{step}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10">
        <span class="kicker">FAQ</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Frequently asked questions
        </h2>
      </header>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="faq-item" name="compare-faq">
            <summary class="faq-summary">
              <span class="faq-q">{faq.q}</span>
              <svg class="faq-chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="faq-answer"><p>{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        {kaldonTagline}
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Start free. 2 analyses. No credit card. See for yourself.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href="https://kaldon.io/signup" data-event="compare_cta">
          Start Free, 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
</BaseLayout>

<style>
  /* Comparison table. shared pattern */
  .comparison-wrap {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--hairline);
    background: var(--deep-space);
  }
  .comparison-table {
    width: 100%;
    min-width: 560px;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 14px;
  }
  .comparison-table thead th {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
    text-align: center;
    padding: 18px 12px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--hairline);
  }
  .comparison-table thead th.sticky-col { text-align: left; padding-left: 20px; }
  .comparison-table thead th.highlight { color: var(--gold); }
  .comparison-table td {
    padding: 14px 12px;
    text-align: center;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--hairline);
  }
  .comparison-table td.sticky-col {
    text-align: left;
    color: var(--chalk);
    padding-left: 20px;
  }
  .comparison-table td.highlight {
    background: rgba(255, 184, 0, 0.03);
  }
  .comparison-table tr:last-child td { border-bottom: none; }

  /* Pricing side-by-side */
  .compare-pricing-kaldon {
    background: var(--deep-space);
    border: 1px solid transparent;
    position: relative;
  }
  .compare-pricing-kaldon::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(to bottom right, rgba(255, 184, 0, 0.4), rgba(0, 212, 255, 0.2) 60%, rgba(255, 255, 255, 0.06));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  /* Advantage cards */
  .advantage-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px 22px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .advantage-card:hover { border-color: var(--hairline-active); }
  .adv-check { flex-shrink: 0; margin-top: 2px; }
  .adv-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }
  .adv-desc {
    margin-top: 4px;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ghost);
    letter-spacing: -0.005em;
  }

  /* Choose cards */
  .choose-card {
    padding: 28px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
  }
  .choose-kaldon {
    border-color: transparent;
    position: relative;
  }
  .choose-kaldon::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(to bottom right, rgba(255, 184, 0, 0.5), rgba(0, 212, 255, 0.2) 60%, rgba(255, 255, 255, 0.05));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  .choose-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
    margin-bottom: 16px;
  }
  .choose-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .choose-list li {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    letter-spacing: -0.005em;
    padding-left: 18px;
    position: relative;
  }
  .choose-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--ghost);
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .choose-kaldon .choose-list li::before { color: var(--gold); }

  /* Migration steps */
  .migration-steps {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .migration-steps li {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 18px 22px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
  }
  .migration-num {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    color: var(--gold);
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .migration-text {
    font-size: 14px;
    color: var(--chalk);
    line-height: 1.5;
    letter-spacing: -0.005em;
  }

  /* FAQ (shared with pricing page pattern) */
  .faq-item {
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .faq-item:hover { border-color: var(--hairline-active); }
  .faq-item[open] { border-color: var(--hairline-active); }
  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 16px;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }
  .faq-chevron {
    color: var(--ghost);
    transition: transform 200ms var(--ease-out-quad);
    flex-shrink: 0;
    margin-left: 16px;
  }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-answer {
    padding: 0 24px 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ghost);
  }
</style>
