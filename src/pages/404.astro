---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Kaldon" description="The page you are looking for does not exist.">
  <section class="pt-32 pb-20 min-h-[70vh] flex items-center">
    <div class="container-custom text-center">
      <div class="mb-8">
        <span class="text-8xl md:text-9xl font-extrabold bg-gradient-to-r from-[#22d3ee] to-[#3b82f6] bg-clip-text text-transparent">404</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-[#e2e8f0] mb-4">This page does not exist.</h1>
      <p class="text-lg text-[#94a3b8] mb-8 max-w-md mx-auto">The page you are looking for may have been moved, deleted, or never existed in the first place.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="btn-primary inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          Back to Home
        </a>
        <a href="/pricing" class="px-5 py-2.5 rounded-lg border border-[rgba(255,255,255,0.12)] text-[#e2e8f0] text-sm font-medium hover:border-[rgba(255,255,255,0.25)] transition-colors">View Pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>
