---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import { getCollection } from 'astro:content';

// Hand-written posts (editorial seed). Kept explicit so their hero images,
// categories, and excerpts are authored, not generated.
const handWrittenPosts = [
  { slug: 'true-cost-ecommerce-product-launch-2026', title: 'The true cost of launching an eCommerce product in 2026', excerpt: 'Six subscriptions. $205+ per month. 200+ hours of manual work. We break down exactly what it costs to launch a product the old way, and the alternative.', category: 'Product Research', date: 'Mar 18, 2026', sortDate: '2026-03-18', readTime: '8 min', image: '/images/screenshots/01-analysis-hero.webp' },
  { slug: 'how-to-find-winning-product-sell-online-2026', title: 'How to find a winning product to sell online (complete 2026 guide)', excerpt: 'A step-by-step guide to finding profitable products in 2026. From niche selection to validation, with actionable frameworks.', category: 'Product Research', date: 'Mar 18, 2026', sortDate: '2026-03-18', readTime: '12 min', image: '/images/screenshots/16-opportunity-feed.webp' },
  { slug: 'amazon-to-dtc-build-brand-beyond-marketplace', title: 'Amazon to DTC: how to build a brand beyond the marketplace', excerpt: "You're making sales on Amazon. Now what? How to reduce marketplace dependency and build a brand customers seek out directly.", category: 'Brand Building', date: 'Mar 18, 2026', sortDate: '2026-03-18', readTime: '10 min', image: '/images/screenshots/07-brand-detail.webp' },
  { slug: 'helium-10-vs-jungle-scout-vs-kaldon', title: 'Helium 10 vs Jungle Scout vs Kaldon: which should you use?', excerpt: 'A fair, detailed three-way comparison of the most popular product research platforms. Features, pricing, and what happens after research.', category: 'Marketplace Tips', date: 'Mar 18, 2026', sortDate: '2026-03-18', readTime: '10 min', image: '/images/screenshots/17-pricing.webp' },
  { slug: 'what-ai-product-research-actually-looks-like', title: 'What AI product research actually looks like (no hype, real output)', excerpt: 'Forget the marketing buzzwords. A real AI-powered product analysis report with commentary on every section.', category: 'Product Research', date: 'Mar 18, 2026', sortDate: '2026-03-18', readTime: '9 min', image: '/images/screenshots/03-analysis-action-plan.webp' },
];

// Auto-generated posts (weekly cron). Pulled from the content collection.
const autoCollection = await getCollection('blog');
const autoPosts = autoCollection.map((p) => ({
  slug: p.data.slug,
  title: p.data.title,
  excerpt: p.data.excerpt,
  category: p.data.category,
  date: p.data.date,
  sortDate: p.data.lastUpdated ?? p.data.date,
  readTime: p.data.readTime,
  image: p.data.image ?? '/images/screenshots/01-analysis-hero.webp',
  autoGenerated: true,
}));

// Newest first. lastUpdated (ISO) and sortDate ('Apr 20, 2026') both sort-friendly.
const posts = [...autoPosts, ...handWrittenPosts].sort((a, b) => {
  const ad = new Date(a.sortDate).getTime();
  const bd = new Date(b.sortDate).getTime();
  return bd - ad;
});

const categories = ['All', 'Product Research', 'Brand Building', 'Marketplace Tips'];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Kaldon Blog',
    description:
      'Expert insights on product research, brand building, content strategy, and marketplace optimization for eCommerce sellers.',
    url: 'https://kaldon.io/blog',
    inLanguage: 'en-US',
    publisher: {
      '@type': 'Organization',
      '@id': 'https://kaldon.io/#org',
      name: 'Kaldon',
      url: 'https://kaldon.io',
      logo: {
        '@type': 'ImageObject',
        url: 'https://kaldon.io/images/logos/kaldon-logo-dark.svg',
      },
    },
  },
];
---

<BaseLayout
  title="Kaldon Blog · eCommerce Intelligence, Product Research, and Brand Building"
  description="Expert insights on product research, brand building, content strategy, and marketplace optimization. Real strategies from the Kaldon team."
  structuredData={structuredData}
>
  <PageHero
    kicker="Blog"
    headline="eCommerce intelligence, unpacked."
    subhead="Product research, brand building, and growing across marketplaces. No hype, real frameworks."
  />

  <!-- Category filter -->
  <section class="pb-10" style="background: var(--void);">
    <div class="container-custom flex flex-wrap justify-center gap-2">
      {categories.map((cat, i) => (
        <button
          class={`category-tab ${i === 0 ? 'active' : ''}`}
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </section>

  <!-- Posts grid -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="blog-card" data-category={post.category}>
            <div class="blog-card-image">
              <img src={post.image} alt={post.title} width="1124" height="712" loading="lazy" decoding="async" />
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="kicker" style="margin: 0;">{post.category}</span>
                <span class="font-mono" style="font-size: 10px; color: var(--ghost); opacity: 0.6;">·</span>
                <span class="font-mono" style="font-size: 10px; color: var(--ghost);">{post.readTime}</span>
              </div>
              <h3 class="blog-card-title">{post.title}</h3>
              <p class="blog-card-excerpt">{post.excerpt}</p>
              <div class="blog-card-footer">
                <span class="font-mono" style="font-size: 11px; color: var(--ghost);">{post.date}</span>
                <span class="arrow" aria-hidden="true">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.category-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        const cat = this.dataset.category;
        document.querySelectorAll('.category-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        document.querySelectorAll('.blog-card').forEach(card => {
          if (cat === 'All' || card.dataset.category === cat) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .category-tab {
    display: inline-flex;
    align-items: center;
    height: 32px;
    padding: 0 14px;
    border-radius: 999px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    color: var(--ghost);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: border-color 160ms var(--ease-out-quad), color 160ms var(--ease-out-quad), background 160ms var(--ease-out-quad);
  }
  .category-tab:hover { color: var(--chalk); border-color: var(--hairline-active); }
  .category-tab.active {
    background: var(--gold);
    color: var(--void);
    border-color: transparent;
    font-weight: 500;
  }

  .blog-card {
    display: block;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .blog-card:hover { border-color: var(--hairline-active); }
  .blog-card:hover .arrow { transform: translateX(3px); }
  .blog-card:hover .blog-card-image img { transform: scale(1.03); }

  .blog-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--hairline);
    background: var(--void);
  }
  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 300ms var(--ease-out-quad);
  }

  .blog-card-body { padding: 20px 22px 22px; }
  .blog-card-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .blog-card-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--chalk);
    margin-bottom: 10px;
  }
  .blog-card-excerpt {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ghost);
    letter-spacing: -0.005em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-footer {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .arrow { transition: transform 200ms var(--ease-out-quad); color: var(--ghost); }
</style>
