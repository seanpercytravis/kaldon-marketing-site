---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import Button from '../../components/ui/Button.astro';

const costBreakdown = [
  { category: 'Product research tools', diy: '$50–150 / mo', kaldon: 'Included' },
  { category: 'Brand identity & design', diy: '$2,000–10,000', kaldon: 'Included' },
  { category: 'Logo design', diy: '$500–3,000', kaldon: 'Included' },
  { category: 'eCommerce store (Shopify + theme)', diy: '$39–105 / mo', kaldon: 'Included' },
  { category: 'Store apps & plugins', diy: '$100–300 / mo', kaldon: 'Included' },
  { category: 'Social media content', diy: '$500–2,000 / mo', kaldon: 'Included' },
  { category: 'Blog content', diy: '$300–1,500 / mo', kaldon: 'Included' },
  { category: 'Email marketing setup', diy: '$50–200 / mo', kaldon: 'Included' },
  { category: 'Product photography', diy: '$200–1,000 per product', kaldon: 'AI mockups included' },
  { category: 'Video content', diy: '$500–5,000 per video', kaldon: 'Included' },
  { category: 'Ad campaign setup', diy: '$500–2,000 (agency)', kaldon: 'Included (excl. ad spend)' },
  { category: 'Business strategy / coaching', diy: '$200–500 / mo', kaldon: 'AI coaching included' },
];

const timeComparison = [
  { task: 'Product research and validation', diy: '2–4 weeks', kaldon: '30 minutes' },
  { task: 'Brand identity creation', diy: '2–6 weeks', kaldon: '5 minutes' },
  { task: 'Logo and visual assets', diy: '1–3 weeks', kaldon: '2 minutes' },
  { task: 'Store setup and configuration', diy: '1–4 weeks', kaldon: '10 minutes' },
  { task: 'First month of content', diy: '2–4 weeks', kaldon: '15 minutes' },
  { task: 'Email sequences', diy: '1–2 weeks', kaldon: '5 minutes' },
  { task: 'Marketplace listings', diy: '1–2 weeks', kaldon: '10 minutes' },
  { task: 'Total time to launch', diy: '8–20 weeks', kaldon: '1–2 days', total: true },
];

const faqs = [
  { q: 'What is the "$10,000 Problem"?', a: 'Most eCommerce sellers spend $5,000–15,000 before making their first sale. Product research subscriptions, a freelance designer for branding, a Shopify store plus $200 / mo in apps, a content writer, a social media manager, an email marketing tool, an ad agency or consultant. We call it the "$10,000 Problem" because that\'s approximately what it costs to assemble the services and tools needed to launch a product brand. Kaldon collapses this into one subscription at $149 / mo.' },
  { q: 'Is DIY quality better than AI-generated content?', a: 'It depends on the provider. A top-tier agency will produce exceptional brand work, but most new sellers can\'t afford top-tier agencies. They end up with mediocre freelancers on Fiverr or templates they customize themselves. Kaldon\'s AI generates professional-quality brand identities, content, and store designs that are better than what most sellers produce on their own and comparable to mid-range agency work.' },
  { q: 'Can I hire freelancers for less than agency prices?', a: 'Yes, and many sellers do. A freelance designer might charge $500 for a logo, a writer $200 for blog posts. But you still need to find them, manage them, provide direction, wait for revisions, and coordinate across multiple freelancers. The total cost in money and time is significant. Kaldon eliminates the coordination overhead entirely.' },
  { q: 'What if I want a custom brand identity, not AI-generated?', a: 'You can use Kaldon\'s AI-generated brand as a starting point and hire a designer to refine it. Many sellers find the AI output strong enough to launch with, then invest in custom design work once revenue is flowing. This eliminates the upfront risk.' },
  { q: 'How much time does the DIY approach actually take?', a: 'Based on seller surveys, the average new eCommerce seller spends 8–20 weeks getting from "I want to sell online" to their first live listing. This includes learning tools, finding freelancers, waiting for deliverables, setting up the store, and creating content. Kaldon compresses this to 1–2 days because the pipeline is connected and automated.' },
  { q: 'Is Kaldon right for experienced sellers who already have a team?', a: 'Yes. Even experienced sellers with existing teams use Kaldon to accelerate new product launches. Instead of deploying your team for weeks on brand development and content creation for a new line, Kaldon generates the foundation in hours, freeing your team to focus on optimization and growth.' },
];
---

<BaseLayout
  title="Kaldon vs Doing It Yourself: The $10,000 Problem Solved (2026)"
  description="New eCommerce sellers spend $5,000–15,000 and 8–20 weeks before their first sale. Kaldon replaces consultants, designers, and agencies with one AI-powered platform."
>
  <PageHero
    kicker="Category Comparison"
    headline="Kaldon vs doing it yourself"
    subhead="Creating a new product the traditional way (finding unmet demand, verifying a supplier, building a brand, shipping a store) takes months and costs $5,000–15,000 in tools, freelancers, and agencies. Kaldon collapses it into days."
    stats={[
      { label: 'DIY timeline', numeral: '8–20', suffix: ' wk', sub: 'To first live product' },
      { label: 'Kaldon timeline', numeral: '1–2', suffix: ' days', sub: 'From concept to launch', accent: 'gold' },
      { label: 'DIY cost', prefix: '$', numeral: '18k', suffix: '+', sub: 'Tools + freelancers + agencies', accent: 'signal' },
    ]}
  />

  <!-- The $10k problem -->
  <section class="pb-12 md:pb-16" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <div class="rounded-card p-8" style="background: var(--deep-space); border: 1px solid var(--hairline); border-left: 2px solid var(--gold);">
        <span class="kicker" style="color: var(--gold); margin-bottom: 10px;">The $10,000 Problem</span>
        <p class="text-body-lg" style="color: var(--chalk); line-height: 1.55; letter-spacing: -0.005em;">
          Most eCommerce sellers spend $5,000–15,000 before making their first sale. Product research subscriptions. A freelance designer for branding. A Shopify store plus $200 / mo in apps. A content writer. A social media manager. An email marketing tool. An ad agency or consultant.
        </p>
      </div>
    </div>
  </section>

  <!-- Cost breakdown -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Cost Breakdown</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          What you'd pay without Kaldon
        </h2>
      </header>
      <div class="comparison-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="sticky-col">Category</th>
              <th>DIY cost</th>
              <th class="highlight">With Kaldon</th>
            </tr>
          </thead>
          <tbody>
            {costBreakdown.map((row) => (
              <tr>
                <td class="sticky-col">{row.category}</td>
                <td><span style="font-family: var(--font-mono); font-size: 12px; color: var(--ghost);">{row.diy}</span></td>
                <td class="highlight"><span style="font-family: var(--font-mono); font-size: 12px; color: var(--gold);">{row.kaldon}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Time comparison -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Time Comparison</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          DIY takes months. Kaldon takes days.
        </h2>
      </header>
      <div class="comparison-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="sticky-col">Task</th>
              <th>DIY</th>
              <th class="highlight">Kaldon</th>
            </tr>
          </thead>
          <tbody>
            {timeComparison.map((row) => (
              <tr class={row.total ? 'total-row' : ''}>
                <td class="sticky-col">{row.task}</td>
                <td><span style="font-family: var(--font-mono); font-size: 12px; color: var(--ghost);">{row.diy}</span></td>
                <td class="highlight"><span style="font-family: var(--font-mono); font-size: 12px; color: var(--gold);">{row.kaldon}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10">
        <span class="kicker">FAQ</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Frequently asked questions
        </h2>
      </header>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="faq-item" name="diy-faq">
            <summary class="faq-summary">
              <span class="faq-q">{faq.q}</span>
              <svg class="faq-chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="faq-answer"><p>{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        Stop stitching tools together. Start shipping.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Start free. 2 analyses. No credit card required.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href="https://kaldon.io/signup" data-event="compare_diy_cta">
          Start Free, 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  })} />
</BaseLayout>

<style>
  .comparison-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--hairline); background: var(--deep-space); }
  .comparison-table { width: 100%; min-width: 560px; border-collapse: separate; border-spacing: 0; font-size: 14px; }
  .comparison-table thead th { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500; text-align: center; padding: 18px 12px; background: rgba(255, 255, 255, 0.02); border-bottom: 1px solid var(--hairline); }
  .comparison-table thead th.sticky-col { text-align: left; padding-left: 20px; }
  .comparison-table thead th.highlight { color: var(--gold); }
  .comparison-table td { padding: 14px 12px; text-align: center; color: var(--text-secondary); border-bottom: 1px solid var(--hairline); }
  .comparison-table td.sticky-col { text-align: left; color: var(--chalk); padding-left: 20px; }
  .comparison-table td.highlight { background: rgba(255, 184, 0, 0.03); }
  .comparison-table tr:last-child td { border-bottom: none; }
  .comparison-table tr.total-row td { background: rgba(255, 184, 0, 0.06); font-weight: 500; }
  .comparison-table tr.total-row td.sticky-col { color: var(--chalk); font-weight: 600; }

  .faq-item { background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; overflow: hidden; transition: border-color 160ms var(--ease-out-quad); }
  .faq-item:hover, .faq-item[open] { border-color: var(--hairline-active); }
  .faq-summary { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; cursor: pointer; list-style: none; }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-q { font-family: var(--font-display); font-weight: 500; font-size: 16px; color: var(--chalk); letter-spacing: -0.01em; }
  .faq-chevron { color: var(--ghost); transition: transform 200ms var(--ease-out-quad); flex-shrink: 0; margin-left: 16px; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.6; color: var(--ghost); }
</style>
