---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import Button from '../../components/ui/Button.astro';

const platforms = [
  { name: 'Shopify', price: '$39–399 / mo + apps', focus: 'Online store + POS', strength: 'Massive app ecosystem, proven at scale', link: '/vs/shopify' },
  { name: 'BigCommerce', price: '$39–399 / mo', focus: 'Online store', strength: 'Built-in features, multi-channel', link: null },
  { name: 'Wix', price: '$17–159 / mo', focus: 'Website + store', strength: 'Drag-and-drop ease, templates', link: null },
  { name: 'Squarespace', price: '$16–65 / mo', focus: 'Website + store', strength: 'Beautiful design templates', link: null },
  { name: 'ClickFunnels', price: '$97–297 / mo', focus: 'Sales funnels', strength: 'Conversion-optimized funnels', link: null },
];

const features = [
  { name: 'Online Store', platforms: 'yes', kaldon: 'yes' },
  { name: 'Checkout / Payments', platforms: 'yes', kaldon: 'yes' },
  { name: 'Landing Pages', platforms: 'yes', kaldon: 'yes' },
  { name: 'Blog', platforms: 'yes', kaldon: 'yes' },
  { name: 'Custom Themes (thousands)', platforms: 'yes', kaldon: 'Limited' },
  { name: 'App / Plugin Ecosystem', platforms: 'Most', kaldon: 'no' },
  { name: 'POS (Point of Sale)', platforms: 'Shopify, Square', kaldon: 'no' },
  { name: 'Product Research', platforms: 'no', kaldon: 'yes' },
  { name: 'Market Intelligence', platforms: 'no', kaldon: 'yes' },
  { name: 'AI Viability Scoring', platforms: 'no', kaldon: 'yes' },
  { name: 'AI Product Mockups', platforms: 'no', kaldon: 'yes' },
  { name: 'Brand Identity Generation', platforms: 'no', kaldon: 'yes' },
  { name: 'AI Logo Creation', platforms: 'no', kaldon: 'yes' },
  { name: 'AI Content Generation', platforms: 'no', kaldon: 'yes' },
  { name: 'Social Media Content', platforms: 'no', kaldon: 'yes' },
  { name: 'Video Studio', platforms: 'no', kaldon: 'yes' },
  { name: 'Email Marketing (native)', platforms: 'Limited', kaldon: 'yes' },
  { name: 'Amazon Intelligence', platforms: 'Limited', kaldon: 'yes' },
  { name: 'Walmart Intelligence', platforms: 'no', kaldon: 'yes' },
  { name: 'Ad Campaign Management', platforms: 'no', kaldon: 'yes' },
  { name: 'AI Coaching', platforms: 'no', kaldon: 'yes' },
  { name: 'Connected Intelligence Pipeline', platforms: 'no', kaldon: 'yes' },
];

const faqs = [
  { q: 'Is Kaldon a Shopify replacement?', a: 'For sellers launching new product brands, Kaldon replaces Shopify and the $200+ / mo in apps most Shopify sellers need. If you need a highly customized enterprise storefront, POS for physical retail, or access to thousands of third-party apps, Shopify remains the better choice. See our detailed Shopify comparison for more.' },
  { q: 'Can I use Kaldon if I already have a Shopify or BigCommerce store?', a: 'Yes. Many sellers use Kaldon for product research, brand building, and content creation, then apply those assets to their existing store. You can also use Kaldon\'s built-in store alongside or instead of your current platform.' },
  { q: 'Do eCommerce platforms include product research?', a: 'No. eCommerce platforms provide the store, but they don\'t tell you what to sell, how to brand it, or what content to create. Sellers typically spend $100–300 / mo on separate research, content, and marketing tools. Kaldon includes all of this natively.' },
  { q: 'What about BigCommerce, Wix, or Squarespace?', a: 'These platforms share the same fundamental limitation as Shopify: they give you a store but no intelligence. You still need to figure out what to sell, build a brand, create content, and drive traffic on your own. Kaldon handles the full pipeline from research to live, marketed store.' },
  { q: 'How does Kaldon compare to ClickFunnels?', a: 'ClickFunnels is focused on sales funnels and conversion optimization. It does not include product research, brand creation, or content generation. Kaldon includes landing page and funnel capabilities as part of a broader platform that starts with market intelligence.' },
  { q: 'What is the true cost of running an eCommerce platform?', a: 'The platform subscription is just the start. Most sellers add $100–300 / mo in apps and tools for email marketing, SEO, content, reviews, analytics, and design. Add freelancers for branding and content, and the true cost reaches $300–800 / mo. Kaldon replaces most of this stack at $149 / mo.' },
];

function renderCell(val: string): string {
  if (val === 'yes') return '<svg class="w-4 h-4 mx-auto" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 L8 14.5 L16 6" stroke="#F5F5F7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>';
  if (val === 'no') return '<span style="color: var(--text-quaternary); font-size: 16px;" aria-hidden="true">. </span><span class="sr-only">Not included</span>';
  return `<span style="font-family: var(--font-mono); font-size: 12px; color: var(--gold);">${val}</span>`;
}
---

<BaseLayout
  title="Kaldon vs eCommerce Platforms: Intelligence Meets Commerce (2026)"
  description="eCommerce platforms give you a store but no intelligence. Kaldon gives you both. Compare Kaldon against Shopify, BigCommerce, Wix, Squarespace, and ClickFunnels."
>
  <PageHero
    kicker="Category Comparison"
    headline="Kaldon vs eCommerce platforms"
    subhead="Shopify gives you a storefront for products you already have. Kaldon helps you find what to build, verify a supplier, ship it, and market it. One uses the other."
    stats={[
      { label: 'Platforms give you', numeral: 1, sub: 'A storefront' },
      { label: 'Kaldon gives you', numeral: 5, sub: 'Phases + the store', accent: 'gold' },
      { label: 'Apps replaced', prefix: '$', numeral: '200', suffix: '+/mo', sub: 'Email · SEO · content · analytics', accent: 'signal' },
    ]}
  />

  <!-- Positioning callout -->
  <section class="pb-12 md:pb-16" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <div class="rounded-card p-8" style="background: var(--deep-space); border: 1px solid var(--hairline); border-left: 2px solid var(--signal);">
        <span class="kicker" style="color: var(--signal); margin-bottom: 10px;">The Storefront vs. The Business</span>
        <p class="text-body-lg" style="color: var(--chalk); line-height: 1.55; letter-spacing: -0.005em;">
          Your eCommerce platform is the storefront. Kaldon is the business brain that decides what to stock, how to brand it, what to say about it, and how to get people in the door. Use them together, or use Kaldon's built-in store and skip the $200+ / mo in Shopify apps.
        </p>
      </div>
    </div>
  </section>

  <!-- Platforms landscape -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="text-center mb-10">
        <span class="kicker">Landscape</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          The platforms landscape
        </h2>
      </header>
      <div class="grid gap-3">
        {platforms.map((p) => (
          <div class="tool-row">
            <div class="tool-col name">
              <h3 class="tool-name">{p.name}</h3>
              <p class="tool-price">{p.price}</p>
            </div>
            <div class="tool-col">
              <span class="tool-label">Focus</span>
              <p class="tool-value">{p.focus}</p>
            </div>
            <div class="tool-col">
              <span class="tool-label">Strength</span>
              <p class="tool-value">{p.strength}</p>
            </div>
            <div class="tool-col link">
              {p.link ? (
                <a href={p.link} class="link-arrow">
                  Detailed comparison
                  <span class="arrow" aria-hidden="true">→</span>
                </a>
              ) : (
                <span class="tool-muted">Storefront only</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature comparison -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Platforms vs Kaldon</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Feature by feature
        </h2>
      </header>
      <div class="comparison-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="sticky-col">Capability</th>
              <th>Platforms</th>
              <th class="highlight">Kaldon</th>
            </tr>
          </thead>
          <tbody>
            {features.map((f) => (
              <tr>
                <td class="sticky-col">{f.name}</td>
                <td set:html={renderCell(f.platforms)} />
                <td class="highlight" set:html={renderCell(f.kaldon)} />
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10">
        <span class="kicker">FAQ</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Frequently asked questions
        </h2>
      </header>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="faq-item" name="ecommerce-faq">
            <summary class="faq-summary">
              <span class="faq-q">{faq.q}</span>
              <svg class="faq-chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="faq-answer"><p>{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        Your platform is the storefront. Kaldon is the business.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Start free. 2 analyses. No credit card required.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href="https://kaldon.io/signup" data-event="compare_platforms_cta">
          Start Free, 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  })} />
</BaseLayout>

<style>
  .tool-row { display: grid; grid-template-columns: 1fr; gap: 12px; padding: 20px; background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; transition: border-color 160ms var(--ease-out-quad); }
  .tool-row:hover { border-color: var(--hairline-active); }
  @media (min-width: 768px) { .tool-row { grid-template-columns: 1.2fr 1.2fr 1.2fr 1fr; align-items: center; gap: 20px; } .tool-col.link { text-align: right; } }
  .tool-name { font-family: var(--font-display); font-weight: 600; font-size: 16px; color: var(--chalk); letter-spacing: -0.01em; }
  .tool-price { margin-top: 2px; font-family: var(--font-mono); font-size: 12px; color: var(--ghost); }
  .tool-label { display: block; font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500; margin-bottom: 4px; }
  .tool-value { font-size: 13.5px; color: var(--text-secondary); line-height: 1.45; }
  .tool-muted { font-family: var(--font-mono); font-size: 12px; color: var(--ghost); }

  .comparison-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--hairline); background: var(--deep-space); }
  .comparison-table { width: 100%; min-width: 560px; border-collapse: separate; border-spacing: 0; font-size: 14px; }
  .comparison-table thead th { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500; text-align: center; padding: 18px 12px; background: rgba(255, 255, 255, 0.02); border-bottom: 1px solid var(--hairline); }
  .comparison-table thead th.sticky-col { text-align: left; padding-left: 20px; }
  .comparison-table thead th.highlight { color: var(--gold); }
  .comparison-table td { padding: 14px 12px; text-align: center; color: var(--text-secondary); border-bottom: 1px solid var(--hairline); }
  .comparison-table td.sticky-col { text-align: left; color: var(--chalk); padding-left: 20px; }
  .comparison-table td.highlight { background: rgba(255, 184, 0, 0.03); }
  .comparison-table tr:last-child td { border-bottom: none; }

  .faq-item { background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; overflow: hidden; transition: border-color 160ms var(--ease-out-quad); }
  .faq-item:hover, .faq-item[open] { border-color: var(--hairline-active); }
  .faq-summary { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; cursor: pointer; list-style: none; }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-q { font-family: var(--font-display); font-weight: 500; font-size: 16px; color: var(--chalk); letter-spacing: -0.01em; }
  .faq-chevron { color: var(--ghost); transition: transform 200ms var(--ease-out-quad); flex-shrink: 0; margin-left: 16px; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.6; color: var(--ghost); }
</style>
