---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import Button from '../../components/ui/Button.astro';
import { appUrl } from '../../lib/urls';

// Prices reflect the PREMIUM / equivalent-capability tier. not the
// starter entry fee. Kaldon is a premium platform; comparing to entry
// tiers understates the true cost of matching Kaldon's coverage.
const tools = [
  { name: 'Helium 10 (Diamond)', price: '$279 / mo', focus: 'Amazon + Walmart + TikTok Shop', strength: 'Cerebro / Magnet keyword research', link: '/vs/helium-10' },
  { name: 'Jungle Scout (Professional)', price: '$349 / mo', focus: 'Amazon', strength: 'Product Tracker, Supplier Database', link: '/vs/jungle-scout' },
  { name: 'SmartScout (Business)', price: '$187 / mo', focus: 'Amazon', strength: 'Brand and subcategory analytics', link: null },
  { name: 'Viral Launch (Pro Plus)', price: '$199 / mo', focus: 'Amazon', strength: 'Market Intelligence, launch tools', link: null },
  { name: 'AMZScout (Business)', price: '$49 / mo', focus: 'Amazon', strength: 'Chrome extension, beginner-friendly', link: null },
];

const features = [
  { name: 'Product Research', tools: 'yes', kaldon: 'yes' },
  { name: 'Keyword Research', tools: 'yes', kaldon: 'yes' },
  { name: 'Competitor Analysis', tools: 'yes', kaldon: 'yes' },
  { name: 'Sales Estimation', tools: 'yes', kaldon: 'yes' },
  { name: 'Supplier Database', tools: 'Jungle Scout only', kaldon: 'no' },
  { name: 'Chrome Extension', tools: 'Most', kaldon: 'no' },
  { name: 'AI Viability Scoring', tools: 'no', kaldon: 'yes' },
  { name: 'AI Product Mockups', tools: 'no', kaldon: 'yes' },
  { name: 'Step-by-Step Action Plans', tools: 'no', kaldon: 'yes' },
  { name: 'AI Coaching', tools: 'no', kaldon: 'yes' },
  { name: 'Brand Identity Generation', tools: 'no', kaldon: 'yes' },
  { name: 'Logo Generation', tools: 'no', kaldon: 'yes' },
  { name: 'Content Calendar', tools: 'no', kaldon: 'yes' },
  { name: 'Social Media Content', tools: 'no', kaldon: 'yes' },
  { name: 'Video Studio', tools: 'no', kaldon: 'yes' },
  { name: 'Landing Page Builder', tools: 'no', kaldon: 'yes' },
  { name: 'Store Deployment', tools: 'no', kaldon: 'yes' },
  { name: 'Blog Engine (auto-publish)', tools: 'no', kaldon: 'yes' },
  { name: 'Ad Campaign Management', tools: 'no', kaldon: 'yes' },
  { name: 'Multi-Channel (Amazon + Walmart + DTC)', tools: 'Limited', kaldon: 'yes' },
  { name: 'Connected Research-to-Revenue Pipeline', tools: 'no', kaldon: 'yes' },
];

const faqs = [
  { q: 'Can Kaldon replace my existing research tool?', a: 'For most sellers, yes. Kaldon includes product research, market intelligence, competitor analysis, and sales estimation. The main exceptions are granular daily keyword rank tracking (Helium 10) and supplier databases (Jungle Scout). If those are critical to your workflow, you may want to keep your existing tool alongside Kaldon.' },
  { q: 'How is Kaldon different from traditional research tools?', a: 'Traditional research tools stop at data. They show you numbers, charts, and keyword volumes. Kaldon starts with research and continues through brand creation, content generation, store deployment, and ad management. It is a complete business launch platform, not just a research dashboard.' },
  { q: 'Do I need to pay for a research tool AND Kaldon?', a: 'Most sellers find Kaldon covers their research needs entirely. Many sellers start using both, then consolidate into Kaldon once they see the full pipeline in action.' },
  { q: 'What research capabilities does Kaldon include?', a: 'Kaldon runs 10 parallel data sources synthesized by Claude: product research, market intelligence, competitor analysis, sales estimation, AI-powered viability scoring, product mockup generation, and step-by-step action plans. The key difference is that these insights feed directly into brand building and content creation.' },
  { q: 'Are research tools enough to launch a successful eCommerce business?', a: 'Research is the first step, not the last. After finding a product, you need a brand identity, content strategy, online store, marketing materials, and ad campaigns. Traditional research tools require you to purchase 5–8 additional tools and services to cover these steps. Kaldon includes them all.' },
  { q: 'How much do sellers typically spend on the full tool stack?', a: 'A typical Amazon seller spends $50–150 / mo on research tools, $39–105 / mo on Shopify, $50–100 / mo on email marketing, $30–100 / mo on SEO and content tools, and $50–200 / mo on design tools. That is $219–655 / mo in subscriptions before any freelancer costs. Kaldon replaces most of this stack at $149 / mo.' },
];

function renderCell(val: string): string {
  if (val === 'yes') {
    return '<svg class="w-4 h-4 mx-auto" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 L8 14.5 L16 6" stroke="#F5F5F7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>';
  }
  if (val === 'no') {
    return '<span style="color: var(--text-quaternary); font-size: 16px;" aria-hidden="true">. </span><span class="sr-only">Not included</span>';
  }
  return `<span style="font-family: var(--font-mono); font-size: 12px; color: var(--gold);">${val}</span>`;
}

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'Kaldon vs Traditional Research Tools: From Research to Revenue (2026)',
    description:
      'Research tools stop at data. Kaldon takes you from research to revenue. Compare Kaldon against Helium 10, Jungle Scout, SmartScout, Viral Launch, and AMZScout.',
    about: {
      '@type': 'Thing',
      name: 'eCommerce Product Research Tools',
      description:
        'Software platforms used by online sellers to discover, validate, and analyze potential products to sell on Amazon, Walmart, and other marketplaces.',
    },
    author: {
      '@type': 'Organization',
      '@id': 'https://kaldon.io/#org',
      name: 'Kaldon',
      url: 'https://kaldon.io',
    },
    publisher: {
      '@type': 'Organization',
      '@id': 'https://kaldon.io/#org',
      name: 'Kaldon',
      url: 'https://kaldon.io',
      logo: { '@type': 'ImageObject', url: 'https://kaldon.io/images/logos/kaldon-logo-dark.svg' },
    },
    datePublished: '2026-03-18',
    dateModified: '2026-03-18',
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': 'https://kaldon.io/compare/research-tools',
    },
    image: 'https://kaldon.io/images/og/compare-research-tools.png',
  },
];
---

<BaseLayout
  title="Kaldon vs Traditional Research Tools: From Research to Revenue (2026)"
  description="Research tools stop at data. Kaldon takes you from research to revenue. Compare Kaldon against Helium 10, Jungle Scout, SmartScout, Viral Launch, and AMZScout."
  structuredData={structuredData}
>
  <PageHero
    kicker="Category Comparison"
    headline="Kaldon vs traditional research tools"
    subhead="Research tools help you find products that already exist. Kaldon helps you build the ones that don't."
    stats={[
      { label: 'Research tools cover', numeral: 1, sub: 'Step: what to sell', accent: 'chalk' },
      { label: 'Kaldon covers', numeral: 5, sub: 'Phases: Discover → Grow', accent: 'gold' },
      { label: 'Marketplaces', numeral: 'All', sub: 'Amazon, Walmart, TikTok, Etsy, Pinterest, WooCommerce, DTC, and more', accent: 'signal' },
    ]}
  />

  <!-- Gap callout -->
  <section class="pb-12 md:pb-16" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <div class="rounded-card p-8" style="background: var(--deep-space); border: 1px solid var(--hairline); border-left: 2px solid var(--signal);">
        <span class="kicker" style="color: var(--signal); margin-bottom: 10px;">Different Tool, Different Job</span>
        <p class="text-body-lg" style="color: var(--chalk); line-height: 1.55; letter-spacing: -0.005em;">
          Research tools answer one question: "What's already selling that I could resell?" That's a cloning game. Kaldon answers a different question: "What is the market demanding that nobody's making yet, and how do I build it?" Market intelligence, supplier verification, brand, content, storefront, and growth, all in one creation pipeline.
        </p>
      </div>
    </div>
  </section>

  <!-- Tool landscape -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="text-center mb-10">
        <span class="kicker">Landscape</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          The research tool landscape
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">
          Prices shown are <span style="color: var(--chalk); font-weight: 500;">premium-tier equivalents</span>, the plans that match Kaldon's coverage. Entry-level tiers cost less but cover far fewer signals, marketplaces, and capabilities.
        </p>
      </header>
      <div class="grid gap-3">
        {tools.map((tool) => (
          <div class="tool-row">
            <div class="tool-col name">
              <h3 class="tool-name">{tool.name}</h3>
              <p class="tool-price">{tool.price}</p>
            </div>
            <div class="tool-col">
              <span class="tool-label">Focus</span>
              <p class="tool-value">{tool.focus}</p>
            </div>
            <div class="tool-col">
              <span class="tool-label">Strength</span>
              <p class="tool-value">{tool.strength}</p>
            </div>
            <div class="tool-col link">
              {tool.link ? (
                <a href={tool.link} class="link-arrow">
                  Detailed comparison
                  <span class="arrow" aria-hidden="true">→</span>
                </a>
              ) : (
                <span class="tool-muted">Research-only tool</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature comparison -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">Research Tools vs Kaldon</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Feature by feature
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">
          Research tools cover the first column. Kaldon covers both.
        </p>
      </header>
      <div class="comparison-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="sticky-col">Capability</th>
              <th>Research Tools</th>
              <th class="highlight">Kaldon</th>
            </tr>
          </thead>
          <tbody>
            {features.map((f) => (
              <tr>
                <td class="sticky-col">{f.name}</td>
                <td set:html={renderCell(f.tools)} />
                <td class="highlight" set:html={renderCell(f.kaldon)} />
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pipeline difference -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">The Pipeline Difference</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Research tools give you data. Kaldon gives you a business.
        </h2>
      </header>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="pipeline-card">
          <p class="pipeline-label">With research tools</p>
          <ol class="pipeline-steps">
            <li><span class="step-num">01</span> Find a product <span class="step-status">done</span></li>
            <li><span class="step-num">02</span> Find a brand designer <span class="step-status muted">→ you</span></li>
            <li><span class="step-num">03</span> Find a content writer <span class="step-status muted">→ you</span></li>
            <li><span class="step-num">04</span> Sign up for Shopify <span class="step-status muted">→ you</span></li>
            <li><span class="step-num">05</span> Buy email / SEO / ad tools <span class="step-status muted">→ you</span></li>
          </ol>
          <p class="pipeline-footer">5+ additional tools · $200–500 / mo extra · weeks of setup</p>
        </div>
        <div class="pipeline-card pipeline-kaldon">
          <p class="pipeline-label" style="color: var(--gold);">With Kaldon</p>
          <ol class="pipeline-steps">
            <li><span class="step-num" style="color: var(--gold);">01</span> Discover · find and validate your product</li>
            <li><span class="step-num" style="color: var(--gold);">02</span> Build · generate your brand identity</li>
            <li><span class="step-num" style="color: var(--gold);">03</span> Create · produce content and marketing</li>
            <li><span class="step-num" style="color: var(--gold);">04</span> Launch · deploy store and listings</li>
            <li><span class="step-num" style="color: var(--gold);">05</span> Grow · run ads and optimize</li>
          </ol>
          <p class="pipeline-footer" style="color: var(--gold);">One platform · one subscription · connected data throughout</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Head-to-head links -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl text-center">
      <header class="mb-8">
        <span class="kicker">Head-to-Head</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Detailed comparisons
        </h2>
      </header>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/vs/helium-10" class="h2h-card">
          <h3 class="h2h-title">Kaldon vs Helium 10</h3>
          <p class="h2h-body">Deep keyword tools vs full pipeline</p>
          <span class="link-arrow mt-4"><span>See comparison</span><span class="arrow" aria-hidden="true">→</span></span>
        </a>
        <a href="/vs/jungle-scout" class="h2h-card">
          <h3 class="h2h-title">Kaldon vs Jungle Scout</h3>
          <p class="h2h-body">Product finder vs business builder</p>
          <span class="link-arrow mt-4"><span>See comparison</span><span class="arrow" aria-hidden="true">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10">
        <span class="kicker">FAQ</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Frequently asked questions
        </h2>
      </header>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="faq-item" name="research-tools-faq">
            <summary class="faq-summary">
              <span class="faq-q">{faq.q}</span>
              <svg class="faq-chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="faq-answer"><p>{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        Stop researching. Start launching.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Start free. 2 analyses. No credit card required.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href={appUrl('/signup', 'compare_research_tools')} data-event="compare_research_cta">
          Start Free, 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
</BaseLayout>

<style>
  /* Tool landscape rows */
  .tool-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    padding: 20px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .tool-row:hover { border-color: var(--hairline-active); }
  @media (min-width: 768px) {
    .tool-row {
      grid-template-columns: 1.2fr 1.2fr 1.2fr 1fr;
      align-items: center;
      gap: 20px;
    }
    .tool-col.link { text-align: right; }
  }
  .tool-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }
  .tool-price {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ghost);
  }
  .tool-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
    margin-bottom: 4px;
  }
  .tool-value {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.45;
  }
  .tool-muted {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ghost);
  }

  /* Comparison table */
  .comparison-wrap {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--hairline);
    background: var(--deep-space);
  }
  .comparison-table { width: 100%; min-width: 560px; border-collapse: separate; border-spacing: 0; font-size: 14px; }
  .comparison-table thead th { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500; text-align: center; padding: 18px 12px; background: rgba(255, 255, 255, 0.02); border-bottom: 1px solid var(--hairline); }
  .comparison-table thead th.sticky-col { text-align: left; padding-left: 20px; }
  .comparison-table thead th.highlight { color: var(--gold); }
  .comparison-table td { padding: 14px 12px; text-align: center; color: var(--text-secondary); border-bottom: 1px solid var(--hairline); }
  .comparison-table td.sticky-col { text-align: left; color: var(--chalk); padding-left: 20px; }
  .comparison-table td.highlight { background: rgba(255, 184, 0, 0.03); }
  .comparison-table tr:last-child td { border-bottom: none; }

  /* Pipeline cards */
  .pipeline-card {
    padding: 28px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
  }
  .pipeline-kaldon {
    border-color: transparent;
    position: relative;
  }
  .pipeline-kaldon::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(to bottom right, rgba(255, 184, 0, 0.5), rgba(0, 212, 255, 0.2) 60%, rgba(255, 255, 255, 0.05));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  .pipeline-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
    margin-bottom: 18px;
  }
  .pipeline-steps {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pipeline-steps li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--chalk);
    line-height: 1.4;
    letter-spacing: -0.005em;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ghost);
    flex-shrink: 0;
    min-width: 20px;
  }
  .step-status {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ghost);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .step-status.muted { color: var(--text-quaternary); }
  .pipeline-footer {
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ghost);
  }

  /* Head-to-head cards */
  .h2h-card {
    display: block;
    padding: 24px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    text-align: left;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .h2h-card:hover { border-color: var(--hairline-active); }
  .h2h-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }
  .h2h-body {
    margin-top: 6px;
    font-size: 14px;
    color: var(--ghost);
    line-height: 1.5;
  }

  /* FAQ (shared pattern) */
  .faq-item { background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; overflow: hidden; transition: border-color 160ms var(--ease-out-quad); }
  .faq-item:hover, .faq-item[open] { border-color: var(--hairline-active); }
  .faq-summary { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; cursor: pointer; list-style: none; }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-q { font-family: var(--font-display); font-weight: 500; font-size: 16px; color: var(--chalk); letter-spacing: -0.01em; }
  .faq-chevron { color: var(--ghost); transition: transform 200ms var(--ease-out-quad); flex-shrink: 0; margin-left: 16px; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.6; color: var(--ghost); }
</style>
