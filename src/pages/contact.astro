---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Kaldon — Get in Touch"
  description="Questions about Kaldon? Need help with your account? Want to partner with us? Get in touch."
>

  <!-- Hero -->
  <section class="pt-32 pb-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#22d3ee]/5 via-[#0a0e17] to-[#0a0e17]"></div>
    <div class="container-custom relative z-10 text-center">
      <span class="eyebrow">CONTACT</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#e2e8f0] mb-4">Get in Touch</h1>
      <p class="text-lg text-[#94a3b8] max-w-2xl mx-auto">Questions, feedback, partnership inquiries, or just want to say hello. We read every message.</p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="section-spacing">
    <div class="container-custom max-w-5xl">
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Contact Form -->
        <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-2xl p-8">
          <h2 class="text-xl font-bold text-[#e2e8f0] mb-6">Send Us a Message</h2>
          <form id="contact-form" class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-[#94a3b8] mb-1.5">Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 bg-[#0a0e17] border border-[rgba(255,255,255,0.08)] rounded-lg text-[#e2e8f0] text-sm focus:border-[#22d3ee] focus:outline-none focus:ring-1 focus:ring-[#22d3ee] transition-colors" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-[#94a3b8] mb-1.5">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 bg-[#0a0e17] border border-[rgba(255,255,255,0.08)] rounded-lg text-[#e2e8f0] text-sm focus:border-[#22d3ee] focus:outline-none focus:ring-1 focus:ring-[#22d3ee] transition-colors" placeholder="you@example.com" />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-[#94a3b8] mb-1.5">Subject</label>
              <select id="subject" name="subject" class="w-full px-4 py-2.5 bg-[#0a0e17] border border-[rgba(255,255,255,0.08)] rounded-lg text-[#e2e8f0] text-sm focus:border-[#22d3ee] focus:outline-none focus:ring-1 focus:ring-[#22d3ee] transition-colors">
                <option value="general">General Inquiry</option>
                <option value="support">Technical Support</option>
                <option value="billing">Billing Question</option>
                <option value="partnership">Partnership Opportunity</option>
                <option value="press">Press / Media</option>
                <option value="feedback">Product Feedback</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-[#94a3b8] mb-1.5">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2.5 bg-[#0a0e17] border border-[rgba(255,255,255,0.08)] rounded-lg text-[#e2e8f0] text-sm focus:border-[#22d3ee] focus:outline-none focus:ring-1 focus:ring-[#22d3ee] transition-colors resize-none" placeholder="How can we help?"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full flex items-center justify-center gap-2">
              Send Message
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </button>
          </form>
          <div id="form-success" class="hidden mt-4 p-4 bg-[#34d399]/10 border border-[#34d399]/20 rounded-lg">
            <p class="text-sm text-[#34d399] font-medium">Message sent! We will get back to you within 24 hours.</p>
          </div>
        </div>

        <!-- Contact Info -->
        <div class="space-y-6">
          <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-2xl p-8">
            <h2 class="text-xl font-bold text-[#e2e8f0] mb-6">Other Ways to Reach Us</h2>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-[#22d3ee]/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-[#22d3ee]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-[#e2e8f0]">Email</h3>
                  <a href="mailto:support@kaldon.io" class="text-sm text-[#22d3ee] hover:underline">support@kaldon.io</a>
                  <p class="text-xs text-[#64748b] mt-0.5">We respond within 24 hours</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-[#a78bfa]/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-[#a78bfa]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-[#e2e8f0]">In-App Chat</h3>
                  <p class="text-sm text-[#94a3b8]">Available inside the Kaldon dashboard</p>
                  <p class="text-xs text-[#64748b] mt-0.5">Fastest response for account questions</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-[#fb923c]/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-[#fb923c]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-[#e2e8f0]">Community</h3>
                  <p class="text-sm text-[#94a3b8]">Join our Discord community</p>
                  <p class="text-xs text-[#64748b] mt-0.5">Connect with other sellers and the Kaldon team</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-[#1a2236] border border-[rgba(255,255,255,0.08)] rounded-2xl p-8" style="border-left: 4px solid #22d3ee">
            <h3 class="text-lg font-bold text-[#e2e8f0] mb-2">Enterprise & Agency Inquiries</h3>
            <p class="text-sm text-[#94a3b8] mb-4">Running an agency or managing multiple brands? We offer custom plans with dedicated support, priority AI processing, and volume pricing.</p>
            <a href="mailto:partnerships@kaldon.io" class="text-sm text-[#22d3ee] hover:underline font-medium">partnerships@kaldon.io</a>
          </div>

          <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-2xl p-8">
            <h3 class="text-lg font-bold text-[#e2e8f0] mb-2">Press & Media</h3>
            <p class="text-sm text-[#94a3b8] mb-4">For press inquiries, interviews, or media assets, contact our communications team.</p>
            <a href="mailto:press@kaldon.io" class="text-sm text-[#22d3ee] hover:underline font-medium">press@kaldon.io</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.getElementById('contact-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      // In production, this would POST to an API endpoint
      this.style.display = 'none';
      document.getElementById('form-success')?.classList.remove('hidden');
    });
  </script>
</BaseLayout>
