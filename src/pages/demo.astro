---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import Button from '../components/ui/Button.astro';
import { appUrl } from '../lib/urls';

const arcadeDemos = [
  { id: 'arcade-demo-1', title: 'Discover a winning product', desc: 'Click through a real product analysis. See the AI scoring, product mockups, action plan, and coaching flow.', screenshot: '/images/screenshots/01-analysis-hero.webp' },
  { id: 'arcade-demo-2', title: 'Build your brand in minutes', desc: 'Watch how Kaldon generates a complete brand identity from analysis data. Logo, colors, voice, everything.', screenshot: '/images/screenshots/07-brand-detail.webp' },
  { id: 'arcade-demo-3', title: 'The full pipeline', desc: 'Experience the complete journey from product idea to live store. Five phases, one platform, zero gaps.', screenshot: '/images/screenshots/15-journey-progress.webp' },
];

const loomVideos = [
  { id: 'loom-video-1', title: 'The full pipeline in 90 seconds', screenshot: '/images/screenshots/15-journey-progress.webp' },
  { id: 'loom-video-2', title: 'Inside an AI analysis report', screenshot: '/images/screenshots/01-analysis-hero.webp' },
  { id: 'loom-video-3', title: 'Building a brand from scratch', screenshot: '/images/screenshots/06-brand-vault.webp' },
  { id: 'loom-video-4', title: 'A month of content in minutes', screenshot: '/images/screenshots/10-content-calendar.webp' },
  { id: 'loom-video-5', title: 'Deploying your store', screenshot: '/images/screenshots/14-store-deployment.webp' },
];
---

<BaseLayout
  title="See Kaldon in Action. Interactive Demos and Video Walkthroughs"
  description="Click through real product analyses, brand creation, and the full pipeline. Watch video walkthroughs of every feature. No signup required."
>
  <PageHero
    kicker="Demo"
    headline="Watch Kaldon create a new product, end to end."
    subhead="Click through a real unmet-demand analysis, the brand identity it generates, the content calendar it produces, and the store it deploys. Five phases, one pipeline. No signup required."
  />

  <!-- Interactive demos -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="text-center mb-10">
        <span class="kicker">Interactive demos</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Click through the real product.
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">No signup needed.</p>
      </header>

      <div class="flex flex-wrap justify-center gap-2 mb-10">
        {arcadeDemos.map((demo, i) => (
          <button
            class={`demo-tab ${i === 0 ? 'active' : ''}`}
            data-tab={i}
          >
            {demo.title}
          </button>
        ))}
      </div>

      {arcadeDemos.map((demo, i) => (
        <div id={demo.id} class={`demo-panel ${i > 0 ? 'hidden' : ''}`} data-panel={i}>
          <button class="demo-frame">
            <img src={demo.screenshot} alt={demo.title} width="1124" height="712" class="demo-img" loading="lazy" decoding="async" />
            <div class="demo-overlay">
              <span class="kicker" style="color: var(--gold);">Interactive Demo</span>
              <p class="demo-title">{demo.title}</p>
              <p class="demo-desc">{demo.desc}</p>
              <div class="demo-play">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--chalk);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
          </button>
        </div>
      ))}
    </div>
  </section>

  <!-- Video walkthroughs -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="text-center mb-10">
        <span class="kicker">Video walkthroughs</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Watch every feature in detail.
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">5 focused walkthroughs. See exactly what Kaldon does.</p>
      </header>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {loomVideos.map((video) => (
          <button id={video.id} class="video-card">
            <div class="video-thumb">
              <img src={video.screenshot} alt={video.title} width="1124" height="712" loading="lazy" decoding="async" />
              <div class="video-play">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--chalk); margin-left: 2px;">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
            </div>
            <h3 class="video-title">{video.title}</h3>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        Ready to try it yourself?
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Your first 2 analyses are free. No credit card required.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href={appUrl('/signup', 'demo_final_cta')} data-event="demo_final_cta">
          Start Free
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.demo-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        const idx = this.dataset.tab;
        document.querySelectorAll('.demo-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        document.querySelectorAll('.demo-panel').forEach(p => p.classList.add('hidden'));
        document.querySelector(`[data-panel="${idx}"]`)?.classList.remove('hidden');
      });
    });
  </script>
</BaseLayout>

<style>
  .demo-tab {
    display: inline-flex; align-items: center; height: 34px; padding: 0 14px; border-radius: 999px;
    background: var(--deep-space); border: 1px solid var(--hairline); color: var(--ghost);
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; cursor: pointer;
    transition: border-color 160ms var(--ease-out-quad), color 160ms var(--ease-out-quad), background 160ms var(--ease-out-quad);
  }
  .demo-tab:hover { color: var(--chalk); border-color: var(--hairline-active); }
  .demo-tab.active { background: var(--gold); color: var(--void); border-color: transparent; font-weight: 500; }

  .demo-frame {
    position: relative; display: block; width: 100%; aspect-ratio: 16 / 10;
    background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px;
    overflow: hidden; cursor: pointer; transition: border-color 160ms var(--ease-out-quad);
  }
  .demo-frame:hover { border-color: var(--hairline-active); }
  .demo-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: top; opacity: 0.35;
    transition: opacity 200ms var(--ease-out-quad);
  }
  .demo-frame:hover .demo-img { opacity: 0.5; }
  .demo-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; padding: 32px; gap: 12px;
    background: linear-gradient(to bottom, rgba(10,10,15,0.3), rgba(10,10,15,0.8));
  }
  .demo-title { font-family: var(--font-display); font-weight: 600; font-size: 20px; color: var(--chalk); letter-spacing: -0.015em; }
  .demo-desc { text-align: center; max-width: 420px; font-size: 14px; line-height: 1.5; color: var(--ghost); }
  .demo-play { width: 52px; height: 52px; border-radius: 50%; background: var(--void); border: 1px solid var(--hairline-active); display: flex; align-items: center; justify-content: center; margin-top: 8px; }

  .video-card {
    display: block; text-align: left; background: transparent; border: none; padding: 0; cursor: pointer;
  }
  .video-thumb {
    position: relative; aspect-ratio: 16 / 9;
    background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px;
    overflow: hidden; margin-bottom: 12px;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .video-card:hover .video-thumb { border-color: var(--hairline-active); }
  .video-thumb img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: top; opacity: 0.25; }
  .video-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .video-play svg { background: var(--void); border: 1px solid var(--hairline-active); border-radius: 50%; padding: 12px; box-sizing: content-box; }
  .video-title { font-family: var(--font-display); font-weight: 600; font-size: 14px; color: var(--chalk); letter-spacing: -0.01em; transition: color 160ms var(--ease-out-quad); }
  .video-card:hover .video-title { color: var(--gold); }
</style>
