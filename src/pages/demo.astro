---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import Button from '../components/ui/Button.astro';
import { appUrl } from '../lib/urls';

const arcadeDemos = [
  {
    id: 'arcade-demo-1',
    title: 'Discover a winning product',
    annotation: 'What you see: opportunity score (8.7), source confidence breakdown, action plan, and supplier verification status.',
    screenshot: '/images/screenshots/01-analysis-hero.webp',
  },
  {
    id: 'arcade-demo-2',
    title: 'Build your brand in minutes',
    annotation: 'What you see: brand name, logo concept, color palette, voice guidelines, and the analysis data that shaped them.',
    screenshot: '/images/screenshots/07-brand-detail.webp',
  },
  {
    id: 'arcade-demo-3',
    title: 'The full pipeline',
    annotation: 'What you see: progress across all five phases, current step, completion percentage, and next-action prompts.',
    screenshot: '/images/screenshots/15-journey-progress.webp',
  },
];

const featureScreens = [
  {
    id: 'feature-screen-1',
    title: 'Inside an analysis report',
    caption: 'Opportunity score, demand signals, competitor density, and the action plan Kaldon ships with every report.',
    screenshot: '/images/screenshots/01-analysis-hero.webp',
  },
  {
    id: 'feature-screen-2',
    title: 'Brand vault overview',
    caption: 'Every brand Kaldon has built for you in one place. Status, last update, and one-click access to assets.',
    screenshot: '/images/screenshots/06-brand-vault.webp',
  },
  {
    id: 'feature-screen-3',
    title: 'Brand identity detail',
    caption: 'Logo, palette, typography, voice rules, and the analysis data that shaped the identity.',
    screenshot: '/images/screenshots/07-brand-detail.webp',
  },
  {
    id: 'feature-screen-4',
    title: 'A month of content, planned',
    caption: 'Calendar view of the content Kaldon produces. Channel, format, hook, and post-ready copy per slot.',
    screenshot: '/images/screenshots/10-content-calendar.webp',
  },
  {
    id: 'feature-screen-5',
    title: 'Live store deployment',
    caption: 'Storefront preview, deployment checklist, domain status, and the products already loaded for launch.',
    screenshot: '/images/screenshots/14-store-deployment.webp',
  },
  {
    id: 'feature-screen-6',
    title: 'Full pipeline progress',
    caption: 'Phase-by-phase progress across Discover, Build, Create, Launch, and Grow with current step highlighted.',
    screenshot: '/images/screenshots/15-journey-progress.webp',
  },
];
---

<BaseLayout
  title="See Kaldon in Action. Real Screenshots from Every Phase"
  description="Annotated screenshots from a real Discover analysis, the brand identity Kaldon generated, the content calendar it produced, and the live store it deployed. Live walkthroughs coming soon."
>
  <PageHero
    kicker="Real Screenshots"
    headline="See exactly what Kaldon produces."
    subhead="Annotated screenshots from a real Discover analysis, the brand identity Kaldon generated from it, the content calendar it produced, and the live store it deployed. Five phases, one pipeline. Live walkthroughs coming soon."
  />

  <!-- Coming soon notice -->
  <section style="background: var(--void); padding-block: clamp(40px, 6vw, 64px);">
    <div class="container-custom max-w-3xl">
      <div class="coming-soon-card">
        <span class="kicker">Coming soon</span>
        <p class="coming-soon-copy">
          Live click-through demo and 90-second video walkthrough are in production. Expected later this quarter. Want to be notified the moment they go live?
        </p>
        <div class="mt-5">
          <Button variant="secondary" href={appUrl('/signup', 'demo_notify_cta')} data-event="demo_notify_cta">
            Get notified
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Annotated screenshots -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="text-center mb-10">
        <span class="kicker">Annotated screenshots</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Real outputs from each phase.
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">Live click-through demos and video walkthroughs are in production.</p>
      </header>

      <div class="flex flex-wrap justify-center gap-2 mb-10">
        {arcadeDemos.map((demo, i) => (
          <button
            class={`demo-tab ${i === 0 ? 'active' : ''}`}
            data-tab={i}
          >
            {demo.title}
          </button>
        ))}
      </div>

      {arcadeDemos.map((demo, i) => (
        <div id={demo.id} class={`demo-panel ${i > 0 ? 'hidden' : ''}`} data-panel={i}>
          <figure class="demo-frame">
            <img src={demo.screenshot} alt={demo.title} width="1124" height="712" class="demo-img" loading="lazy" decoding="async" />
            <figcaption class="demo-overlay">
              <span class="kicker">Annotation</span>
              <p class="demo-title">{demo.title}</p>
              <p class="demo-desc">{demo.annotation}</p>
            </figcaption>
          </figure>
        </div>
      ))}
    </div>
  </section>

  <!-- Feature deep-dives -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="text-center mb-10">
        <span class="kicker">Feature deep-dives</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Every feature, in detail.
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">Six annotated screens. See exactly what Kaldon ships.</p>
      </header>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featureScreens.map((screen) => (
          <figure id={screen.id} class="feature-card">
            <div class="feature-thumb">
              <img src={screen.screenshot} alt={screen.title} width="1124" height="712" loading="lazy" decoding="async" />
            </div>
            <figcaption>
              <h3 class="feature-title">{screen.title}</h3>
              <p class="feature-caption">{screen.caption}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        Ready to try it yourself?
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Your first 2 analyses are free. No credit card required.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href={appUrl('/signup', 'demo_final_cta')} data-event="demo_final_cta">
          Start Free
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.demo-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        const idx = this.dataset.tab;
        document.querySelectorAll('.demo-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        document.querySelectorAll('.demo-panel').forEach(p => p.classList.add('hidden'));
        document.querySelector(`[data-panel="${idx}"]`)?.classList.remove('hidden');
      });
    });
  </script>
</BaseLayout>

<style>
  .demo-tab {
    display: inline-flex; align-items: center; height: 34px; padding: 0 14px; border-radius: 999px;
    background: var(--deep-space); border: 1px solid var(--hairline); color: var(--ghost);
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; cursor: pointer;
    transition: border-color 160ms var(--ease-out-quad), color 160ms var(--ease-out-quad), background 160ms var(--ease-out-quad);
  }
  .demo-tab:hover { color: var(--chalk); border-color: var(--hairline-active); }
  .demo-tab.active { background: var(--gold); color: var(--void); border-color: transparent; font-weight: 500; }

  .demo-frame {
    position: relative; display: block; width: 100%; aspect-ratio: 16 / 10; margin: 0;
    background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px;
    overflow: hidden;
  }
  .demo-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: top; opacity: 0.45;
  }
  .demo-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; padding: 32px; gap: 12px;
    background: linear-gradient(to bottom, rgba(10,10,15,0.35), rgba(10,10,15,0.85));
    margin: 0;
  }
  .demo-title { font-family: var(--font-display); font-weight: 600; font-size: 20px; color: var(--chalk); letter-spacing: -0.015em; }
  .demo-desc { text-align: center; max-width: 480px; font-size: 14px; line-height: 1.5; color: var(--ghost); }

  .coming-soon-card {
    border: 1px solid var(--hairline); border-radius: 12px;
    background: var(--deep-space); padding: 28px 32px; text-align: center;
  }
  .coming-soon-copy {
    margin-top: 10px; font-size: 15px; line-height: 1.55; color: var(--ghost); max-width: 520px; margin-left: auto; margin-right: auto;
  }

  .feature-card {
    display: block; margin: 0;
  }
  .feature-thumb {
    position: relative; aspect-ratio: 16 / 10;
    background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px;
    overflow: hidden; margin-bottom: 14px;
  }
  .feature-thumb img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: top; opacity: 0.85; }
  .feature-title { font-family: var(--font-display); font-weight: 600; font-size: 15px; color: var(--chalk); letter-spacing: -0.01em; margin-bottom: 6px; }
  .feature-caption { font-size: 13px; line-height: 1.55; color: var(--ghost); }
</style>
