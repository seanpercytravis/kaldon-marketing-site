---
import BaseLayout from '../layouts/BaseLayout.astro';

const phases = [
  {
    num: 1,
    name: 'Discover',
    color: '#22d3ee',
    tagline: 'Know what to build before you invest a dollar.',
    features: [
      { title: 'AI Analysis Engine', desc: 'Score any product idea across 10 parallel data sources, synthesized by Claude, covering Amazon, Walmart, and DTC markets. A viability score and a recommendation, not a spreadsheet.' },
      { title: 'Market Intelligence', desc: 'Competitive landscape analysis, demand forecasting, and pricing insights drawn from real-time marketplace data.' },
      { title: 'AI Product Mockups', desc: 'Generate photorealistic product images from your idea before you source a single unit. Test concepts visually.' },
      { title: 'Action Plans', desc: 'Step-by-step roadmaps with timelines and milestones. Every analysis produces a prioritized plan, not just a report.' },
      { title: 'AI Coaching', desc: 'An AI coach that walks you through every decision in your analysis, answering questions and guiding your go/no-go call.' },
    ],
  },
  {
    num: 2,
    name: 'Build',
    color: '#3b82f6',
    tagline: 'Create a professional brand identity in minutes.',
    features: [
      { title: 'Brand Vault', desc: 'Store and manage every brand asset in one place — logo, palette, typography, voice guidelines — and have it flow automatically into every downstream step.' },
      { title: 'AI Logo Generation', desc: 'Generate multiple logo concepts from your analysis data. Pick your favorite and lock it into your brand identity.' },
      { title: 'Brand Board', desc: 'A shareable, professional brand presentation with your logo, palette, typography, and voice. Send it to partners and manufacturers.' },
    ],
  },
  {
    num: 3,
    name: 'Create',
    color: '#a78bfa',
    tagline: 'Generate a month of content without a content team.',
    features: [
      { title: 'Content Calendar', desc: 'A full month of social media posts across 5 platforms, all matching your brand voice. Schedule, preview, and publish from one view.' },
      { title: 'One-Off Composer', desc: 'Need a single post or announcement? Compose on-brand content for any platform in seconds.' },
      { title: 'Video Studio', desc: '10 AI-video recipes — product reveals, brand stories, testimonials, product demos, before/after, and more. No filming required.' },
      { title: 'Landing Page Builder', desc: 'Conversion-optimized landing pages that look like a design agency built them. Your brand identity is baked in automatically.' },
      { title: 'Multi-Platform Publishing', desc: 'Publish to Instagram, Facebook, LinkedIn, X, and Pinterest from a single dashboard. No switching between apps.' },
    ],
  },
  {
    num: 4,
    name: 'Launch',
    color: '#fb923c',
    tagline: 'Go live with a revenue-ready store in one click.',
    features: [
      { title: 'Store Deployment', desc: 'Deploy a complete DTC store with checkout, automated emails, SMS sequences, and chatbot. Configure your brand and subdomain, then ship.' },
      { title: 'Blog Engine', desc: 'Hands-free autopilot: AI writes GEO-optimized SEO articles in your brand voice and auto-publishes them on a weekly schedule. Structured data baked in.' },
      { title: 'GEO Optimization', desc: 'Generative Engine Optimization ensures your brand and products surface in AI-powered search results and recommendation engines.' },
    ],
  },
  {
    num: 5,
    name: 'Grow',
    color: '#34d399',
    tagline: 'Scale with ads that optimize themselves.',
    features: [
      { title: 'Ad Campaign Management', desc: 'Launch and manage Meta ad campaigns with AI optimization. Kaldon generates creatives, targets audiences, and adjusts bids automatically.' },
      { title: 'Customer Retention', desc: 'Identify churn risk, trigger win-back campaigns, and keep customers coming back with automated lifecycle marketing.' },
      { title: 'Performance Analytics', desc: 'Track ROAS, CAC, LTV, and every metric that matters in real-time. See exactly where your money goes and what it earns.' },
      { title: 'Social Account Connections', desc: 'Connect all your social and ad accounts in one place. Unified reporting across every channel you sell and market on.' },
    ],
  },
];
---

<BaseLayout
  title="Kaldon Features — The Complete eCommerce Intelligence Platform"
  description="Explore Kaldon's 5-phase pipeline: Discover winning products, Build professional brands, Create content, Launch stores, and Grow with AI-optimized ads. Everything connected. Zero gaps."
>

  <!-- Hero -->
  <section class="pt-32 pb-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#22d3ee]/5 via-[#0a0e17] to-[#0a0e17]"></div>
    <div class="container-custom relative z-10 text-center">
      <span class="eyebrow">FEATURES</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#e2e8f0] mb-4">Everything You Need.<br/><span class="gradient-text">Nothing You Don't.</span></h1>
      <p class="text-lg text-[#94a3b8] max-w-2xl mx-auto">Five phases. One connected pipeline. Every feature feeds the next so you never copy-paste between tools, re-enter data, or start from scratch.</p>
    </div>
  </section>

  <!-- Phase nav pills -->
  <section class="pb-12">
    <div class="container-custom">
      <div class="flex flex-wrap justify-center gap-3">
        {phases.map(phase => (
          <a href={`#phase-${phase.num}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold transition-all hover:scale-105" style={`background: ${phase.color}15; color: ${phase.color}; border: 1px solid ${phase.color}30`}>
            <span class="w-5 h-5 rounded-full text-xs flex items-center justify-center font-bold" style={`background: ${phase.color}30`}>{phase.num}</span>
            {phase.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Phase sections -->
  {phases.map((phase, i) => (
    <section id={`phase-${phase.num}`} class={`py-20 ${i % 2 === 0 ? 'bg-[#0a0e17]' : 'bg-[#111827]/30'}`}>
      <div class="container-custom max-w-6xl">
        <div class="animate-on-scroll text-center mb-12">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4" style={`background: ${phase.color}15; color: ${phase.color}; border: 1px solid ${phase.color}30`}>
            Phase {phase.num}
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-[#e2e8f0] mb-3">{phase.name}</h2>
          <p class="text-lg text-[#94a3b8] max-w-xl mx-auto">{phase.tagline}</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {phase.features.map((feat, fi) => (
            <div class="animate-on-scroll bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl p-6 hover:border-opacity-20 transition-all hover:translate-y-[-2px]" style={`animation-delay: ${fi * 100}ms; border-top: 3px solid ${phase.color}`}>
              <h3 class="text-lg font-bold text-[#e2e8f0] mb-2">{feat.title}</h3>
              <p class="text-sm text-[#94a3b8] leading-relaxed">{feat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Pipeline callout -->
  <section class="py-20 bg-[#0a0e17]">
    <div class="container-custom max-w-4xl text-center animate-on-scroll">
      <h2 class="text-2xl md:text-3xl font-extrabold text-[#e2e8f0] mb-4">The Pipeline Advantage</h2>
      <p class="text-[#94a3b8] text-lg leading-relaxed mb-8">Other platforms give you tools. Kaldon gives you a pipeline. Your analysis data flows into your brand. Your brand flows into your content. Your content populates your store. Your store data optimizes your ads. Every phase makes the next one smarter.</p>
      <div class="flex flex-wrap justify-center gap-3 text-sm">
        {phases.map((phase, i) => (
          <div class="flex items-center gap-2">
            <span class="font-bold" style={`color: ${phase.color}`}>{phase.name}</span>
            {i < phases.length - 1 && (
              <svg class="w-4 h-4 text-[#94a3b8]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-spacing relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#22d3ee]/10 via-[#0a0e17] to-[#a78bfa]/10"></div>
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#e2e8f0] mb-4">See It All in Action</h2>
      <p class="text-lg text-[#94a3b8] mb-8">Your first 2 analyses are free. No credit card required.</p>
      <a href="https://kaldon.io/signup" class="btn-primary btn-large btn-glow inline-flex items-center gap-2">Start Free <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></a>
    </div>
  </section>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  </script>
</BaseLayout>
