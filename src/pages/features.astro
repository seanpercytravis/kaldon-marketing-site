---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import Button from '../components/ui/Button.astro';
import ModeBadges from '../components/ui/ModeBadges.astro';
import DiscoverPane from '../components/visuals/phases/DiscoverPane.astro';
import BuildPane from '../components/visuals/phases/BuildPane.astro';
import CreatePane from '../components/visuals/phases/CreatePane.astro';
import LaunchPane from '../components/visuals/phases/LaunchPane.astro';
import GrowPane from '../components/visuals/phases/GrowPane.astro';
import CoachConsole from '../components/visuals/CoachConsole.astro';

const phases = [
  {
    num: '01',
    name: 'Discover',
    tagline: 'Find unmet demand the market is paying for.',
    features: [
      { title: 'Unmet-Demand Engine', desc: 'Ten parallel data sources synthesized by Claude: sales velocity, pricing gaps, search demand, social momentum, ad saturation, competitor coverage. Output: the gaps nobody is building for.' },
      { title: 'Market Intelligence', desc: 'Competitive landscape, demand forecasting, and pricing insights drawn from real-time marketplace data across Amazon, Walmart, and DTC.' },
      { title: 'AI Product Mockups', desc: 'Render photorealistic images of the new product before you source a single unit. Test the concept visually while you still can change it.' },
      { title: 'Supplier Verification', desc: 'Find manufacturers who can actually produce the product, not just generic factories. Verified capability before you commit capital.' },
      { title: 'Action Plans', desc: 'Step-by-step roadmaps with timelines and milestones. Every concept produces a prioritized plan from spec to first shipment.' },
      { title: 'AI Coaching', desc: 'An AI coach walks you through every decision: go/no-go calls, spec trade-offs, supplier choice, so you never guess.' },
    ],
  },
  {
    num: '02',
    name: 'Build',
    tagline: 'A professional brand identity, in minutes, not months.',
    features: [
      { title: 'Brand Vault', desc: 'Store and manage every brand asset in one place: logo, palette, typography, voice, and have it flow automatically into every downstream step.' },
      { title: 'AI Logo Generation', desc: 'Generate multiple logo concepts from your analysis data. Pick your favorite and lock it into your brand identity.' },
      { title: 'Brand Board', desc: 'A shareable, professional brand presentation with your logo, palette, typography, and voice. Send it to partners and manufacturers.' },
    ],
  },
  {
    num: '03',
    name: 'Create',
    tagline: 'Generate a month of content without a content team.',
    features: [
      { title: 'Content Calendar', desc: 'A full month of social media posts across 5 platforms, all matching your brand voice. Schedule, preview, and publish from one view.' },
      { title: 'One-Off Composer', desc: 'Need a single post or announcement? Compose on-brand content for any platform in seconds.' },
      { title: 'Video Studio', desc: '10 AI-video recipes: product reveals, brand stories, testimonials, product demos, before/after, and more. No filming required.' },
      { title: 'Landing Page Builder', desc: 'Conversion-optimized landing pages that look like a design agency built them. Your brand identity is baked in automatically.' },
      { title: 'Multi-Platform Publishing', desc: 'Publish to Instagram, Facebook, LinkedIn, X, and Pinterest from a single dashboard. No switching between apps.' },
    ],
  },
  {
    num: '04',
    name: 'Launch',
    tagline: 'Go live with a revenue-ready store.',
    features: [
      { title: 'Store Deployment', desc: 'Deploy a complete DTC store with checkout, automated emails, SMS sequences, and chatbot. Configure your brand and subdomain, then ship.' },
      { title: 'Blog Engine', desc: 'Hands-free autopilot: AI writes GEO-optimized SEO articles in your brand voice and auto-publishes them on a weekly schedule. Structured data baked in.' },
      { title: 'GEO Optimization', desc: 'Generative Engine Optimization ensures your brand and products surface in AI-powered search results and recommendation engines.' },
    ],
  },
  {
    num: '05',
    name: 'Grow',
    tagline: 'Scale with ads that optimize themselves.',
    features: [
      { title: 'Ad Campaign Management', desc: 'Launch and manage Meta ad campaigns with AI optimization. Kaldon generates creatives, targets audiences, and adjusts bids automatically.' },
      { title: 'Customer Retention', desc: 'Identify churn risk, trigger win-back campaigns, and keep customers coming back with automated lifecycle marketing.' },
      { title: 'Performance Analytics', desc: 'Track ROAS, CAC, LTV, and every metric that matters. See exactly where your money goes and what it earns.' },
      { title: 'Social Account Connections', desc: 'Connect all your social and ad accounts in one place. Unified reporting across every channel you sell and market on.' },
    ],
  },
];
---

<BaseLayout
  title="Kaldon Features. The Complete eCommerce Intelligence Platform"
  description="Five phases. One connected pipeline. Discover winning products, build professional brands, create content, launch stores, and grow with AI-optimized ads. Every feature feeds the next."
>
  <PageHero
    kicker="Features"
    headline="Everything you need to create new products from market demand."
    subhead="Five phases. One connected pipeline. Demand signals become validated concepts. Concepts become brands. Brands become content. Content populates stores. Stores scale ads. Every feature feeds the next, so you never copy-paste between tools or start from scratch."
    stats={[
      { label: 'Signal sources', numeral: 10, sub: 'Parallel, cross-referenced' },
      { label: 'Pipeline phases', numeral: 5, sub: 'Discover → Grow', accent: 'gold' },
      { label: 'Platform', numeral: 1, sub: 'One subscription, zero gaps', accent: 'signal' },
    ]}
  />

  <!-- Phase nav pills -->
  <section class="pb-8 md:pb-12" style="background: var(--void);">
    <div class="container-custom flex flex-wrap justify-center gap-2 md:gap-3">
      {phases.map((phase) => (
        <a
          href={`#phase-${phase.num}`}
          class="phase-pill"
        >
          <span class="phase-pill-num">{phase.num}</span>
          {phase.name}
        </a>
      ))}
    </div>
  </section>

  <!-- Three modes · One pipeline. unify messaging with homepage -->
  <ModeBadges headline="Three modes. Same five-phase pipeline." />

  <!-- Phase sections. each with its custom pane to the side -->
  {phases.map((phase, i) => (
    <section id={`phase-${phase.num}`} class="section-spacing" style="background: var(--void);">
      <div class="container-custom max-w-6xl">
        <header class="max-w-prose mx-auto text-center mb-10 md:mb-14">
          <div class="phase-kicker">
            <span class="phase-kicker-num">{phase.num}</span>
            <span class="phase-kicker-label">Phase {parseInt(phase.num)} · {phase.name}</span>
          </div>
          <h2 class="font-display font-semibold mt-4" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
            {phase.tagline}
          </h2>
        </header>

        <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
          <div class="grid sm:grid-cols-2 gap-4">
            {phase.features.map((feat) => (
              <div class="feat-card">
                <h3 class="feat-title">{feat.title}</h3>
                <p class="feat-desc">{feat.desc}</p>
              </div>
            ))}
          </div>
          <div class="feat-visual">
            {i === 0 && <DiscoverPane variant="inline" />}
            {i === 1 && <BuildPane variant="inline" />}
            {i === 2 && <CreatePane variant="inline" />}
            {i === 3 && <LaunchPane variant="inline" />}
            {i === 4 && <GrowPane variant="inline" />}
          </div>
        </div>
      </div>
      {i < phases.length - 1 && (
        <div class="container-custom max-w-6xl mt-16 md:mt-24">
          <div class="hairline-t" style="max-width: 120px; margin: 0 auto;"></div>
        </div>
      )}
    </section>
  ))}

  <!-- Supplier Verification spotlight. underplayed elsewhere, elevate here -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <div class="supplier-card">
        <div class="supplier-lede">
          <span class="kicker" style="color: var(--gold);">Verified Suppliers</span>
          <h2 class="font-display font-semibold mt-2" style="font-weight: 600; font-size: clamp(24px, 3vw, 32px); line-height: 1.2; letter-spacing: -0.015em; color: var(--chalk);">
            Every concept ships with a supplier who can actually make it.
          </h2>
          <p class="mt-4 text-body-lg" style="color: var(--ghost); line-height: 1.55;">
            Most tools surface products. Kaldon surfaces <span style="color: var(--chalk); font-weight: 500;">products plus the manufacturers with the capability to produce them</span>. MOQs, certifications, material specs, lead times, and verified production samples. No more shipping a validated concept only to discover no factory can make it to your spec.
          </p>
        </div>
        <div class="supplier-stats">
          <div class="supplier-stat">
            <span class="supplier-stat-num">MOQ-matched</span>
            <span class="supplier-stat-label">From 50 units to 50,000</span>
          </div>
          <div class="supplier-stat">
            <span class="supplier-stat-num">Certified</span>
            <span class="supplier-stat-label">ISO, FDA, BSCI as spec requires</span>
          </div>
          <div class="supplier-stat">
            <span class="supplier-stat-num">Sampled</span>
            <span class="supplier-stat-label">Production samples before commit</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Coach demonstration. show don't tell -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">AI Coach</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          An AI coach that actually walks you through decisions.
        </h2>
        <p class="mt-4 text-body-lg" style="color: var(--ghost);">
          Not a chatbot. A strategist that cites sources, shows math, and recommends action.
        </p>
      </header>
      <CoachConsole />
    </div>
  </section>

  <!-- Pipeline advantage callout -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-prose text-center">
      <span class="kicker">The Pipeline Advantage</span>
      <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
        Tools vs. a pipeline.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost); line-height: 1.5;">
        Other platforms give you tools. Kaldon gives you a pipeline. Your analysis data flows into your brand. Your brand flows into your content. Your content populates your store. Your store data optimizes your ads. Every phase makes the next one smarter.
      </p>
      <div class="mt-10 flex flex-wrap justify-center items-center gap-3 font-mono" style="font-size: 13px; letter-spacing: -0.01em;">
        {phases.map((phase, i) => (
          <Fragment>
            <span style="color: var(--chalk);">{phase.name}</span>
            {i < phases.length - 1 && (
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--ghost); opacity: 0.5;">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            )}
          </Fragment>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        See it in action.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Your first 2 analyses are free. No credit card required.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href="https://kaldon.io/signup" data-event="features_final_cta">
          Start Free, 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .phase-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px 6px 6px;
    border-radius: 999px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    color: var(--ghost);
    font-size: 13px;
    font-weight: 500;
    transition: border-color 160ms var(--ease-out-quad), color 160ms var(--ease-out-quad);
  }
  .phase-pill:hover { border-color: var(--hairline-active); color: var(--chalk); }
  .phase-pill-num {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--chalk);
    font-weight: 500;
  }

  .phase-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .phase-kicker-num {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--gold);
    letter-spacing: -0.01em;
    font-weight: 500;
  }
  .phase-kicker-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
  }

  .feat-card {
    padding: 24px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .feat-card:hover { border-color: var(--hairline-active); }
  .feat-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    color: var(--chalk);
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }
  .feat-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ghost);
    letter-spacing: -0.005em;
  }

  .feat-visual {
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  @media (max-width: 1023px) {
    .feat-visual { margin-top: 24px; }
  }

  /* Supplier Verification spotlight */
  .supplier-card {
    padding: 40px 36px;
    background: var(--deep-space);
    border: 1px solid transparent;
    border-radius: 16px;
    position: relative;
    box-shadow: var(--shadow-lift);
  }
  .supplier-card::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(255,184,0,0.45), rgba(0,212,255,0.2) 60%, rgba(255,255,255,0.06));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  .supplier-stats {
    margin-top: 28px;
    padding-top: 28px;
    border-top: 1px solid var(--hairline);
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .supplier-stats { grid-template-columns: repeat(3, 1fr); gap: 24px; }
  }
  .supplier-stat { display: flex; flex-direction: column; gap: 4px; }
  .supplier-stat-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    color: var(--gold);
    letter-spacing: -0.02em;
  }
  .supplier-stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
  }
</style>
