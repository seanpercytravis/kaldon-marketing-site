---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import Button from '../components/ui/Button.astro';
import DiscoverPane from '../components/visuals/phases/DiscoverPane.astro';
import { appUrl } from '../lib/urls';
import BuildPane from '../components/visuals/phases/BuildPane.astro';
import CreatePane from '../components/visuals/phases/CreatePane.astro';
import LaunchPane from '../components/visuals/phases/LaunchPane.astro';
import GrowPane from '../components/visuals/phases/GrowPane.astro';

const phases = [
  {
    num: '01',
    name: 'Discover',
    youDo: 'Enter a product category or market you want to build in.',
    kaldonDoes: 'Kaldon runs 10 parallel data sources: sales, pricing, search demand, social momentum, advertising saturation, competitor coverage, across Amazon, Walmart, and DTC. Claude synthesizes the signals and surfaces the products the market is already paying for but nobody is shipping yet.',
    youGet: 'A new-product brief: unmet-demand score, validated UVP your product can own, competitive gap map, AI-generated mockups, supplier capability shortlist, and a step-by-step plan from spec to first shipment.',
    screenshot: '/images/screenshots/01-analysis-hero.webp',
    alt: 'Kaldon AI analysis report showing product viability score, market data, and AI-generated product images',
  },
  {
    num: '02',
    name: 'Build',
    youDo: 'Click "Build Brand" from your analysis.',
    kaldonDoes: 'Kaldon generates a complete brand identity from your analysis data: name suggestions, logo concepts, color palette, typography, brand voice, and visual identity. Everything is stored in your Brand Vault and flows automatically into every downstream step.',
    youGet: 'A professional brand identity with logo, colors, voice guidelines, and a Brand Board you can share with partners, manufacturers, or your team.',
    screenshot: '/images/screenshots/07-brand-detail.webp',
    alt: 'Kaldon Brand Vault showing complete brand identity with logo, colors, and voice settings',
  },
  {
    num: '03',
    name: 'Create',
    youDo: 'Click "Generate Content" from your brand.',
    kaldonDoes: 'Kaldon generates a full month of social media content across 5 platforms, all matching your brand voice. It creates 10 types of AI videos, conversion-optimized landing pages, and product descriptions. Everything is on-brand automatically.',
    youGet: 'A month of social content, AI videos, landing pages, and product copy, all ready to publish and all matching your brand identity.',
    screenshot: '/images/screenshots/10-content-calendar.webp',
    alt: 'Kaldon Content Calendar showing multi-platform social posts with scheduling',
  },
  {
    num: '04',
    name: 'Launch',
    youDo: 'Configure your brand, pick a subdomain, and deploy.',
    kaldonDoes: 'Kaldon deploys a complete store with checkout, automated emails, SMS sequences, chatbot, and ad templates. The Blog Engine auto-publishes GEO-optimized SEO content on a weekly schedule, in your brand voice, with structured data baked in.',
    youGet: 'A live, revenue-ready store that is already marketing itself from day one, with automated blog content and all customer touchpoints configured.',
    screenshot: '/images/screenshots/14-store-deployment.webp',
    alt: 'Kaldon Store Deployment page showing one-click store launch features',
  },
  {
    num: '05',
    name: 'Grow',
    youDo: 'Review your dashboard.',
    kaldonDoes: 'Kaldon manages your Meta ad campaigns with AI optimization, identifies churn risk in your customer base, tracks ROAS/CAC/LTV in real-time, and automatically generates new ad creatives from your best performers.',
    youGet: 'Ads that optimize themselves, customers that keep coming back, and a performance dashboard that shows exactly where your money is going and what it is earning.',
    screenshot: '/images/screenshots/15-journey-progress.webp',
    alt: 'Kaldon growth dashboard showing performance analytics and ad optimization',
  },
];
---

<BaseLayout
  title="How Kaldon Works. From Product Idea to Revenue in 5 Phases"
  description="See how Kaldon's AI-powered pipeline takes you from product research to a live, revenue-generating store in 5 connected phases. No juggling tools. No gaps."
  structuredData={[
    {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: 'How Kaldon takes a seller from market gap to shipped business',
      description: 'A 5-phase AI-powered pipeline: Discover unmet demand, Build a brand, Create content, Launch a store, and Grow with AI-optimized ads.',
      step: [
        { '@type': 'HowToStep', position: 1, name: 'Discover', text: 'Kaldon reads 10 parallel data sources (sales, pricing, search demand, social momentum, ad saturation, competitor coverage) across Amazon, Walmart, and DTC, then surfaces the products the market is paying for but nobody is shipping.' },
        { '@type': 'HowToStep', position: 2, name: 'Build', text: 'Kaldon generates a complete brand identity from the research signals: logo, palette, typography, voice. A professional brand in minutes.' },
        { '@type': 'HowToStep', position: 3, name: 'Create', text: 'Kaldon generates a month of on-brand content across Instagram, TikTok, LinkedIn, X, Pinterest, and Facebook. Blogs auto-publish on schedule.' },
        { '@type': 'HowToStep', position: 4, name: 'Launch', text: 'Kaldon deploys a full DTC storefront in minutes with checkout, email sequences, SMS flows, and a chatbot trained on the product data.' },
        { '@type': 'HowToStep', position: 5, name: 'Grow', text: 'Kaldon optimizes ads across Meta, TikTok, and Google. Monitors CAC, ROAS, and LTV, and proposes the next product adjacency when margin allows.' },
      ],
    },
    {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Kaldon',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description: 'AI-powered eCommerce intelligence platform. From market gap to shipped business in one continuous pipeline.',
      offers: {
        '@type': 'AggregateOffer',
        lowPrice: '0',
        highPrice: '1499',
        priceCurrency: 'USD',
        offerCount: '5',
      },
    },
  ]}
>
  <PageHero
    kicker="How It Works"
    headline="From market gap to shipped product. Five phases."
    subhead="Kaldon reads demand signals, finds what to build, verifies who can make it, generates the brand, creates the content, deploys the store, and scales the ads. Every step feeds the next, one continuous creation pipeline."
    stats={[
      { label: 'Minutes to first analysis', numeral: 15, sub: 'From signup to report' },
      { label: 'Days to launch', numeral: '1–2', sub: 'From spec to live store', accent: 'gold' },
      { label: 'Tools replaced', prefix: '$', numeral: '18k', suffix: '+', sub: 'in subscriptions and fees', accent: 'signal' },
    ]}
  />

  <!-- Timeline -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <div class="relative">
        <!-- Vertical spine (desktop only) -->
        <div class="timeline-spine" aria-hidden="true"></div>

        {phases.map((phase, i) => (
          <div class="timeline-row">
            <!-- Phase marker -->
            <div class="timeline-marker">
              <span class="timeline-marker-num">{phase.num}</span>
            </div>

            <div class="timeline-content">
              <!-- Phase kicker -->
              <div class="phase-label">
                <span class="phase-label-text">Phase {parseInt(phase.num)} · {phase.name}</span>
              </div>

              <!-- Content grid -->
              <div class="grid md:grid-cols-2 gap-6 md:gap-8 items-start mt-5">
                <!-- Text triptych -->
                <div class="space-y-3">
                  <div class="triptych-card">
                    <span class="triptych-kicker">What you do</span>
                    <p class="triptych-body" style="color: var(--chalk); font-weight: 500;">{phase.youDo}</p>
                  </div>
                  <div class="triptych-card">
                    <span class="triptych-kicker" style="color: var(--signal);">What Kaldon does</span>
                    <p class="triptych-body">{phase.kaldonDoes}</p>
                  </div>
                  <div class="triptych-card" style="border-left: 2px solid var(--gold);">
                    <span class="triptych-kicker" style="color: var(--gold);">What you get</span>
                    <p class="triptych-body">{phase.youGet}</p>
                  </div>
                </div>

                <!-- Custom phase pane (live DOM, not a screenshot) -->
                <div class="timeline-visual">
                  {i === 0 && <DiscoverPane variant="inline" />}
                  {i === 1 && <BuildPane variant="inline" />}
                  {i === 2 && <CreatePane variant="inline" />}
                  {i === 3 && <LaunchPane variant="inline" />}
                  {i === 4 && <GrowPane variant="inline" />}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing quote -->
  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <p class="font-display italic" style="font-weight: 500; font-size: clamp(20px, 2.2vw, 24px); color: var(--gold); letter-spacing: -0.015em;">
        "The entire pipeline takes less time than reading this page."
      </p>
      <h2 class="font-display mt-8" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        Ready to start?
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Your first 2 analyses are free. No credit card required.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href={appUrl('/signup', 'how_it_works_cta')} data-event="how_it_works_cta">
          Start Your First Analysis
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .timeline-spine {
    position: absolute;
    top: 20px;
    bottom: 20px;
    left: 22px;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--hairline-active) 8%, var(--hairline-active) 92%, transparent);
  }
  @media (min-width: 768px) {
    .timeline-spine { left: 27px; }
  }

  .timeline-row {
    position: relative;
    padding-left: 60px;
    padding-bottom: 64px;
  }
  .timeline-row:last-child { padding-bottom: 0; }

  @media (min-width: 768px) {
    .timeline-row { padding-left: 72px; padding-bottom: 80px; }
  }

  .timeline-marker {
    position: absolute;
    top: 0;
    left: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--void);
    border: 1px solid var(--hairline-active);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.03);
  }
  .timeline-marker-num {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--chalk);
    letter-spacing: -0.01em;
  }

  .phase-label-text {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
  }

  .triptych-card {
    padding: 18px 20px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
  }
  .triptych-kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
    margin-bottom: 6px;
  }
  .triptych-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-secondary);
    letter-spacing: -0.005em;
  }

  .timeline-visual {
    position: sticky;
    top: 80px;
  }
  .visual-frame {
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    overflow: hidden;
  }
  .visual-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--hairline);
    background: rgba(255, 255, 255, 0.015);
  }
  .visual-breadcrumb {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--ghost);
    letter-spacing: 0.04em;
  }

  @media (max-width: 767px) {
    .timeline-visual { position: static; }
  }
</style>
