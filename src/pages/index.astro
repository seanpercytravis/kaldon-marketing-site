---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ConnectedPlatforms from '../components/home/ConnectedPlatforms.astro';
import ProblemSection from '../components/home/ProblemSection.astro';
import PipelineScroll from '../components/home/PipelineScroll.astro';
import ModeBadges from '../components/ui/ModeBadges.astro';
import MarketGapWeek from '../components/home/MarketGapWeek.astro';
import IntelligenceDepth from '../components/home/IntelligenceDepth.astro';
import WhoItsFor from '../components/home/WhoItsFor.astro';
import PricingTeaser from '../components/home/PricingTeaser.astro';
import SavingsCalculator from '../components/home/SavingsCalculator.astro';
import FinalCTA from '../components/home/FinalCTA.astro';
import Testimonials from '../components/home/Testimonials.astro';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Kaldon',
    url: 'https://kaldon.io',
    logo: 'https://kaldon.io/images/logos/kaldon-logo-dark.svg',
    description:
      'AI-powered eCommerce intelligence platform that takes sellers from product research to revenue across Amazon, Walmart, and DTC.',
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'support@kaldon.io',
      contactType: 'customer support',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Kaldon',
    url: 'https://kaldon.io',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Kaldon',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    offers: {
      '@type': 'AggregateOffer',
      lowPrice: '0',
      highPrice: '1499',
      priceCurrency: 'USD',
      offerCount: '5',
    },
  },
];
---

<BaseLayout
  title="Kaldon — AI-Powered eCommerce Intelligence Platform"
  description="Kaldon finds winning products across Amazon, Walmart, and DTC, then builds your brand, creates your content, launches your store, and grows your business. One platform. One click at a time."
  structuredData={structuredData}
>
  <Hero />
  <ConnectedPlatforms />
  <ProblemSection />
  <PipelineScroll />
  <ModeBadges headline="Three ways to use Kaldon. One creation pipeline." />
  <IntelligenceDepth />
  <MarketGapWeek
    signalCategory="Beverage Accessories"
    signalHeadline="Insulated mugs with integrated lid-based tea infusers"
    signalDetail="Search growth across Amazon, Walmart, TikTok, and Pinterest outpaces every other insulated-mug subcategory. Only three competitors ship a lid-infuser combo and none use ceramic-lined interiors — the format readers keep asking for in reviews."
    demandLift="340%"
    supplySupply="3"
    searchVolume="48k / mo"
  />
  <Testimonials />
  <WhoItsFor />
  <PricingTeaser />
  <SavingsCalculator />
  <FinalCTA />
</BaseLayout>
