---
import BaseLayout from '../layouts/BaseLayout.astro';

const screenshots = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/01-analysis-hero_3f7ba299.webp',
  aiImages: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/02-analysis-ai-images_14ee42ac.webp',
  actionPlan: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/03-analysis-action-plan_78cf672b.webp',
  coaching: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/04-analysis-coaching_2780bad5.webp',
  brandVault: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/06-brand-vault_fa12d0ed.webp',
  brandDetail: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/07-brand-detail_4f3a066d.webp',
  calendar: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/10-content-calendar_7c1d7fef.webp',
  storeDeployment: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/14-store-deployment_0243c609.webp',
  pricing: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/17-pricing_68278703.webp',
  journey: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/15-journey-progress_07bbb337.webp',
  opportunityFeed: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/16-opportunity-feed_363e1510.webp',
  videoStudio: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/12-video-studio_7f146b15.webp',
  landingPages: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663311683194/7J678J842cyHStNyXeG49u/13-landing-pages_5fbc7fb5.webp',
};
---

<BaseLayout
  title="Kaldon — AI-Powered eCommerce Intelligence Platform"
  description="Find your next winning product, build your brand, create content, launch your store, and grow your business. One platform. Five phases. Zero gaps."
>

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-kaldon-cyan/5 via-kaldon-bg to-kaldon-purple/5"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-kaldon-cyan/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-kaldon-purple/5 rounded-full blur-[100px]"></div>

    <div class="container-custom relative z-10 py-20 lg:py-28">
      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div class="max-w-2xl">
          <h1 class="text-4xl md:text-5xl lg:text-[56px] font-extrabold leading-[1.1] mb-6">
            <span class="gradient-text">Find Your Next Winning Product.</span><br />
            <span class="text-kaldon-text">Launch It. Grow It.</span><br />
            <span class="text-kaldon-text">One Platform.</span>
          </h1>
          <p class="text-lg md:text-xl text-kaldon-muted leading-relaxed mb-8 max-w-xl">
            Kaldon is the AI-powered operating system that takes eCommerce sellers from product research to a live, revenue-generating store — without juggling six different tools.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://kaldon.io/signup" class="btn-primary btn-large btn-glow">
              Start Free: 2 Analyses Included
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
            <a href="#demo-section" class="btn-secondary btn-large">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Watch How It Works
            </a>
          </div>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-kaldon-surface border border-kaldon-border text-kaldon-muted">
              <svg class="w-3.5 h-3.5 text-kaldon-green" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              No credit card required
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-kaldon-surface border border-kaldon-border text-kaldon-muted">
              <svg class="w-3.5 h-3.5 text-kaldon-cyan" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              2 free analyses
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-kaldon-surface border border-kaldon-border text-kaldon-muted">
              <svg class="w-3.5 h-3.5 text-kaldon-purple" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
              Set up in 60 seconds
            </span>
          </div>
        </div>
        <div class="relative">
          <div class="screenshot-container"><img src={screenshots.hero} alt="Kaldon AI product analysis report showing a detailed score with market intelligence" class="w-full h-auto" loading="eager" /></div>
          <div class="absolute -inset-4 bg-kaldon-cyan/5 rounded-3xl blur-2xl -z-10"></div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-kaldon-border/50 text-center">
        <p class="text-sm text-kaldon-muted">Powered by <span class="text-kaldon-text font-medium">21 frontier AI engines</span> &middot; Trusted by eCommerce sellers across <span class="text-kaldon-text font-medium">Amazon, Walmart &amp; DTC</span></p>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: THE PROBLEM ===== -->
  <section class="section-spacing bg-kaldon-bg">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <span class="eyebrow">THE PROBLEM</span>
        <h2 class="section-headline mb-6">Launching an eCommerce Product Shouldn't Require 6 Subscriptions and 200 Hours</h2>
        <p class="text-kaldon-muted text-lg leading-relaxed">You've got a product idea. But turning that idea into a real, selling product means learning Jungle Scout for research, Canva for brand design, Jasper for content, Later for scheduling, Shopify for your store, and Ads Manager for traffic. Six different logins. Six different learning curves. And none of them talk to each other.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-cyan/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Jungle Scout / Helium 10</h3><p class="text-sm text-kaldon-muted">Product research</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$79–99/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-purple/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Canva Pro / Looka</h3><p class="text-sm text-kaldon-muted">Brand design + logo</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$15–35/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-green/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Jasper / Copy.ai</h3><p class="text-sm text-kaldon-muted">Content writing</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$49–59/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-yellow/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Later / Hootsuite</h3><p class="text-sm text-kaldon-muted">Social scheduling</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$25–49/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-red/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Shopify</h3><p class="text-sm text-kaldon-muted">Store platform</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$39–79/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-orange/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Meta Ads Manager</h3><p class="text-sm text-kaldon-muted">Ad management</p><p class="text-sm font-semibold text-kaldon-orange mt-1">Your time</p></div>
        </div>
      </div>
      <div class="text-center animate-on-scroll">
        <p class="text-2xl md:text-3xl font-bold"><span class="text-kaldon-red line-through decoration-2">$207–400+/mo.</span><span class="text-kaldon-muted ml-2">And none of them talk to each other.</span></p>
        <p class="text-kaldon-cyan font-semibold text-lg mt-6">There's a better way.</p>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: THE SOLUTION ===== -->
  <section class="section-spacing relative">
    <div class="absolute inset-0 bg-gradient-to-b from-kaldon-bg via-kaldon-surface/50 to-kaldon-bg"></div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <span class="eyebrow">THE SOLUTION</span>
        <h2 class="section-headline mb-6">One Platform. Five Phases. Zero Gaps.</h2>
        <p class="text-kaldon-muted text-lg leading-relaxed">Kaldon replaces your entire tool stack with a single AI-powered pipeline. Your data flows from research to brand to content to store to ads — automatically.</p>
      </div>
      <div class="relative max-w-5xl mx-auto mb-16 animate-on-scroll">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-0">
          <div class="flex flex-col items-center text-center w-40">
            <div class="w-16 h-16 rounded-2xl bg-kaldon-cyan/10 border-2 border-kaldon-cyan flex items-center justify-center mb-3 transition-all hover:bg-kaldon-cyan/20 hover:shadow-cyan-glow"><svg class="w-7 h-7 text-kaldon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg></div>
            <h3 class="font-bold text-kaldon-text mb-1">Discover</h3>
            <p class="text-xs text-kaldon-muted leading-relaxed">AI Analysis Engine<br/>Opportunity Feed<br/>Market Intelligence</p>
          </div>
          <div class="hidden md:block flex-1 h-0.5 bg-gradient-to-r from-kaldon-cyan to-kaldon-orange mx-2"></div>
          <div class="md:hidden w-0.5 h-8 bg-gradient-to-b from-kaldon-cyan to-kaldon-orange"></div>
          <div class="flex flex-col items-center text-center w-40">
            <div class="w-16 h-16 rounded-2xl bg-kaldon-orange/10 border-2 border-kaldon-orange flex items-center justify-center mb-3 transition-all hover:bg-kaldon-orange/20"><svg class="w-7 h-7 text-kaldon-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg></div>
            <h3 class="font-bold text-kaldon-text mb-1">Build</h3>
            <p class="text-xs text-kaldon-muted leading-relaxed">Brand Vault<br/>AI Logo Generation<br/>Brand Board</p>
          </div>
          <div class="hidden md:block flex-1 h-0.5 bg-gradient-to-r from-kaldon-orange to-kaldon-purple mx-2"></div>
          <div class="md:hidden w-0.5 h-8 bg-gradient-to-b from-kaldon-orange to-kaldon-purple"></div>
          <div class="flex flex-col items-center text-center w-40">
            <div class="w-16 h-16 rounded-2xl bg-kaldon-purple/10 border-2 border-kaldon-purple flex items-center justify-center mb-3 transition-all hover:bg-kaldon-purple/20"><svg class="w-7 h-7 text-kaldon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></div>
            <h3 class="font-bold text-kaldon-text mb-1">Create</h3>
            <p class="text-xs text-kaldon-muted leading-relaxed">Content Calendar<br/>Video Studio<br/>Landing Pages</p>
          </div>
          <div class="hidden md:block flex-1 h-0.5 bg-gradient-to-r from-kaldon-purple to-kaldon-green mx-2"></div>
          <div class="md:hidden w-0.5 h-8 bg-gradient-to-b from-kaldon-purple to-kaldon-green"></div>
          <div class="flex flex-col items-center text-center w-40">
            <div class="w-16 h-16 rounded-2xl bg-kaldon-green/10 border-2 border-kaldon-green flex items-center justify-center mb-3 transition-all hover:bg-kaldon-green/20"><svg class="w-7 h-7 text-kaldon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg></div>
            <h3 class="font-bold text-kaldon-text mb-1">Launch</h3>
            <p class="text-xs text-kaldon-muted leading-relaxed">Store Deployment<br/>Blog Engine<br/>Marketplace Listings</p>
          </div>
          <div class="hidden md:block flex-1 h-0.5 bg-gradient-to-r from-kaldon-green to-kaldon-yellow mx-2"></div>
          <div class="md:hidden w-0.5 h-8 bg-gradient-to-b from-kaldon-green to-kaldon-yellow"></div>
          <div class="flex flex-col items-center text-center w-40">
            <div class="w-16 h-16 rounded-2xl bg-kaldon-yellow/10 border-2 border-kaldon-yellow flex items-center justify-center mb-3 transition-all hover:bg-kaldon-yellow/20"><svg class="w-7 h-7 text-kaldon-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg></div>
            <h3 class="font-bold text-kaldon-text mb-1">Grow</h3>
            <p class="text-xs text-kaldon-muted leading-relaxed">Ad Optimization<br/>Customer Retention<br/>Performance Analytics</p>
          </div>
        </div>
      </div>
      <div class="text-center max-w-2xl mx-auto animate-on-scroll">
        <p class="text-kaldon-muted text-lg leading-relaxed mb-8">Every step feeds the next. Your analysis data becomes your brand. Your brand becomes your content. Your content populates your store. <span class="text-kaldon-text font-medium">One continuous flow.</span></p>
        <a href="https://kaldon.io/signup" class="btn-primary">Start with Discover — it's free <svg class="w-5 h-5 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></a>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 4: FEATURE DEEP DIVES ===== -->
  <section class="section-spacing bg-kaldon-bg">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <span class="eyebrow">THE PLATFORM</span>
        <h2 class="section-headline">Five Phases. One Seamless Pipeline.</h2>
      </div>
      <div class="flex flex-wrap justify-center gap-2 mb-12" id="phase-tabs">
        <button class="phase-tab active px-5 py-2.5 rounded-lg text-sm font-medium transition-all border" data-phase="discover" style="border-color:#00E5CC;color:#00E5CC;background:rgba(0,229,204,0.1);">Discover</button>
        <button class="phase-tab px-5 py-2.5 rounded-lg text-sm font-medium transition-all border border-kaldon-border text-kaldon-muted hover:text-kaldon-text" data-phase="build">Build</button>
        <button class="phase-tab px-5 py-2.5 rounded-lg text-sm font-medium transition-all border border-kaldon-border text-kaldon-muted hover:text-kaldon-text" data-phase="create">Create</button>
        <button class="phase-tab px-5 py-2.5 rounded-lg text-sm font-medium transition-all border border-kaldon-border text-kaldon-muted hover:text-kaldon-text" data-phase="launch">Launch</button>
        <button class="phase-tab px-5 py-2.5 rounded-lg text-sm font-medium transition-all border border-kaldon-border text-kaldon-muted hover:text-kaldon-text" data-phase="grow">Grow</button>
      </div>
      <div id="phase-panels">
        <!-- Discover Panel -->
        <div class="phase-panel" data-phase="discover">
          <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div>
              <h3 class="text-2xl md:text-3xl font-bold text-kaldon-text mb-4">Know Exactly What to Sell — Before You Invest a Dollar</h3>
              <ul class="space-y-3 mb-6">
