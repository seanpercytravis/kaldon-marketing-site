  <section class="section-spacing relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-kaldon-cyan/10 via-kaldon-bg to-kaldon-purple/10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-kaldon-cyan/5 rounded-full blur-[150px]"></div>
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-kaldon-text mb-4 animate-on-scroll">Your Next Product Is Waiting</h2>
      <p class="text-lg text-kaldon-muted mb-8 max-w-lg mx-auto animate-on-scroll">2 free analyses. No credit card. No commitment. Just intelligence.</p>
      <a href="https://kaldon.io/signup" class="btn-primary btn-large btn-glow inline-flex">Start Free <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></a>
      <p class="text-sm text-kaldon-muted mt-6 animate-on-scroll">Set up in 60 seconds. Cancel anytime. Your data stays yours.</p>
    </div>
  </section>

  <script is:inline>
    // Phase tabs
    document.querySelectorAll('.phase-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        const phase = this.dataset.phase;
        const colors = { discover:'#22d3ee', build:'#fb923c', create:'#a78bfa', launch:'#34d399', grow:'#fbbf24' };
        document.querySelectorAll('.phase-tab').forEach(t => { t.classList.remove('active'); t.style.borderColor=''; t.style.color=''; t.style.background=''; });
        this.classList.add('active'); this.style.borderColor=colors[phase]; this.style.color=colors[phase]; this.style.background=colors[phase]+'1A';
        document.querySelectorAll('.phase-panel').forEach(p => p.classList.add('hidden'));
        document.querySelector('.phase-panel[data-phase="'+phase+'"]').classList.remove('hidden');
      });
    });
    // Demo tabs
    document.querySelectorAll('.demo-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.demo-tab').forEach(t => { t.classList.remove('active'); t.className=t.className.replace(/bg-kaldon-cyan\/10 text-kaldon-cyan border-kaldon-cyan\/30/g,'text-kaldon-muted border-kaldon-border'); });
        this.classList.add('active'); this.className=this.className.replace(/text-kaldon-muted border-kaldon-border/g,'bg-kaldon-cyan/10 text-kaldon-cyan border-kaldon-cyan/30');
        document.querySelectorAll('.demo-panel').forEach(p => p.classList.add('hidden'));
        document.getElementById('arcade-demo-'+this.dataset.demo).classList.remove('hidden');
      });
    });
    // Pricing toggle
    let isAnnual=true;
    document.getElementById('pricing-toggle')?.addEventListener('click',function(){
      isAnnual=!isAnnual;
      document.getElementById('pricing-toggle-dot').style.transform=isAnnual?'translateX(24px)':'translateX(0)';
      document.querySelectorAll('.pricing-annual').forEach(el=>el.classList.toggle('hidden',!isAnnual));
      document.querySelectorAll('.pricing-monthly').forEach(el=>el.classList.toggle('hidden',isAnnual));
      document.getElementById('annual-label').classList.toggle('font-medium',isAnnual);
      document.getElementById('annual-label').classList.toggle('text-kaldon-text',isAnnual);
      document.getElementById('annual-label').classList.toggle('text-kaldon-muted',!isAnnual);
      document.getElementById('monthly-label').classList.toggle('font-medium',!isAnnual);
      document.getElementById('monthly-label').classList.toggle('text-kaldon-text',!isAnnual);
      document.getElementById('monthly-label').classList.toggle('text-kaldon-muted',isAnnual);
    });
    // ROI Calculator
    function updateROI(){
      const tools=parseInt(document.getElementById('tools-slider').value);
      const cost=parseInt(document.getElementById('cost-slider').value);
      const hours=parseInt(document.getElementById('hours-slider').value);
      document.getElementById('tools-value').textContent=tools;
      document.getElementById('cost-value').textContent='$'+cost;
      document.getElementById('hours-value').textContent=hours;
      const monthlySavings=Math.max(0,tools*cost-149);
      document.getElementById('monthly-savings').textContent='$'+monthlySavings.toLocaleString();
      document.getElementById('yearly-savings').textContent='$'+(monthlySavings*12).toLocaleString();
      document.getElementById('hours-saved').textContent=(hours*48)+'h';
    }
    document.getElementById('tools-slider')?.addEventListener('input',updateROI);
    document.getElementById('cost-slider')?.addEventListener('input',updateROI);
    document.getElementById('hours-slider')?.addEventListener('input',updateROI);
    // Intersection Observer
    const observer=new IntersectionObserver((entries)=>{entries.forEach(entry=>{if(entry.isIntersecting){entry.target.classList.add('visible');observer.unobserve(entry.target);}});},{threshold:0.1,rootMargin:'0px 0px -50px 0px'});
    document.querySelectorAll('.animate-on-scroll').forEach(el=>observer.observe(el));
  </script>
</BaseLayout>
