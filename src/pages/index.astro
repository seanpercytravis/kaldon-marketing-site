---
import BaseLayout from '../layouts/BaseLayout.astro';

const screenshots = {
  hero: '/images/screenshots/01-analysis-hero.webp',
  aiImages: '/images/screenshots/02-analysis-ai-images.webp',
  actionPlan: '/images/screenshots/03-analysis-action-plan.webp',
  coaching: '/images/screenshots/04-analysis-coaching.webp',
  brandVault: '/images/screenshots/06-brand-vault.webp',
  brandDetail: '/images/screenshots/07-brand-detail.webp',
  brandVisualIdentity: '/images/screenshots/09-brand-visual-identity.webp',
  calendar: '/images/screenshots/10-content-calendar.webp',
  storeDeployment: '/images/screenshots/14-store-deployment.webp',
  pricing: '/images/screenshots/17-pricing.webp',
  journey: '/images/screenshots/15-journey-progress.webp',
  opportunityFeed: '/images/screenshots/16-opportunity-feed.webp',
  videoStudio: '/images/screenshots/12-video-studio.webp',
  landingPages: '/images/screenshots/13-landing-pages.webp',
};

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Kaldon",
    "url": "https://kaldon.io",
    "logo": "https://kaldon.io/images/logos/kaldon-logo-dark.svg",
    "description": "AI-powered eCommerce intelligence platform that takes sellers from product research to revenue.",
    "contactPoint": { "@type": "ContactPoint", "email": "support@kaldon.io", "contactType": "customer support" }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Kaldon",
    "url": "https://kaldon.io"
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Kaldon",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "0",
      "highPrice": "499",
      "priceCurrency": "USD",
      "offerCount": "5"
    }
  }
];
---

<BaseLayout
  title="Kaldon — AI-Powered eCommerce Intelligence Platform"
  description="Find your next winning product, build your brand, create content, launch your store, and grow your business. One platform. Five phases. Zero gaps."
  structuredData={structuredData}
>

  <!-- ===== SECTION 1: HERO ===== -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-kaldon-cyan/5 via-kaldon-bg to-kaldon-purple/5"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-kaldon-cyan/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-kaldon-purple/5 rounded-full blur-[100px]"></div>

    <div class="container-custom relative z-10 py-20 lg:py-28">
      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
        <div class="max-w-2xl">
          <h1 class="text-4xl md:text-5xl lg:text-[56px] font-extrabold leading-[1.1] mb-6">
            <span class="gradient-text">From Research to Revenue.</span><br />
            <span class="text-kaldon-text">Any Marketplace.</span>
          </h1>
          <p class="text-lg md:text-xl text-kaldon-muted leading-relaxed mb-8 max-w-xl">
            Kaldon is the AI-powered operating system that takes eCommerce sellers from product research to a live, revenue-generating store — without juggling six different tools.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <a href="https://kaldon.io/signup" class="btn-primary btn-large btn-glow" data-event="hero_cta_click">
              Start Free, 2 Analyses Included
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
            <a href="#product-showcase" class="btn-secondary btn-large" data-event="see_how_click">
              See How It Works
            </a>
          </div>
          <p class="text-sm text-kaldon-muted mb-6">No credit card required. Free plan available.</p>
          <!-- C1: Hero social proof -->
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              <svg class="w-4 h-4 text-kaldon-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              <svg class="w-4 h-4 text-kaldon-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              <svg class="w-4 h-4 text-kaldon-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              <svg class="w-4 h-4 text-kaldon-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              <svg class="w-4 h-4 text-kaldon-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            </div>
            <span class="text-sm text-kaldon-muted">Trusted by eCommerce sellers across 3 marketplaces</span>
          </div>
        </div>
        <div class="relative hidden lg:block">
          <div class="screenshot-container"><img src={screenshots.hero} alt="Kaldon AI product analysis report showing detailed market intelligence" class="w-full h-auto" loading="eager" /></div>
          <div class="absolute -inset-4 bg-kaldon-cyan/5 rounded-3xl blur-2xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: SOCIAL PROOF STRIP ===== -->
  <section class="py-8 border-y border-kaldon-border/50">
    <div class="container-custom">
      <p class="text-center text-sm text-kaldon-muted mb-6">Connected to the marketplaces and platforms your business runs on</p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12 opacity-60 hover:opacity-80 transition-opacity">
        <span class="text-sm font-semibold text-kaldon-muted tracking-wider">Amazon</span>
        <span class="text-sm font-semibold text-kaldon-muted tracking-wider">Walmart</span>
        <span class="text-sm font-semibold text-kaldon-muted tracking-wider">Stripe</span>
        <span class="text-sm font-semibold text-kaldon-muted tracking-wider">Meta</span>
        <span class="text-sm font-semibold text-kaldon-muted tracking-wider">TikTok</span>
        <span class="text-sm font-semibold text-kaldon-muted tracking-wider">Google</span>
        <span class="text-sm font-semibold text-kaldon-muted tracking-wider">Shopify</span>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: THE PROBLEM ($10,000 Problem) ===== -->
  <section class="section-spacing bg-kaldon-bg">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <span class="eyebrow">THE $10,000 PROBLEM</span>
        <h2 class="section-headline mb-6">Launching an eCommerce Product Shouldn't Require 6 Subscriptions and 200 Hours</h2>
        <p class="text-kaldon-muted text-lg leading-relaxed">You've got a product idea. But turning that idea into a real, selling product means learning Jungle Scout for research, Canva for brand design, Jasper for content, Later for scheduling, Shopify for your store, and Ads Manager for traffic. Six different logins. Six different learning curves. And none of them talk to each other.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-cyan/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Jungle Scout / Helium 10</h3><p class="text-sm text-kaldon-muted">Product research</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$79–99/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-purple/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Canva Pro / Looka</h3><p class="text-sm text-kaldon-muted">Brand design + logo</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$15–35/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-green/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Jasper / Copy.ai</h3><p class="text-sm text-kaldon-muted">Content writing</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$49–59/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-yellow/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Later / Hootsuite</h3><p class="text-sm text-kaldon-muted">Social scheduling</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$25–49/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-red/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Shopify</h3><p class="text-sm text-kaldon-muted">Store platform</p><p class="text-sm font-semibold text-kaldon-orange mt-1">$39–79/mo</p></div>
        </div>
        <div class="card flex items-start gap-4 animate-on-scroll">
          <div class="w-10 h-10 rounded-lg bg-kaldon-orange/10 flex items-center justify-center shrink-0 mt-1"><svg class="w-5 h-5 text-kaldon-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" /></svg></div>
          <div><h3 class="font-semibold text-kaldon-text mb-1">Meta Ads Manager</h3><p class="text-sm text-kaldon-muted">Ad management</p><p class="text-sm font-semibold text-kaldon-orange mt-1">Your time</p></div>
        </div>
      </div>
      <div class="text-center animate-on-scroll">
        <p class="text-2xl md:text-3xl font-bold"><span class="text-kaldon-red line-through decoration-2">$207–400+/mo.</span><span class="text-kaldon-muted ml-2">And none of them talk to each other.</span></p>
        <p class="text-kaldon-cyan font-semibold text-lg mt-6">There's a better way.</p>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 4: ANIMATED PRODUCT SHOWCASE (Phase 3) ===== -->
  <section id="product-showcase" class="section-spacing relative">
    <div class="absolute inset-0 bg-gradient-to-b from-kaldon-bg via-kaldon-surface/50 to-kaldon-bg"></div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-12 animate-on-scroll">
        <span class="eyebrow">THE SOLUTION</span>
        <h2 class="section-headline mb-4">One Platform. Five Phases. Zero Gaps.</h2>
        <p class="text-kaldon-muted text-lg">Kaldon replaces your entire tool stack with a single AI-powered pipeline.</p>
      </div>

      <!-- Phase Tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-12" id="showcase-tabs" role="tablist" aria-label="Product phases">
        <button class="showcase-tab active" data-phase="discover" role="tab" aria-selected="true" aria-controls="panel-discover" style="border-color:#22d3ee;color:#22d3ee;background:rgba(34,211,238,0.1);">
          <span class="tab-label">Discover</span>
          <div class="tab-progress"><div class="tab-progress-bar"></div></div>
        </button>
        <button class="showcase-tab" data-phase="build" role="tab" aria-selected="false" aria-controls="panel-build">
          <span class="tab-label">Build</span>
          <div class="tab-progress"><div class="tab-progress-bar"></div></div>
        </button>
        <button class="showcase-tab" data-phase="create" role="tab" aria-selected="false" aria-controls="panel-create">
          <span class="tab-label">Create</span>
          <div class="tab-progress"><div class="tab-progress-bar"></div></div>
        </button>
        <button class="showcase-tab" data-phase="launch" role="tab" aria-selected="false" aria-controls="panel-launch">
          <span class="tab-label">Launch</span>
          <div class="tab-progress"><div class="tab-progress-bar"></div></div>
        </button>
        <button class="showcase-tab" data-phase="grow" role="tab" aria-selected="false" aria-controls="panel-grow">
          <span class="tab-label">Grow</span>
          <div class="tab-progress"><div class="tab-progress-bar"></div></div>
        </button>
      </div>

      <!-- Phase Panels -->
      <div id="showcase-panels">
        <div class="showcase-panel" id="panel-discover" data-phase="discover" role="tabpanel">
          <div class="grid lg:grid-cols-[2fr_3fr] gap-12 items-center">
            <div>
              <h3 class="text-2xl md:text-3xl font-bold text-kaldon-text mb-4">Find Products That Actually Sell</h3>
              <p class="text-kaldon-muted text-lg leading-relaxed mb-6">11 intelligence sources analyze every angle: demand, competition, margins, trends, and supplier options. Across Amazon, Walmart, and emerging marketplaces. Know before you invest.</p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3"><svg class="w-5 h-5 text-kaldon-cyan shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-kaldon-muted">Multi-marketplace intelligence in one report</span></li>
                <li class="flex items-start gap-3"><svg class="w-5 h-5 text-kaldon-cyan shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-kaldon-muted">AI product mockups before sourcing</span></li>
                <li class="flex items-start gap-3"><svg class="w-5 h-5 text-kaldon-cyan shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-kaldon-muted">Step-by-step action plan with timelines</span></li>
              </ul>
            </div>
            <div class="screenshot-container"><img src={screenshots.hero} alt="Kaldon analysis report with market intelligence scores" class="w-full" loading="lazy" /></div>
          </div>
        </div>

        <div class="showcase-panel hidden" id="panel-build" data-phase="build" role="tabpanel">
          <div class="grid lg:grid-cols-[2fr_3fr] gap-12 items-center">
            <div>
              <h3 class="text-2xl md:text-3xl font-bold text-kaldon-text mb-4">Build a Brand in Minutes, Not Months</h3>
              <p class="text-kaldon-muted text-lg leading-relaxed mb-6">AI generates your complete brand identity: name, voice, visual system, logo concepts, and brand guidelines. Professional quality that used to cost $5,000+.</p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3"><svg class="w-5 h-5 text-kaldon-orange shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-kaldon-muted">Complete identity from your analysis data</span></li>
                <li class="flex items-start gap-3"><svg class="w-5 h-5 text-kaldon-orange shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-kaldon-muted">Professional Brand Boards for partners</span></li>
                <li class="flex items-start gap-3"><svg class="w-5 h-5 text-kaldon-orange shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-kaldon-muted">Edit or regenerate anything, anytime</span></li>
              </ul>
            </div>
            <div class="screenshot-container"><img src={screenshots.brandVisualIdentity} alt="Kaldon AI brand identity generator" class="w-full" loading="lazy" /></div>
          </div>
        </div>

        <div class="showcase-panel hidden" id="panel-create" data-phase="create" role="tabpanel">
          <div class="grid lg:grid-cols-[2fr_3fr] gap-12 items-center">
            <div>
              <h3 class="text-2xl md:text-3xl font-bold text-kaldon-text mb-4">A Month of Content, Ready to Go</h3>
              <p class="text-kaldon-muted text-lg leading-relaxed mb-6">Professional product photos, social media calendars, video content, and marketing copy. All on-brand, all generated in seconds, all yours.</p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3"><svg class="w-5 h-5 text-kaldon-purple shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-kaldon-muted">Full month of social content across 5 platforms</span></li>
