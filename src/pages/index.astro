  <script is:inline>
    // ===== ANIMATED PRODUCT SHOWCASE =====
    (function() {
      const phases = ['discover', 'build', 'create', 'launch', 'grow'];
      const colors = { discover:'#22d3ee', build:'#fb923c', create:'#a78bfa', launch:'#34d399', grow:'#fbbf24' };
      let currentIndex = 0;
      let autoTimer = null;
      let progressTimer = null;
      const CYCLE_MS = 5000;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function activatePhase(index) {
        currentIndex = index;
        const phase = phases[index];
        // Update tabs
        document.querySelectorAll('.showcase-tab').forEach((t, i) => {
          const isActive = i === index;
          t.classList.toggle('active', isActive);
          t.setAttribute('aria-selected', isActive);
          if (isActive) {
            t.style.borderColor = colors[phase];
            t.style.color = colors[phase];
            t.style.background = colors[phase] + '1A';
          } else {
            t.style.borderColor = '';
            t.style.color = '';
            t.style.background = '';
          }
          // Reset progress bars
          const bar = t.querySelector('.tab-progress-bar');
          if (bar) {
            bar.style.transition = 'none';
            bar.style.width = '0%';
            if (isActive && !prefersReducedMotion) {
              requestAnimationFrame(() => {
                bar.style.transition = 'width ' + CYCLE_MS + 'ms linear';
                bar.style.width = '100%';
              });
            }
          }
        });
        // Update panels with crossfade
        document.querySelectorAll('.showcase-panel').forEach(p => {
          if (p.dataset.phase === phase) {
            p.classList.remove('hidden');
            if (!prefersReducedMotion) {
              p.style.opacity = '0';
              p.style.transition = 'opacity 0.3s ease-in-out';
              requestAnimationFrame(() => { p.style.opacity = '1'; });
            }
          } else {
            p.classList.add('hidden');
          }
        });
      }

      function startAutoAdvance() {
        if (prefersReducedMotion) return;
        stopAutoAdvance();
        autoTimer = setInterval(() => {
          activatePhase((currentIndex + 1) % phases.length);
        }, CYCLE_MS);
      }

      function stopAutoAdvance() {
        if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
      }

      // Tab click handlers
      document.querySelectorAll('.showcase-tab').forEach((tab, i) => {
        tab.addEventListener('click', () => {
          activatePhase(i);
          stopAutoAdvance();
          startAutoAdvance();
        });
      });

      // Keyboard navigation
      document.getElementById('showcase-tabs')?.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          const next = (currentIndex + 1) % phases.length;
          activatePhase(next);
          document.querySelectorAll('.showcase-tab')[next]?.focus();
          stopAutoAdvance(); startAutoAdvance();
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          const prev = (currentIndex - 1 + phases.length) % phases.length;
          activatePhase(prev);
          document.querySelectorAll('.showcase-tab')[prev]?.focus();
          stopAutoAdvance(); startAutoAdvance();
        }
      });

      // Initialize
      activatePhase(0);
      startAutoAdvance();
    })();

    // ===== ROI CALCULATOR =====
    function updateROI() {
      const tools = parseInt(document.getElementById('tools-slider').value);
      const cost = parseInt(document.getElementById('cost-slider').value);
      const hours = parseInt(document.getElementById('hours-slider').value);
      document.getElementById('tools-value').textContent = tools;
      document.getElementById('cost-value').textContent = '$' + cost;
      document.getElementById('hours-value').textContent = hours;
      const monthlySavings = Math.max(0, tools * cost - 149);
      document.getElementById('monthly-savings').textContent = '$' + monthlySavings.toLocaleString();
      document.getElementById('yearly-savings').textContent = '$' + (monthlySavings * 12).toLocaleString();
      document.getElementById('hours-saved').textContent = (hours * 48) + 'h';
    }
    document.getElementById('tools-slider')?.addEventListener('input', updateROI);
    document.getElementById('cost-slider')?.addEventListener('input', updateROI);
    document.getElementById('hours-slider')?.addEventListener('input', updateROI);
  </script>

