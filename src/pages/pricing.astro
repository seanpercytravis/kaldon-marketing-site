  <script is:inline>
    // Pricing toggle
    let isAnnual = true;
    document.getElementById('pricing-toggle')?.addEventListener('click', function() {
      isAnnual = !isAnnual;
      document.getElementById('pricing-toggle-dot').style.transform = isAnnual ? 'translateX(28px)' : 'translateX(0)';
      document.querySelectorAll('.pricing-annual').forEach(el => el.classList.toggle('hidden', !isAnnual));
      document.querySelectorAll('.pricing-monthly').forEach(el => el.classList.toggle('hidden', isAnnual));
      document.getElementById('annual-label').classList.toggle('font-medium', isAnnual);
      document.getElementById('annual-label').classList.toggle('text-[#e2e8f0]', isAnnual);
      document.getElementById('annual-label').classList.toggle('text-[#94a3b8]', !isAnnual);
      document.getElementById('monthly-label').classList.toggle('font-medium', !isAnnual);
      document.getElementById('monthly-label').classList.toggle('text-[#e2e8f0]', !isAnnual);
      document.getElementById('monthly-label').classList.toggle('text-[#94a3b8]', isAnnual);
    });

    // Comparison table toggle
    document.getElementById('toggle-comparison')?.addEventListener('click', function() {
      const table = document.getElementById('comparison-table');
      const isHidden = table.classList.contains('hidden');
      table.classList.toggle('hidden');
      this.textContent = isHidden ? 'Hide Comparison Table ↑' : 'Show Full Comparison Table ↓';
    });

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(btn => {
      btn.addEventListener('click', function() {
        const answer = this.nextElementSibling;
        const chevron = this.querySelector('.faq-chevron');
        const isOpen = !answer.classList.contains('hidden');
        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-chevron').forEach(c => c.style.transform = '');
        if (!isOpen) {
          answer.classList.remove('hidden');
          chevron.style.transform = 'rotate(180deg)';
        }
      });
    });

    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  </script>

