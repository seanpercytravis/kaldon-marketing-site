<script is:inline>
  (function() {
    // Billing toggle. defaults to MONTHLY (matches initial HTML state)
    const toggle = document.getElementById('pricing-toggle');
    const dot = document.getElementById('pricing-toggle-dot');
    const monthlyLabel = document.getElementById('billing-monthly');
    const annualLabel = document.getElementById('billing-annual');
    const annualNotes = document.querySelectorAll('.tier-annual-note');
    if (!toggle) return;
    let annual = false; // default: monthly
    toggle.addEventListener('click', () => {
      annual = !annual;
      toggle.setAttribute('aria-pressed', String(annual));
      dot.style.transform = annual ? 'translateX(24px)' : 'translateX(0)';
      monthlyLabel.style.color = annual ? 'var(--ghost)' : 'var(--chalk)';
      monthlyLabel.style.fontWeight = annual ? '400' : '500';
      annualLabel.style.color = annual ? 'var(--chalk)' : 'var(--ghost)';
      annualLabel.style.fontWeight = annual ? '500' : '400';
      document.querySelectorAll('.tier-amount').forEach(el => {
        el.textContent = annual ? el.dataset.annual : el.dataset.monthly;
      });
      // Hide the "$X/mo with annual" note when annual is already selected
      annualNotes.forEach(n => {
        n.style.visibility = annual ? 'hidden' : 'visible';
      });
    });
  })();
</script>

