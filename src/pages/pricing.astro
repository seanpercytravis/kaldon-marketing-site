  { name: 'Export to PDF', free: false, growth: true, pro: true, scale: true, enterprise: true },
  { name: 'Priority Support', free: false, growth: false, pro: 'Email', scale: 'Email + Chat', enterprise: 'Dedicated' },
  { name: 'API Access', free: false, growth: false, pro: false, scale: false, enterprise: true },
  { name: 'Custom Integrations', free: false, growth: false, pro: false, scale: false, enterprise: true },
  { name: 'Team Members', free: '1', growth: '1', pro: '3', scale: '10', enterprise: 'Unlimited' },
  { name: 'White Label', free: false, growth: false, pro: false, scale: false, enterprise: true },
  { name: 'Onboarding Session', free: false, growth: false, pro: false, scale: '1 session', enterprise: 'Dedicated' },
  { name: 'SLA', free: false, growth: false, pro: false, scale: false, enterprise: '99.9%' },
