          <p class="text-3xl font-extrabold text-[#e2e8f0] mb-1">$0<span class="text-sm font-normal text-[#94a3b8]">/mo</span></p>
          <p class="text-xs text-[#94a3b8] mb-6">Forever free</p>
          <a href="https://kaldon.io/signup" class="block text-center py-2.5 px-4 rounded-lg border border-[rgba(255,255,255,0.08)] text-[#94a3b8] text-sm font-semibold hover:text-[#e2e8f0] hover:border-[rgba(255,255,255,0.15)] transition-all mb-6">Get Started</a>
          <ul class="space-y-2 text-sm text-[#94a3b8] flex-1">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#34d399] shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>2 analyses total</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#34d399] shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>Standard depth</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#34d399] shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>Action plans</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-[#34d399] shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>Command Palette</li>
          </ul>
