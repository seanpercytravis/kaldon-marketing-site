  { name: 'Marketplace Listings', free: false, growth: false, pro: false, scale: true, enterprise: true },
  { name: 'Amazon Listing Generator', free: false, growth: false, pro: false, scale: true, enterprise: true },
  { name: 'Walmart Listing Generator', free: false, growth: false, pro: false, scale: true, enterprise: true },
  { name: 'Social Account Connections', free: false, growth: false, pro: false, scale: true, enterprise: true },
  { name: 'Ad Campaign Management', free: false, growth: false, pro: false, scale: false, enterprise: true },
  { name: 'Meta Ads Integration', free: false, growth: false, pro: false, scale: false, enterprise: true },
