  { name: 'Marketplace Coverage', free: 'Amazon US', growth: 'Amazon US/CA', pro: 'Amazon + Walmart', scale: 'All Marketplaces', enterprise: 'All + Custom' },
  { name: 'AI Product Mockups', free: '2/analysis', growth: '4/analysis', pro: '8/analysis', scale: '12/analysis', enterprise: 'Unlimited' },
  { name: 'Action Plan Generation', free: true, growth: true, pro: true, scale: true, enterprise: true },
  { name: 'AI Coaching', free: false, growth: true, pro: true, scale: true, enterprise: true },
