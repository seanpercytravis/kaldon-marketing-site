const faqs = [
  { q: 'What counts as an analysis?', a: 'One analysis is a complete AI-powered product research report. You enter a product category or idea, and Kaldon runs 9 parallel AI engines across Amazon, Walmart, and DTC to generate a comprehensive report with scoring, market data, AI product mockups, an action plan, and coaching. Each analysis is a separate report.' },
  { q: 'Can I switch plans?', a: 'Yes. You can upgrade or downgrade your plan at any time from your Account Settings. When you upgrade, you get immediate access to the new features. When you downgrade, your current plan stays active until the end of your billing period.' },
  { q: 'What is your refund policy?', a: 'We offer a 14-day money-back guarantee on all subscription plans. If you are not satisfied, contact us at beta@kaldon.io within 14 days of your purchase for a full refund. Single analysis purchases are non-refundable once the report has been generated.' },
  { q: 'Do I need a credit card for the free plan?', a: 'No. The free plan includes 2 analyses with no credit card required. Just sign up with your email and start analyzing products immediately.' },
  { q: 'What happens when I use all my free analyses?', a: 'You can purchase a single analysis for $39.99 (no subscription required) or upgrade to a Growth plan starting at $119/mo (annual) for 5 analyses per month plus access to Brand Vault, Content Calendar, and more.' },
  { q: 'Can I cancel anytime?', a: 'Yes. All plans are cancel-anytime with no long-term contracts. Your access continues until the end of your current billing period.' },
  { q: 'What marketplaces does Kaldon support?', a: 'Kaldon currently supports Amazon (US, CA, UK, DE), Walmart, and DTC (direct-to-consumer). We are actively expanding marketplace coverage. Enterprise plans can include custom marketplace integrations.' },
  { q: 'Is my data secure?', a: 'Yes. All data is encrypted with AES-256 at rest and in transit. We do not share your data with third parties. Your analyses, brands, and content are yours. We are SOC 2 aligned and follow industry best practices for data security.' },
];

function renderCell(val: string | boolean) {
  if (val === true) return '<svg class="w-5 h-5 text-emerald-400 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>';
  if (val === false) return '<svg class="w-5 h-5 text-slate-600 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6" /></svg>';
  return `<span class="text-sm text-slate-300">${val}</span>`;
}
---

<BaseLayout
  title="Kaldon Pricing — Plans for Every Stage of Your eCommerce Journey"
  description="Simple, transparent pricing. Start free with 2 analyses. Growth from $119/mo. Pro from $239/mo. Scale from $399/mo. Enterprise custom pricing."
>

  <!-- Hero -->
  <section class="pt-32 pb-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#22d3ee]/5 via-[#0a0e17] to-[#0a0e17]"></div>
    <div class="container-custom relative z-10 text-center">
      <span class="eyebrow">PRICING</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#e2e8f0] mb-4">Simple, Transparent Pricing</h1>
      <p class="text-lg text-[#94a3b8] max-w-2xl mx-auto mb-2">All plans include 2 free analyses. No credit card required to start.</p>
      <p class="text-sm text-[#94a3b8]">Choose the plan that matches your stage. Upgrade anytime.</p>
    </div>
  </section>

  <!-- Toggle -->
  <section class="pb-8">
    <div class="container-custom">
      <div class="flex items-center justify-center gap-3">
        <span class="text-sm text-[#94a3b8]" id="monthly-label">Monthly</span>
        <button id="pricing-toggle" class="relative w-14 h-7 bg-[#1a2236] rounded-full border border-[rgba(255,255,255,0.08)] transition-colors cursor-pointer" aria-label="Toggle annual pricing">
          <span id="pricing-toggle-dot" class="absolute top-0.5 left-0.5 w-6 h-6 bg-[#22d3ee] rounded-full transition-transform translate-x-7"></span>
        </button>
        <span class="text-sm text-[#e2e8f0] font-medium" id="annual-label">Annual <span class="inline-block ml-1 px-2 py-0.5 bg-[#22d3ee]/10 text-[#22d3ee] text-xs font-bold rounded-full">Save 20%</span></span>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pb-16">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-7xl mx-auto">

        <!-- Free -->
        <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-2xl p-6 flex flex-col">
