---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import Button from '../components/ui/Button.astro';
import LinkArrow from '../components/ui/LinkArrow.astro';
import { appUrl } from '../lib/urls';

// Pricing tiers. annual default, monthly toggle swaps display values
const tiers = [
  {
    name: 'Free',
    monthly: '$0',
    annual: '$0',
    period: 'forever',
    sub: 'See what Kaldon can do',
    cta: 'Start Free',
    href: appUrl('/signup', 'pricing_tier_free', { extra: { plan: 'free' } }),
    features: [
      '2 analyses total',
      'Standard analysis depth',
      'Action plans + AI product mockups',
      'Command Palette (⌘K)',
    ],
  },
  {
    name: 'Growth',
    monthly: '$149',
    annual: '$119',
    period: '/ mo',
    sub: 'For sellers getting serious',
    cta: 'Start Growth',
    href: appUrl('/signup', 'pricing_tier_growth', { extra: { plan: 'growth' } }),
    features: [
      '5 analyses / month',
      'AI Coaching',
      'Brand Vault (1 brand)',
      'Content Calendar (3 platforms)',
      'Brand Board generator',
      'Export to PDF',
    ],
  },
  {
    name: 'Pro',
    monthly: '$299',
    annual: '$239',
    period: '/ mo',
    sub: 'For sellers ready to scale',
    cta: 'Go Pro',
    href: appUrl('/signup', 'pricing_tier_pro', { extra: { plan: 'pro' } }),
    highlight: true,
    features: [
      '15 analyses / month',
      'Everything in Growth',
      'Video Studio (10 recipes)',
      'Landing Page Builder',
      '3 brands + AI Logo',
      'Email support',
    ],
  },
  {
    name: 'Scale',
    monthly: '$499',
    annual: '$399',
    period: '/ mo',
    sub: 'For power sellers and teams',
    cta: 'Start Scale',
    href: appUrl('/signup', 'pricing_tier_scale', { extra: { plan: 'scale' } }),
    features: [
      '100 analyses / month',
      'Everything in Pro',
      'Store Deployment',
      'Blog Engine (auto-publish)',
      'Ad Campaign Management',
      '10 brands',
    ],
  },
  {
    name: 'Enterprise',
    monthly: '$1,499',
    annual: '$1,499',
    period: '/ mo',
    sub: 'Agencies and teams',
    cta: 'Contact Sales',
    href: 'mailto:beta@kaldon.io?subject=Enterprise%20plan%20inquiry',
    features: [
      '300 analyses / month',
      'Everything in Scale',
      'Daily auto-published SEO articles',
      'Dedicated account manager',
      'Custom onboarding',
    ],
  },
];

// Feature comparison table
const featureGroups = [
  {
    label: 'Discover',
    rows: [
      { name: 'AI Product Analyses', free: '2 total', growth: '5 / mo', pro: '15 / mo', scale: '100 / mo', enterprise: '300 / mo' },
      { name: 'Analysis Depth',      free: 'Standard', growth: 'Standard', pro: 'Deep', scale: 'Deep', enterprise: 'Custom' },
      { name: 'Marketplace Coverage', free: 'Amazon US', growth: 'Amazon US + DTC', pro: 'Amazon US + Walmart + DTC', scale: 'Amazon US + Walmart + DTC', enterprise: '+ Custom' },
      { name: 'AI Product Mockups',  free: '2 / analysis', growth: '4 / analysis', pro: '8 / analysis', scale: '12 / analysis', enterprise: 'Unlimited' },
      { name: 'Action Plan Generation', free: true, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'AI Coaching',         free: false, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'Ask AI (Chat)',       free: false, growth: 'Limited', pro: true, scale: true, enterprise: true },
    ],
  },
  {
    label: 'Build',
    rows: [
      { name: 'Brand Vault',         free: false, growth: '1 brand', pro: '3 brands', scale: '10 brands', enterprise: 'Unlimited' },
      { name: 'AI Logo Generation',  free: false, growth: false, pro: true, scale: true, enterprise: true },
      { name: 'Brand Board Generator', free: false, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'Import Brand from Analysis', free: false, growth: true, pro: true, scale: true, enterprise: true },
    ],
  },
  {
    label: 'Create',
    rows: [
      { name: 'Content Calendar',    free: false, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'One-Off Composer',    free: false, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'Multi-Platform Publishing', free: false, growth: '3 platforms', pro: '5 platforms', scale: '5 platforms', enterprise: '5 platforms' },
      { name: 'Video Studio',        free: false, growth: false, pro: true, scale: true, enterprise: true },
      { name: 'Video Recipes',       free: false, growth: false, pro: '10', scale: '10', enterprise: '10 + custom' },
      { name: 'Landing Page Builder', free: false, growth: false, pro: true, scale: true, enterprise: true },
      { name: 'Landing Page Templates', free: false, growth: false, pro: '3', scale: '10', enterprise: 'Unlimited' },
    ],
  },
  {
    label: 'Launch & Grow',
    rows: [
      { name: 'Store Deployment',    free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Blog Engine',         free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Auto-Published SEO Articles', free: false, growth: false, pro: false, scale: 'Weekly', enterprise: 'Daily' },
      { name: 'GEO Optimization',    free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Social Account Connections', free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Ad Campaign Management', free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Meta Ads Integration', free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Customer Retention Tools', free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Performance Analytics', free: false, growth: false, pro: false, scale: 'Basic', enterprise: 'Advanced' },
    ],
  },
  {
    label: 'Platform',
    rows: [
      { name: 'Command Palette (⌘K)', free: true, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'Dark Mode',           free: true, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'Export to PDF',       free: false, growth: true, pro: true, scale: true, enterprise: true },
      { name: 'Priority Support',    free: false, growth: false, pro: 'Email', scale: 'Email + Chat', enterprise: 'Dedicated' },
      { name: 'API Access',          free: false, growth: false, pro: false, scale: true, enterprise: true },
      { name: 'Team Members',        free: '1', growth: '1', pro: '3', scale: '10', enterprise: 'Unlimited' },
      { name: 'Onboarding Session',  free: false, growth: false, pro: false, scale: '1 session', enterprise: 'Dedicated' },
    ],
  },
];

const faqs = [
  {
    q: 'What counts as an analysis?',
    a: 'One analysis is a complete AI-powered product intelligence report. You enter a product category or idea, and Kaldon runs 10 parallel data sources across Amazon, Walmart, and DTC, then Claude synthesizes the findings into a single report with an opportunity score, market data, AI product mockups, an action plan, and coaching. Each analysis is a separate report.',
  },
  {
    q: 'Can I switch plans?',
    a: 'Yes. You can upgrade or downgrade from your Account Settings. Upgrades take effect immediately; downgrades stay on your current plan until the end of your billing period.',
  },
  {
    q: 'What is your refund policy?',
    a: 'We offer a 14-day money-back guarantee on all subscription plans. If you\'re not satisfied, email beta@kaldon.io within 14 days for a full refund. Single analyses are non-refundable once the report is generated.',
  },
  {
    q: 'Do I need a credit card for the free plan?',
    a: 'No. The Free plan includes 2 analyses with no credit card required. Sign up with your email and start analyzing products immediately.',
  },
  {
    q: 'What happens when I use all my free analyses?',
    a: 'You can purchase a single analysis for $39.99 or upgrade to a Growth plan starting at $119/mo (annual) for 5 analyses per month plus Brand Vault, Content Calendar, and more.',
  },
  {
    q: 'Can I cancel anytime?',
    a: 'Yes. All plans are cancel-anytime with no long-term contracts. Your access continues until the end of your current billing period.',
  },
  {
    q: 'What marketplaces does Kaldon support?',
    a: 'Kaldon currently supports Amazon US, Walmart, and DTC (direct-to-consumer). Additional Amazon regions (CA, UK, DE) are on our roadmap. Enterprise plans can include custom marketplace integrations.',
  },
  {
    q: 'Is my data secure?',
    a: 'Yes. Data is encrypted with AES-256-GCM at rest and TLS 1.2+ in transit. Billing is handled by Stripe, so we never store card data. We do not share your data with third parties. Your analyses, brands, and content are yours.',
  },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Kaldon',
    description: 'AI-Powered eCommerce Intelligence Platform',
    offers: [
      { '@type': 'Offer', name: 'Free', price: '0', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Growth', price: '149', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Pro', price: '299', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Scale', price: '499', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Enterprise', price: '1499', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Single Analysis', price: '39.99', priceCurrency: 'USD' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];

function renderCell(val: string | boolean): string {
  if (val === true) {
    return '<svg class="w-4 h-4 mx-auto" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5 L8 14.5 L16 6" stroke="#F5F5F7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>';
  }
  if (val === false) {
    return '<span class="cell-muted" aria-hidden="true">. </span><span class="sr-only">Not included</span>';
  }
  return `<span>${val}</span>`;
}
---

<BaseLayout
  title="Kaldon Pricing. Plans for Every Stage of Your eCommerce Journey"
  description="Simple, transparent pricing. Start free with 2 analyses. Growth from $119/mo. Pro from $239/mo. Scale from $399/mo. Enterprise $1,499/mo."
  structuredData={structuredData}
>
  <PageHero
    kicker="Pricing"
    headline="Premium intelligence. Accessible pricing."
    subhead="Every plan includes full-quality intelligence across all marketplaces. Scale when you're ready."
    stats={[
      { label: 'Plans to pick from', numeral: 5, sub: 'Free · Growth · Pro · Scale · Enterprise' },
      { label: 'Tools it replaces', prefix: '$', numeral: '18k+', sub: 'per year in research, brand, content, store', accent: 'gold' },
      { label: 'Free analyses', numeral: 2, sub: 'No credit card required', accent: 'signal' },
    ]}
  >
    <p class="mt-3 text-small" style="color: var(--ghost);">
      All plans include 2 free analyses. No credit card required to start.
    </p>
  </PageHero>

  <!-- Billing toggle. defaults to monthly so the prices people see on
       first load match what they'll be charged month-to-month. -->
  <section class="pb-6" style="background: var(--void);">
    <div class="container-custom flex items-center justify-center gap-3">
      <span class="text-small" id="billing-monthly" style="color: var(--chalk); font-weight: 500;">Monthly</span>
      <button
        id="pricing-toggle"
        class="relative inline-flex items-center rounded-full border transition-colors"
        style="width: 52px; height: 28px; background: var(--deep-space); border-color: var(--hairline);"
        aria-label="Toggle annual pricing"
        aria-pressed="false"
      >
        <span id="pricing-toggle-dot" class="absolute top-0.5 left-0.5 rounded-full transition-transform" style="width: 22px; height: 22px; background: var(--gold); transform: translateX(0);"></span>
      </button>
      <span class="text-small inline-flex items-center gap-2" id="billing-annual" style="color: var(--ghost);">
        Annual
        <span class="font-mono" style="font-size: 11px; padding: 2px 8px; border-radius: 999px; background: rgba(255, 184, 0, 0.1); color: var(--gold); letter-spacing: 0.04em;">Save 20%</span>
      </span>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="pb-20 md:pb-24" style="background: var(--void);">
    <div class="container-custom">
      <p class="text-center text-small mb-8" style="color: var(--ghost);">
        Join sellers who've replaced $18,000 to $50,000+ per year in tools, consultants, and agencies.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 max-w-7xl mx-auto">
        {tiers.map((t) => (
          <div class={`tier ${t.highlight ? 'tier-highlight' : ''}`}>
            {t.highlight && <span class="tier-badge">Most Popular</span>}
            <p class="tier-name">{t.name}</p>
            <p class="tier-price">
              <span class="tier-amount" data-annual={t.annual} data-monthly={t.monthly}>{t.monthly}</span>
              <span class="tier-period">{t.period}</span>
            </p>
            {t.annual !== t.monthly && (
              <p class="tier-annual-note">
                <span class="tier-annual-amount" data-annual={t.annual} data-monthly={t.monthly}>{t.annual}</span>/mo with annual · <span style="color: var(--gold);">save 20%</span>
              </p>
            )}
            <p class="tier-sub">{t.sub}</p>
            <a
              href={t.href}
              class={t.highlight ? 'btn-primary w-full justify-center' : 'btn-secondary w-full justify-center'}
              style="margin-top: 20px; height: 40px; font-size: 14px;"
              data-event={`pricing_${t.name.toLowerCase()}_cta`}
            >
              {t.cta}
            </a>
            <ul class="tier-features">
              {t.features.map((f) => (
                <li>
                  <svg class="feat-check" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M4 10.5 L8 14.5 L16 6" stroke="#F5F5F7" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="text-center text-small mt-8" style="color: var(--ghost);">
        Need just one report? <span style="color: var(--chalk); font-weight: 500;">Single Analysis. $39.99 one-time</span>, no subscription required.
      </p>
    </div>
  </section>

  <!-- Enterprise "why $1,499" explainer. justify the top tier -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <div class="enterprise-math">
        <div class="enterprise-lede">
          <span class="kicker" style="color: var(--gold);">Why Enterprise is $1,499</span>
          <h2 class="font-display font-semibold mt-2" style="font-weight: 600; font-size: clamp(22px, 2.8vw, 30px); line-height: 1.25; letter-spacing: -0.015em; color: var(--chalk);">
            300 analyses = roughly one month of agency throughput.
          </h2>
        </div>
        <div class="enterprise-math-grid">
          <div class="em-cell">
            <span class="em-label">30</span>
            <span class="em-sub">clients / month</span>
          </div>
          <span class="em-op" aria-hidden="true">×</span>
          <div class="em-cell">
            <span class="em-label">10</span>
            <span class="em-sub">concept vets each</span>
          </div>
          <span class="em-op" aria-hidden="true">=</span>
          <div class="em-cell">
            <span class="em-label em-gold">300</span>
            <span class="em-sub">analyses / month</span>
          </div>
        </div>
        <p class="enterprise-body">
          Enterprise is built for agencies running 20+ active client brands and for in-house teams launching adjacent products monthly. Includes a <span style="color: var(--chalk); font-weight: 500;">dedicated account manager</span>, <span style="color: var(--chalk); font-weight: 500;">custom onboarding</span>, and <span style="color: var(--chalk); font-weight: 500;">daily auto-published SEO content</span> across all client brands. For context, one $5k/mo brand-design agency retainer covers two launches. $1,499 / month covers ten times that.
        </p>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="hairline-t hairline-b" style="background: var(--void);">
    <div class="container-custom py-10 md:py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 max-w-4xl mx-auto">
        <div class="trust-item">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          <span>AES-256-GCM at rest</span>
        </div>
        <div class="trust-item">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <span>TLS 1.2+ in transit</span>
        </div>
        <div class="trust-item">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
          </svg>
          <span>Stripe-powered billing</span>
        </div>
        <div class="trust-item">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Cancel anytime</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature comparison table -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom">
      <header class="max-w-prose mx-auto text-center mb-10 md:mb-14">
        <span class="kicker">Compare Plans</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Every plan detail, transparent.
        </h2>
      </header>

      <div class="comparison-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="sticky-col">Feature</th>
              <th>Free</th>
              <th>Growth</th>
              <th class="highlight">Pro</th>
              <th>Scale</th>
              <th>Enterprise</th>
            </tr>
          </thead>
          <tbody>
            {featureGroups.map((group) => (
              <>
                <tr class="group-row">
                  <td colspan="6" class="group-label">{group.label}</td>
                </tr>
                {group.rows.map((row) => (
                  <tr>
                    <td class="sticky-col feat-name">{row.name}</td>
                    <td set:html={renderCell(row.free)} />
                    <td set:html={renderCell(row.growth)} />
                    <td class="highlight" set:html={renderCell(row.pro)} />
                    <td set:html={renderCell(row.scale)} />
                    <td set:html={renderCell(row.enterprise)} />
                  </tr>
                ))}
              </>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Value comparison -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10">
        <span class="kicker">Value Comparison</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          What you'd pay without Kaldon
        </h2>
      </header>

      <!-- Giant typographic moment: the DIY cost as display type -->
      <div class="diy-anchor">
        <span class="diy-anchor-kicker">Premium DIY tool + freelancer + agency stack</span>
        <p class="diy-anchor-num">
          <span class="diy-strike">$18,000</span>
          <span class="diy-to">to</span>
          <span class="diy-strike">$53,000</span>
          <span class="diy-unit">/ year</span>
        </p>
      </div>

      <div class="rounded-card overflow-hidden" style="border: 1px solid var(--hairline);">
        {[
          { label: 'Premium research (JS Brand Owner + H10 Diamond)', cost: '$1,788–4,788 / yr' },
          { label: 'AI copy + content (Jasper Business + Copy.ai Team)', cost: '$1,788–4,188 / yr' },
          { label: 'AI generation (ChatGPT Pro + Claude Max)', cost: '$720–2,400 / yr' },
          { label: 'Visual + brand design (Canva Teams + Adobe CC + MJ)', cost: '$1,200–3,600 / yr' },
          { label: 'Social scheduling (Later Agency + Hootsuite Business)', cost: '$1,188–2,988 / yr' },
          { label: 'Store + website (Shopify Advanced + theme + apps)', cost: '$5,988–9,588 / yr' },
          { label: 'Per-launch services (photography, listings, brand studio)', cost: '$4,100–25,000' },
        ].map((row, i) => (
          <div class="flex justify-between items-center px-6 py-4" style={`background: ${i % 2 === 0 ? 'rgba(255,255,255,0.015)' : 'transparent'}; border-top: ${i === 0 ? 'none' : '1px solid var(--hairline)'};`}>
            <span class="text-body-sm" style="color: var(--chalk);">{row.label}</span>
            <span class="font-mono text-body-sm" style="color: var(--ghost);">{row.cost}</span>
          </div>
        ))}
        <div class="flex justify-between items-center px-6 py-5" style="border-top: 1px solid var(--hairline); background: rgba(255, 184, 0, 0.06);">
          <span class="font-display font-semibold" style="font-weight: 600; color: var(--chalk); font-size: 15px;">vs Kaldon Pro</span>
          <span class="font-display" style="font-weight: 500; color: var(--gold); font-size: 22px; letter-spacing: -0.02em;">$2,868 / yr <span class="font-mono text-small" style="color: var(--ghost);">($239/mo annual)</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10 md:mb-12">
        <span class="kicker">FAQ</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Frequently asked questions
        </h2>
      </header>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <details class="faq-item" name="pricing-faq">
            <summary class="faq-summary">
              <span class="faq-q">{faq.q}</span>
