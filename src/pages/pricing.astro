  { name: 'One-Off Composer', free: false, growth: true, pro: true, scale: true, enterprise: true },
  { name: 'Multi-Platform Publishing', free: false, growth: '3 platforms', pro: '5 platforms', scale: '5 platforms', enterprise: '5 platforms' },
  { name: 'Video Studio', free: false, growth: false, pro: true, scale: true, enterprise: true },
  { name: 'Video Templates', free: false, growth: false, pro: '5 types', scale: '9 types', enterprise: '9 types + custom' },
