---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import Button from '../../components/ui/Button.astro';
import UseCaseCrossLinks from '../../components/ui/UseCaseCrossLinks.astro';
import { appUrl } from '../../lib/urls';

const painPoints = [
  { title: 'Too much manual work per client', desc: 'Every client launch requires the same 40+ hours of work: product research, brand identity, content creation, store setup. You are the bottleneck. You cannot take on more clients without burning out or hiring more people.' },
  { title: 'Inconsistent quality', desc: "When you're doing everything manually, quality varies. Monday's client gets your best work. Friday's client gets whatever you have left. Your reputation depends on consistency you can't maintain at scale." },
  { title: "Can't scale the business", desc: 'You want to grow from 2 launches per month to 10, but your current process does not allow it. Hiring is expensive and slow. Training takes months. Your revenue is capped by your personal capacity.' },
];

const howItHelps = [
  { title: 'Professional output for every client', desc: "Kaldon generates agency-quality deliverables for every client: brand identities, content calendars, landing pages, and stores. Your Friday client gets the same quality as your Monday client." },
  { title: 'Minutes instead of hours', desc: 'Product analysis takes minutes, not days. Brand generation takes minutes, not weeks. Content creation takes minutes, not hours. You reclaim 30+ hours per client launch.' },
  { title: 'Scale without hiring', desc: 'The Scale plan supports 10 brands from one dashboard. Enterprise supports agencies and teams. Go from 2 launches per month to 10 without adding headcount. Margins improve as you scale.' },
  { title: 'Repeatable process', desc: 'Every client goes through the same 5-phase pipeline. Discover, Build, Create, Launch, Grow. Consistent process means consistent results and predictable timelines.' },
  { title: 'Impress at every touchpoint', desc: 'Share AI analysis reports, brand boards, and content previews with clients at each milestone. They see professional deliverables and feel confident in your process.' },
  { title: 'Dedicated support at Enterprise', desc: 'Enterprise includes a dedicated account manager and custom onboarding. Agencies running 10+ clients get white-glove attention when they need it.' },
];

const economics = [
  { label: 'Your Kaldon cost', value: '$1,499 / mo', sub: 'Enterprise. 10+ clients' },
  { label: 'Client launch fee', value: '$3,000–5,000', sub: 'Per client, your pricing' },
  { label: 'Launches per month', value: '8–10', sub: 'With the Kaldon pipeline' },
  { label: 'Your time per launch', value: '4–6 hrs', sub: 'Down from 40+ hours' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Kaldon for eCommerce Agencies',
    serviceType: 'Agency-Scale eCommerce Intelligence Platform',
    description:
      'Kaldon gives eCommerce agencies an AI-powered pipeline that compresses 40 hours of per-client work into hours, supporting 10+ client brands and consistent agency-quality deliverables.',
    url: 'https://kaldon.io/use-cases/agencies',
    provider: {
      '@type': 'Organization',
      '@id': 'https://kaldon.io/#org',
      name: 'Kaldon',
      url: 'https://kaldon.io',
      logo: 'https://kaldon.io/images/logos/kaldon-logo-dark.svg',
    },
    areaServed: 'Worldwide',
    audience: {
      '@type': 'Audience',
      audienceType: 'eCommerce agencies and consultants',
      name: 'Agencies and teams running multiple client brands',
    },
    offers: {
      '@type': 'Offer',
      price: '1499',
      priceCurrency: 'USD',
      description: 'Enterprise plan at $1,499/mo for agencies running 10+ client brands.',
      availability: 'https://schema.org/InStock',
    },
  },
];
---

<BaseLayout
  title="Kaldon for Agencies. Scale Your Agency with AI"
  description="Help sellers launch products without the 40-hour-per-client bottleneck. Kaldon gives agencies an AI-powered pipeline that produces agency-quality deliverables in minutes."
  structuredData={structuredData}
>
  <PageHero
    kicker="For Agencies"
    headline="Ship new products for clients. In hours, not weeks."
    subhead="Your clients don't need another market report. They need a shippable new product. Kaldon compresses 40 hours per client into one afternoon: unmet-demand discovery, validated UVP, verified supplier, on-brand launch assets, live store. Move from 2 launches a month to 10 without hiring."
    stats={[
      { label: 'Hours per client', numeral: '4–6', sub: 'Down from 40+', accent: 'gold' },
      { label: 'Launches per month', numeral: '8–10', sub: 'Up from 2', accent: 'signal' },
      { label: 'Value per client', prefix: '$', numeral: '10k', suffix: '+', sub: 'Deliverable parity with agencies' },
    ]}
  >
    <div class="mt-8 flex justify-center">
      <Button variant="primary" size="large" href={appUrl('/signup', 'use_cases_agencies_hero')} data-event="agencies_hero_cta">
        Start Free, 2 Analyses Included
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
        </svg>
      </Button>
    </div>
  </PageHero>

  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="max-w-prose mx-auto text-center mb-12">
        <span class="kicker">The agency bottleneck</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Why you can't take on more clients.
        </h2>
      </header>
      <div class="grid md:grid-cols-3 gap-4">
        {painPoints.map((p, i) => (
          <div class="use-card">
            <span class="use-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="use-title">{p.title}</h3>
            <p class="use-body">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="max-w-prose mx-auto text-center mb-12">
        <span class="kicker">What Kaldon unlocks</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Deliver more. Consistently. Profitably.
        </h2>
      </header>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {howItHelps.map((item) => (
          <div class="use-card">
            <h3 class="use-title">{item.title}</h3>
            <p class="use-body">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-4xl">
      <header class="text-center mb-10">
        <span class="kicker">The economics</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Simple math for scaling agencies.
        </h2>
      </header>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        {economics.map((e) => (
          <div class="econ-card">
            <span class="econ-label">{e.label}</span>
            <p class="econ-value">{e.value}</p>
            <span class="econ-sub">{e.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <UseCaseCrossLinks current="agencies" />

  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        More clients. Less work. Better margins.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Start free. See what agency-grade output at AI speed feels like.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href={appUrl('/signup', 'use_cases_agencies_final')} data-event="agencies_final_cta">
          Start Free, 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .use-card { padding: 26px 24px; background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; transition: border-color 160ms var(--ease-out-quad); }
  .use-card:hover { border-color: var(--hairline-active); }
  .use-num { display: block; font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--gold); letter-spacing: -0.01em; margin-bottom: 10px; }
  .use-title { font-family: var(--font-display); font-weight: 600; font-size: 17px; color: var(--chalk); letter-spacing: -0.01em; margin-bottom: 8px; }
  .use-body { font-size: 14px; line-height: 1.55; color: var(--ghost); letter-spacing: -0.005em; }

  .econ-card { padding: 20px; background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; text-align: center; }
  .econ-label { display: block; font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ghost); font-weight: 500; margin-bottom: 8px; }
  .econ-value { font-family: var(--font-display); font-weight: 500; font-size: 24px; letter-spacing: -0.025em; color: var(--gold); line-height: 1; }
  .econ-sub { display: block; margin-top: 8px; font-size: 12px; color: var(--ghost); line-height: 1.4; }
</style>
