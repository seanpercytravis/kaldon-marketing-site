---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import Button from '../../components/ui/Button.astro';

const painPoints = [
  { title: 'Stuck on one marketplace', desc: 'All your revenue comes from Amazon. One algorithm change, one policy update, one suspended listing — and your income disappears overnight. You know diversification is critical, but you don\'t have time to figure out Walmart, DTC, and social commerce on your own.' },
  { title: 'No DTC presence', desc: "You're building someone else's brand on someone else's platform. Your customers don't know your name. You have no email list, no direct relationship, and no way to market to them outside of Amazon. Your margins are shrinking and you have no leverage." },
  { title: 'Brand feels amateur', desc: 'Your listings convert, but your brand wouldn\'t survive outside Amazon. Your logo was made in 10 minutes. Your social media is inconsistent or nonexistent. Wholesale buyers and retail partners take one look at your brand and pass.' },
];

const howItHelps = [
  { title: 'Multi-marketplace intelligence', desc: "Kaldon's Vet Product mode analyzes your existing ASINs and identifies expansion opportunities across Walmart, DTC, and emerging channels. Data-driven expansion, not guesswork." },
  { title: 'Professional brand building', desc: 'Generate a complete brand identity from your existing product data: logo, colors, typography, voice. Your brand goes from amateur to premium in minutes.' },
  { title: 'One-click store deployment', desc: 'Deploy a full DTC store with checkout, automated emails, SMS, chatbot, and blog engine. Your Amazon customers start finding you directly. Your margins improve.' },
  { title: 'Unified content management', desc: 'Manage content across Amazon, Walmart, your DTC store, and 5 social platforms from one dashboard. Consistent brand voice everywhere.' },
  { title: 'Auto-published SEO blog', desc: 'Hands-free autopilot: AI writes GEO-optimized SEO articles in your brand voice and auto-publishes on a weekly schedule. Structured data baked in.' },
  { title: 'GEO optimization', desc: 'Generative Engine Optimization ensures your brand surfaces in AI-powered search results and recommendation engines. Future-proof your discoverability.' },
];

const results = [
  'Revenue diversified across 3+ channels instead of dependent on one',
  'Direct customer relationships with email list and DTC store',
  'Professional brand identity that commands premium pricing',
  'Walmart intelligence and DTC storefront alongside your Amazon presence',
  'Automated content and marketing across every channel',
  'Higher margins on DTC sales without marketplace fees',
];
---

<BaseLayout
  title="Kaldon for Existing Brands — Expand Beyond Amazon"
  description="You already sell. Kaldon takes your existing brand multi-channel: Walmart, DTC, social — with intelligence, auto-generated content, and direct customer relationships."
>
  <PageHero
    kicker="For Existing Brands"
    headline="New products for your existing brand. From demand signal to shelf."
    subhead="You're already selling. You know the category, the customer, the unit economics. Kaldon surfaces the unmet-demand adjacent products your brand can own next — validates the UVP, verifies a supplier, generates the on-brand launch assets, and expands your presence across Walmart and DTC while you keep shipping the current line."
  >
    <div class="mt-8 flex justify-center">
      <Button variant="primary" size="large" href="https://kaldon.io/signup" data-event="existing_brands_hero_cta">
        Start Free — 2 Analyses Included
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
        </svg>
      </Button>
    </div>
  </PageHero>

  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="max-w-prose mx-auto text-center mb-12">
        <span class="kicker">Where you're stuck</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Three walls every Amazon seller hits.
        </h2>
      </header>
      <div class="grid md:grid-cols-3 gap-4">
        {painPoints.map((p, i) => (
          <div class="use-card">
            <span class="use-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="use-title">{p.title}</h3>
            <p class="use-body">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <header class="max-w-prose mx-auto text-center mb-12">
        <span class="kicker">What changes with Kaldon</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          Take what you've built multi-channel.
        </h2>
      </header>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {howItHelps.map((item) => (
          <div class="use-card">
            <h3 class="use-title">{item.title}</h3>
            <p class="use-body">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-3xl">
      <header class="text-center mb-10">
        <span class="kicker">The outcome</span>
        <h2 class="font-display font-semibold" style="font-weight: 600; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; letter-spacing: -0.015em; color: var(--chalk);">
          What your business looks like six months later.
        </h2>
      </header>
      <ul class="results-list">
        {results.map((r) => (
          <li>
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10.5 L8 14.5 L16 6" stroke="#FFB800" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        One channel today. Every channel tomorrow.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        Start free. 2 analyses. Import your brand in minutes.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href="https://kaldon.io/signup" data-event="existing_brands_final_cta">
          Start Free — 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .use-card { padding: 26px 24px; background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; transition: border-color 160ms var(--ease-out-quad); }
  .use-card:hover { border-color: var(--hairline-active); }
  .use-num { display: block; font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--gold); letter-spacing: -0.01em; margin-bottom: 10px; }
  .use-title { font-family: var(--font-display); font-weight: 600; font-size: 17px; color: var(--chalk); letter-spacing: -0.01em; margin-bottom: 8px; }
  .use-body { font-size: 14px; line-height: 1.55; color: var(--ghost); letter-spacing: -0.005em; }

  .results-list { display: flex; flex-direction: column; gap: 14px; padding: 32px; background: var(--deep-space); border: 1px solid var(--hairline); border-radius: 12px; }
  .results-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 15px; line-height: 1.55; color: var(--text-secondary); letter-spacing: -0.005em; }
  .results-list svg { flex-shrink: 0; margin-top: 4px; }
</style>
