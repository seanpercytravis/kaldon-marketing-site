---
import BaseLayout from '../layouts/BaseLayout.astro';

const personas = [
  {
    name: 'The Aspiring Launcher',
    tagline: 'I have a product idea but no idea where to start.',
    gradient: 'from-[#22d3ee] to-[#3b82f6]',
    color: '#22d3ee',
    icon: '🚀',
    challenge: 'You have been researching products for weeks. You have 47 browser tabs open. You have spreadsheets comparing niches, but you still do not know if your idea is actually viable. Every tool you try gives you data, but none of them tell you what to do with it. You are stuck in analysis paralysis, spending money on subscriptions and getting no closer to launching.',
    helps: [
      'AI Analysis Engine scores your product idea across 9 data sources and tells you if it is worth pursuing',
      'Action Plan gives you a step-by-step roadmap with timelines, not just data',
      'AI Coaching walks you through every decision so you never feel lost',
      'Brand Vault generates your entire brand identity from your analysis data',
      'Content Calendar creates a month of social content before you even have inventory',
    ],
    outcome: 'You go from "I think this might work" to "I have a scored analysis, a professional brand, a month of content, and a launch plan" in a single afternoon. No experience required. No guesswork. Just intelligence.',
    dayInLife: 'Monday morning. You type "premium insulated water bottles" into Kaldon. By lunch, you have a 92-score analysis with AI product mockups, a competitive breakdown, and a step-by-step action plan. By Tuesday, your brand identity is generated: logo, colors, voice. By Wednesday, you have a month of social content scheduled across 5 platforms. By Thursday, your landing page is live. You spent $149 total. Your friends think you hired an agency.',
    cta: 'Start Your First Analysis',
  },
  {
    name: 'The Expanding Seller',
    tagline: 'I am selling on Amazon but want to go DTC and multi-channel.',
    gradient: 'from-[#fb923c] to-[#fbbf24]',
    color: '#fb923c',
    icon: '📈',
    challenge: 'You are making sales on Amazon, but you are dependent on one marketplace. Amazon changes a policy, and your revenue drops 30% overnight. You know you need your own store, your own brand, your own audience. But building a DTC presence from scratch while managing your Amazon business feels impossible. You do not have time to learn Shopify, Canva, Jasper, and Meta Ads Manager on top of everything else.',
    helps: [
      'Vet Product mode analyzes your existing Amazon listings and identifies DTC expansion opportunities',
      'Brand Vault creates a professional brand identity that works across Amazon, Walmart, and your own store',
      'Store Deployment launches a complete DTC store with checkout, emails, and chatbot in one click',
      'Marketplace Listings generates optimized listings for Walmart and other channels',
      'Content Calendar manages content across all your channels from one dashboard',
    ],
    outcome: 'You stop being dependent on one marketplace. You have your own brand, your own store, your own audience. When Amazon changes a policy, you shrug. Your revenue is diversified, your brand is professional, and your customers know you by name.',
    dayInLife: 'You paste your top Amazon ASIN into Kaldon. The Vet Product analysis shows a DTC opportunity score of 87. You click "Build Brand" and Kaldon generates a complete identity from your existing product data. You click "Deploy Store" and your DTC store is live with your brand, your products, and automated marketing. Your Amazon customers start finding you directly. Your margins improve. Your stress decreases.',
    cta: 'Expand Your Business',
  },
  {
    name: 'The Brand Builder',
    tagline: 'I have products but my brand feels amateur.',
    gradient: 'from-[#a78bfa] to-[#f472b6]',
    color: '#a78bfa',
    icon: '🎨',
    challenge: 'You are selling products, but your brand looks like it was made in Microsoft Paint. Your logo is clip art. Your social media is inconsistent. Your product photos are taken on your kitchen counter. You know that a professional brand would command higher prices and more trust, but hiring a branding agency costs $5,000 to $15,000 and takes months. You cannot justify that spend at your current stage.',
    helps: [
      'AI generates a complete brand identity: logo concepts, color palette, typography, voice guidelines',
      'Brand Board Generator creates a professional brand presentation for partners and manufacturers',
      'Video Studio produces 9 types of branded videos with your identity baked in',
      'Landing Page Builder creates conversion-optimized pages that look like a design agency built them',
      'Everything matches automatically because your brand flows through the entire pipeline',
    ],
    outcome: 'Your brand looks like you spent $10,000 on it. Your social media is consistent. Your product pages convert better. Your wholesale partners take you seriously. Customers pay premium prices because your brand communicates premium quality. And it took you 15 minutes, not 3 months.',
    dayInLife: 'You open Kaldon and click "Build Brand." You answer a few questions about your products and audience. Kaldon generates three logo concepts, a color palette, typography pairings, and voice guidelines. You pick your favorite, lock it, and suddenly every piece of content Kaldon creates matches your brand perfectly. Your Instagram looks curated. Your landing page looks expensive. Your competitors wonder who you hired.',
    cta: 'Build Your Brand',
  },
  {
    name: 'The Coach / Agency',
    tagline: 'I help sellers launch products and need better tools.',
    gradient: 'from-[#34d399] to-[#22d3ee]',
    color: '#34d399',
    icon: '🏢',
    challenge: 'You coach eCommerce sellers or run a small agency. Every client needs the same thing: product research, brand identity, content, and a store. But you are doing it manually for each client, using 6 different tools, and spending 40+ hours per launch. You cannot scale because your time is the bottleneck. You need a system that makes every client launch look professional without you doing all the work.',
    helps: [
      'Run analyses for clients in minutes instead of hours of manual research',
      'Generate complete brand identities that clients think you designed yourself',
      'Create a month of content per client without hiring a content team',
      'Deploy stores for clients with one click instead of weeks of Shopify setup',
      'Scale plan supports 10 brands, so you can manage multiple clients from one dashboard',
    ],
    outcome: 'You go from launching 2 clients per month to 10. Each client gets a professional brand, a month of content, and a live store. They think you are a genius. You charge premium rates because the output is premium. Your agency grows without hiring more people.',
    dayInLife: 'A new client signs up on Monday. By Monday afternoon, you have run their product analysis and shared the report. By Tuesday, their brand identity is generated and approved. By Wednesday, their content calendar is populated and their landing page is live. By Thursday, their store is deployed. The client is amazed. You invoice them for $3,000. Kaldon cost you $399/month. You take Friday off.',
    cta: 'Scale Your Agency',
  },
];
---

<BaseLayout
  title="Who Kaldon Is For — eCommerce Sellers at Every Stage"
  description="Whether you are launching your first product, expanding from Amazon to DTC, building a brand, or scaling an agency, Kaldon is built for your stage."
>

  <!-- Hero -->
  <section class="pt-32 pb-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#22d3ee]/5 via-[#0a0e17] to-[#0a0e17]"></div>
    <div class="container-custom relative z-10 text-center">
      <span class="eyebrow">WHO IT'S FOR</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#e2e8f0] mb-4">Built for Your Stage.<br/>Designed for Your Goals.</h1>
      <p class="text-lg text-[#94a3b8] max-w-2xl mx-auto">Whether you are researching your first product or scaling your tenth brand, Kaldon meets you where you are and takes you where you want to go.</p>
    </div>
  </section>

  <!-- Personas -->
  {personas.map((p, i) => (
    <section class={`py-20 ${i % 2 === 0 ? 'bg-[#0a0e17]' : 'bg-[#111827]/30'}`}>
      <div class="container-custom max-w-5xl">
        <div class="animate-on-scroll">
          <!-- Header -->
          <div class="flex items-center gap-4 mb-8">
            <span class="text-4xl">{p.icon}</span>
            <div>
              <h2 class="text-2xl md:text-3xl font-bold text-[#e2e8f0]">{p.name}</h2>
              <p class="text-lg italic" style={`color: ${p.color}`}>"{p.tagline}"</p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <!-- Left column -->
            <div class="space-y-6">
              <!-- Challenge -->
              <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl p-6">
                <h3 class="text-sm font-bold uppercase tracking-wider text-[#f87171] mb-3">The Challenge</h3>
                <p class="text-[#94a3b8] text-sm leading-relaxed">{p.challenge}</p>
              </div>

              <!-- How Kaldon Helps -->
              <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl p-6" style={`border-top: 3px solid ${p.color}`}>
                <h3 class="text-sm font-bold uppercase tracking-wider mb-3" style={`color: ${p.color}`}>How Kaldon Helps</h3>
                <ul class="space-y-2">
                  {p.helps.map(h => (
                    <li class="flex items-start gap-2 text-sm text-[#94a3b8]">
                      <svg class="w-4 h-4 shrink-0 mt-0.5" style={`color: ${p.color}`} fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                      {h}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Right column -->
            <div class="space-y-6">
              <!-- Outcome -->
              <div class="bg-[#1a2236] border border-[rgba(255,255,255,0.08)] rounded-xl p-6" style={`border-left: 3px solid ${p.color}`}>
                <h3 class="text-sm font-bold uppercase tracking-wider text-[#34d399] mb-3">The Outcome</h3>
                <p class="text-[#e2e8f0] text-sm leading-relaxed">{p.outcome}</p>
              </div>

              <!-- Day in the Life -->
              <div class="bg-[#111827] border border-[rgba(255,255,255,0.08)] rounded-xl p-6">
                <h3 class="text-sm font-bold uppercase tracking-wider text-[#94a3b8] mb-3">A Day in Your Life with Kaldon</h3>
                <p class="text-[#94a3b8] text-sm leading-relaxed italic">{p.dayInLife}</p>
              </div>

              <!-- CTA -->
              <a href="https://kaldon.io/signup" class="inline-flex items-center gap-2 py-3 px-6 rounded-lg font-semibold text-sm transition-all hover:scale-[1.02]" style={`background: ${p.color}; color: #0a0e17`}>
                {p.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Final CTA -->
  <section class="section-spacing relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#22d3ee]/10 via-[#0a0e17] to-[#a78bfa]/10"></div>
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#e2e8f0] mb-4">No Matter Your Stage, Kaldon Gets You There Faster</h2>
      <p class="text-lg text-[#94a3b8] mb-8">2 free analyses. No credit card. Start in 60 seconds.</p>
      <a href="https://kaldon.io/signup" class="btn-primary btn-large btn-glow inline-flex items-center gap-2">Start Free <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></a>
    </div>
  </section>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  </script>
</BaseLayout>
