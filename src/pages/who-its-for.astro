---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import Button from '../components/ui/Button.astro';

const segments = [
  {
    num: '01',
    kicker: 'New Sellers',
    title: 'The aspiring launcher',
    tagline: "I have a product idea but no idea where to start.",
    body: "Weeks of research, 47 open browser tabs, and spreadsheets comparing niches — and you still don't know if your idea is viable. Every tool gives you data, none tell you what to do with it. Kaldon collapses research, brand, content, and launch into one guided pipeline.",
    href: '/use-cases/new-sellers',
  },
  {
    num: '02',
    kicker: 'Existing Brands',
    title: 'The expanding seller',
    tagline: "I'm selling on Amazon and need to go multi-channel.",
    body: "You're making sales but dependent on one marketplace. Amazon changes a policy, your revenue drops 30% overnight. Kaldon analyzes your existing ASINs, generates a DTC-ready brand, deploys your store, and gives you intelligence across Walmart and DTC without you learning six new tools.",
    href: '/use-cases/existing-brands',
  },
  {
    num: '03',
    kicker: 'Agencies',
    title: 'The scaling operator',
    tagline: "I run an agency and can't scale past a handful of clients.",
    body: "Every client launch takes 40+ hours and quality varies when you're stretched thin. Kaldon compresses the work into an afternoon per client, produces agency-quality deliverables every time, and lets you move from 2 launches/mo to 10 without hiring.",
    href: '/use-cases/agencies',
  },
];
---

<BaseLayout
  title="Who Kaldon Is For — From First-Time Sellers to Scaling Agencies"
  description="Whether you're launching your first product, expanding beyond Amazon, or running an agency, Kaldon fits your stage. See the three seller profiles we're built for."
>
  <PageHero
    kicker="Who It's For"
    headline="Three profiles. One pipeline."
    subhead="Whether you're launching your first product, expanding beyond Amazon, or running an agency — Kaldon adapts to the stage you're at."
  />

  <section class="section-spacing" style="background: var(--void);">
    <div class="container-custom max-w-5xl">
      <div class="grid gap-4">
        {segments.map((s) => (
          <a href={s.href} class="segment-card">
            <div class="segment-left">
              <span class="segment-num">{s.num}</span>
              <span class="segment-kicker">{s.kicker}</span>
            </div>
            <div class="segment-right">
              <h2 class="segment-title">{s.title}</h2>
              <p class="segment-tagline">"{s.tagline}"</p>
              <p class="segment-body">{s.body}</p>
              <span class="link-arrow mt-5">
                See the full playbook
                <span class="arrow" aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-spacing-lg relative overflow-hidden" style="background: var(--void);">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 24px 24px; -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%); mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);"
      aria-hidden="true"
    ></div>
    <div class="container-custom relative z-10 text-center max-w-prose mx-auto">
      <h2 class="font-display" style="font-weight: 500; font-size: clamp(32px, 4.5vw, 48px); line-height: 1.08; letter-spacing: -0.022em; color: var(--chalk);">
        Not sure which fits? Start free and find out.
      </h2>
      <p class="mt-5 text-body-lg" style="color: var(--ghost);">
        2 analyses. No credit card. See exactly what Kaldon delivers before you commit.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="large" href="https://kaldon.io/signup" data-event="who_final_cta">
          Start Free — 2 Analyses Included
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .segment-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 32px;
    background: var(--deep-space);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    transition: border-color 160ms var(--ease-out-quad);
  }
  .segment-card:hover { border-color: var(--hairline-active); }
  .segment-card:hover .arrow { transform: translateX(3px); }

  @media (min-width: 768px) {
    .segment-card { grid-template-columns: 180px 1fr; gap: 40px; }
  }

  .segment-left { display: flex; flex-direction: column; gap: 6px; }
  .segment-num {
    font-family: var(--font-mono);
    font-size: 48px;
    font-weight: 400;
    line-height: 1;
    color: var(--gold);
    letter-spacing: -0.04em;
  }
  .segment-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ghost);
    font-weight: 500;
  }

  .segment-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    color: var(--chalk);
    letter-spacing: -0.015em;
  }
  .segment-tagline {
    margin-top: 8px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 16px;
    color: var(--signal);
    letter-spacing: -0.01em;
  }
  .segment-body {
    margin-top: 14px;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--ghost);
    letter-spacing: -0.005em;
  }
</style>
